{
  "name": "@mesh/upower-power",
  "version": "0.1.0",
  "description": "Power/battery backend reading state via the upower CLI.",
  "private": true,
  "mesh": {
    "apiVersion": "0.1",
    "kind": "backend",
    "uses": {
      "capabilities": [
        "exec.upower"
      ],
      "binaries": [
        {
          "name": "upower",
          "reason": "Battery state, charge level, and rate.",
          "packages": {
            "debian": "upower",
            "arch": "upower",
            "fedora": "upower",
            "nixos": "upower"
          }
        }
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": ["en"]
    },
    "entry": "src/main.luau",
    "interfaces": [
      {
        "name": "mesh.power",
        "version": "1.0",
        "domain": "power",
        "relationship": "base",
        "contract": {
          "state": [
            {
              "name": "available",
              "type": "boolean",
              "description": "Whether the power service is reachable and a battery is present"
            },
            {
              "name": "level",
              "type": "float",
              "description": "Battery charge as a percentage (0.0-100.0)"
            },
            {
              "name": "charging",
              "type": "boolean",
              "description": "Whether the battery is currently charging"
            },
            {
              "name": "time_remaining_minutes",
              "type": "float",
              "description": "Estimated minutes of remaining runtime on battery (0 if unknown/charging)"
            },
            {
              "name": "time_to_full_minutes",
              "type": "float",
              "description": "Estimated minutes until full charge while charging (0 if unknown/discharging)"
            },
            {
              "name": "power_draw_watts",
              "type": "float",
              "description": "Instantaneous power draw or charge rate in watts"
            },
            {
              "name": "energy_now_watt_hours",
              "type": "float",
              "description": "Current stored energy in watt-hours"
            },
            {
              "name": "energy_full_watt_hours",
              "type": "float",
              "description": "Full-charge energy capacity in watt-hours"
            },
            {
              "name": "source_module",
              "type": "string",
              "description": "Backend module ID that emitted this state (runtime-additive)"
            }
          ],
          "events": [
            {
              "name": "BatteryChanged",
              "payload": [
                { "name": "level", "type": "float" },
                { "name": "charging", "type": "boolean" }
              ]
            }
          ],
          "capabilities": {
            "required": ["service.power.read"]
          }
        }
      }
    ],
    "implements": [
      {
        "interface": "mesh.power",
        "version": "1.0",
        "provider": "upower",
        "label": "UPower",
        "priority": 100
      }
    ]
  }
}
