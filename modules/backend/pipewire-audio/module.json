{
  "name": "@mesh/pipewire-audio",
  "version": "0.1.0",
  "description": "Audio backend using PipeWire",
  "private": true,
  "mesh": {
    "apiVersion": "0.1",
    "kind": "backend",
    "capabilities": {
      "required": [
        "exec.wpctl",
        "service.audio.read",
        "service.audio.control"
      ],
      "optional": [
        "exec.aplay",
        "exec.pw-mon"
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": ["en"]
    },
    "dependencies": {
      "binaries": [
        {
          "name": "wpctl",
          "reason": "PipeWire volume and mute control.",
          "packages": {
            "debian": "wireplumber",
            "arch": "wireplumber",
            "fedora": "wireplumber"
          }
        },
        {
          "name": "pw-mon",
          "reason": "Live subscription to PipeWire object changes for event-driven volume updates.",
          "optional": true,
          "packages": {
            "debian": "pipewire-bin",
            "arch": "pipewire",
            "fedora": "pipewire"
          }
        },
        {
          "name": "aplay",
          "reason": "Playback for shell sound effects.",
          "optional": true,
          "packages": {
            "debian": "alsa-utils",
            "arch": "alsa-utils",
            "fedora": "alsa-utils"
          }
        }
      ]
    },
    "entrypoints": {
      "main": "src/main.luau"
    },
    "implements": [
      {
        "interface": "mesh.audio",
        "version": "1.0",
        "baseModule": "@mesh/audio-interface",
        "provider": "pipewire",
        "label": "PipeWire",
        "priority": 100
      }
    ]
  }
}
