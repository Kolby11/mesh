{
  "id": "@mesh/pulseaudio-audio",
  "name": "MESH PulseAudio",
  "version": "0.1.0",
  "type": "backend",
  "api_version": "0.1",
  "description": "Audio backend using PulseAudio",
  "authors": ["MESH Project"],
  "capabilities": {
    "required": [
      "exec.pactl"
    ],
    "optional": [
      "exec.aplay"
    ]
  },
  "dependencies": {
    "modules": {
      "@mesh/audio-interface": ">=1.0.0, <2.0.0"
    },
    "binaries": [
      {
        "name": "pactl",
        "reason": "PulseAudio volume and mute control.",
        "packages": {
          "debian": "pulseaudio-utils",
          "arch": "libpulse",
          "fedora": "pulseaudio-utils"
        }
      },
      {
        "name": "aplay",
        "reason": "Playback for shell sound effects.",
        "optional": true,
        "packages": {
          "debian": "alsa-utils",
          "arch": "alsa-utils",
          "fedora": "alsa-utils"
        }
      }
    ]
  },
  "entrypoints": {
    "main": "src/main.luau"
  },
  "provides": [
    {
      "interface": "mesh.audio",
      "version": "1.0",
      "base_module": "@mesh/audio-interface",
      "backend_name": "PulseAudio",
      "priority": 50
    }
  ]
}
