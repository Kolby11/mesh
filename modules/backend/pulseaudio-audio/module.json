{
  "name": "@mesh/pulseaudio-audio",
  "version": "0.1.0",
  "description": "Audio backend using PulseAudio",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "backend",
    "capabilities": {
      "required": [
        "exec.pactl",
        "service.audio.read",
        "service.audio.control"
      ],
      "optional": [
        "exec.aplay"
      ]
    },
    "dependencies": {
      "modules": {
        "@mesh/audio-interface": ">=1.0.0, <2.0.0"
      },
      "binaries": [
        {
          "name": "pactl",
          "reason": "PulseAudio volume, mute control, and live subscription to sink events.",
          "packages": {
            "debian": "pulseaudio-utils",
            "arch": "libpulse",
            "fedora": "pulseaudio-utils"
          }
        },
        {
          "name": "aplay",
          "reason": "Playback for shell sound effects.",
          "optional": true,
          "packages": {
            "debian": "alsa-utils",
            "arch": "alsa-utils",
            "fedora": "alsa-utils"
          }
        }
      ]
    },
    "entrypoints": {
      "main": "src/main.luau"
    },
    "implements": [
      {
        "interface": "mesh.audio",
        "version": "1.0",
        "baseModule": "@mesh/audio-interface",
        "provider": "pulseaudio",
        "label": "PulseAudio",
        "priority": 50
      }
    ]
  }
}
