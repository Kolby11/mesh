{
  "name": "@mesh/hyprland-wm",
  "version": "0.1.0",
  "description": "Hyprland compositor backend — workspace and window state via hyprctl.",
  "private": true,
  "mesh": {
    "apiVersion": "0.1",
    "kind": "backend",
    "uses": {
      "capabilities": [
        "exec.hyprctl",
        "exec.sh"
      ],
      "optionalCapabilities": [
        "exec.socat",
        "exec.nc"
      ],
      "binaries": [
        {
          "name": "hyprctl",
          "reason": "Query active workspace, active window, and dispatch workspace switches.",
          "packages": {
            "arch": "hyprland",
            "nixos": "hyprland"
          }
        },
        {
          "name": "socat",
          "reason": "Stream Hyprland IPC events for instant workspace/window change updates (preferred over nc).",
          "optional": true,
          "packages": {
            "debian": "socat",
            "arch": "socat",
            "fedora": "socat",
            "nixos": "socat"
          }
        },
        {
          "name": "nc",
          "reason": "Fallback stream reader for the Hyprland event socket when socat is not available.",
          "optional": true,
          "packages": {
            "debian": "netcat-openbsd",
            "arch": "openbsd-netcat",
            "fedora": "nmap-ncat",
            "nixos": "netcat-openbsd"
          }
        }
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": ["en"]
    },
    "entry": "src/main.luau",
    "interfaces": [
      {
        "name": "mesh.wm",
        "version": "1.0",
        "domain": "wm",
        "relationship": "base",
        "contract": {
          "state": [
            {
              "name": "available",
              "type": "boolean",
              "description": "Whether the compositor is running and reachable"
            },
            {
              "name": "active_workspace",
              "type": "int",
              "description": "ID of the currently active workspace (1-based)"
            },
            {
              "name": "active_window",
              "type": "object?",
              "description": "Active window info: { title, class } — nil when the desktop is focused"
            },
            {
              "name": "workspaces",
              "type": "Workspace[]",
              "description": "List of known workspaces"
            },
            {
              "name": "source_module",
              "type": "string",
              "description": "Backend module ID that emitted this state (runtime-additive)"
            }
          ],
          "methods": [
            {
              "name": "focus_workspace",
              "args": [{ "name": "id", "type": "int" }],
              "returns": "Result"
            }
          ],
          "events": [
            {
              "name": "WorkspaceChanged",
              "payload": [
                { "name": "id", "type": "int" },
                { "name": "name", "type": "string" }
              ]
            },
            {
              "name": "WindowChanged",
              "payload": [
                { "name": "title", "type": "string" },
                { "name": "class", "type": "string" }
              ]
            }
          ],
          "types": {
            "Workspace": {
              "fields": [
                { "name": "id", "type": "int" },
                { "name": "name", "type": "string" },
                { "name": "windows", "type": "int" }
              ]
            }
          },
          "capabilities": {
            "required": ["service.wm.read"],
            "optional": ["service.wm.control"]
          }
        }
      }
    ],
    "implements": [
      {
        "interface": "mesh.wm",
        "version": "1.0",
        "provider": "hyprland",
        "label": "Hyprland",
        "priority": 100
      }
    ]
  }
}
