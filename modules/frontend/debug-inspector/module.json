{
  "name": "@mesh/debug-inspector",
  "version": "0.1.0",
  "description": "Shell-shipped debug inspector surface for profiling and live shell diagnostics.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "interfaces": {
        "mesh.debug": ">=1.0"
      },
      "capabilities": [
        "shell.surface",
        "service.debug.read",
        "locale.read"
      ]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "right",
      "layer": "overlay",
      "width": 320,
      "height": 0,
      "exclusive_zone": 0,
      "keyboard_mode": "on_demand",
      "visible_on_start": false,
      "size": "fixed"
    },
    "accessibility": {
      "role": "dialog",
      "label": "Debug inspector",
      "description": "Debug-only profiling and shell inspection panel"
    }
  }
}
