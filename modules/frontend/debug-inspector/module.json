{
  "id": "@mesh/debug-inspector",
  "name": "Debug Inspector",
  "version": "0.1.0",
  "type": "surface",
  "api_version": "0.1",
  "description": "Shell-shipped debug inspector surface for profiling and live shell diagnostics.",
  "authors": [
    "MESH Project"
  ],
  "compatibility": {
    "mesh": ">=0.1.0",
    "compositors": [
      "wlr-layer-shell-v1"
    ]
  },
  "capabilities": {
    "required": [
      "shell.surface",
      "service.debug.read",
      "locale.read"
    ]
  },
  "entrypoints": {
    "main": "src/main.mesh"
  },
  "settings": {
    "namespace": "@mesh/debug-inspector",
    "schema": {
      "surface": {
        "type": "object",
        "description": "Placement and sizing for the built-in debug inspector panel.",
        "defaults": {
          "anchor": "right",
          "layer": "overlay",
          "width": 320,
          "height": 0,
          "keyboard_mode": "on_demand",
          "visible_on_start": false
        },
        "properties": {
          "anchor": {
            "type": "enum",
            "values": [
              "top",
              "bottom",
              "left",
              "right"
            ],
            "default": "right",
            "description": "Screen edge this surface anchors to."
          },
          "layer": {
            "type": "enum",
            "values": [
              "background",
              "bottom",
              "top",
              "overlay"
            ],
            "default": "overlay",
            "description": "Layer-shell stacking layer."
          },
          "width": {
            "type": "integer",
            "default": 320,
            "min": 240,
            "max": 7680,
            "description": "Surface width in pixels."
          },
          "height": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 4320,
            "description": "Surface height in pixels. Use 0 to span the available output height."
          },
          "exclusive_zone": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 256,
            "description": "Reserved compositor space in pixels."
          },
          "keyboard_mode": {
            "type": "enum",
            "values": [
              "none",
              "exclusive",
              "on_demand"
            ],
            "default": "on_demand",
            "description": "Keyboard interactivity policy for the inspector surface."
          },
          "visible_on_start": {
            "type": "boolean",
            "default": false,
            "description": "Whether this surface starts visible when Mesh boots."
          }
        }
      }
    }
  },
  "surface_layout": {
    "size_policy": "fixed"
  },
  "accessibility": {
    "role": "dialog",
    "label": "Debug inspector",
    "description": "Debug-only profiling and shell inspection panel"
  }
}
