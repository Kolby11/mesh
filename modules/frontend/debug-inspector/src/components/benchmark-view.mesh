<template>
  <column class="benchmark-view" hidden={hidden}>
    <text class="section-title">Benchmark / Interaction</text>
    <text class="section-copy">
      Run fixed shell interactions and compare their live profiling summaries.
    </text>

    <column class="benchmark-list">
      {#for row in rows}
        <box class="benchmark-row">
          <column class="benchmark-copy">
            <row class="benchmark-head">
              <text class="benchmark-title">{row.title}</text>
              <text class="benchmark-status">{row.status}</text>
            </row>
            <text class="benchmark-meta">{row.scenario_id} / {row.target}</text>
            <button class="benchmark-action" onclick={onRunScenario(row.scenario_id)} aria-label={row.action_aria_label}>
              <text class="benchmark-action-text">{row.action_label}</text>
            </button>
            <text class="benchmark-primary-metric">{row.primary_metric}</text>
            <text class="benchmark-secondary-metric">{row.secondary_metric}</text>
            <text class="benchmark-hint">{row.hint}</text>
          </column>
        </box>
      {/for}
    </column>
  </column>
</template>

<script lang="luau">
hidden = false
rows = {}
onRunScenario = nil
</script>

