<template>
  <column class="modules-view" hidden={hidden}>
    <text class="section-title">Modules</text>
    <text class="section-copy">{state_copy}</text>
    <input
      class="module-filter"
      value={filter_value}
      placeholder="Filter modules"
      label="Filter installed modules"
      onchange={onFilterChange}
    />

    <empty-state class="empty-card" hidden={empty_hidden}>
      <column class="empty-copy">
        <text class="empty-title">No module graph loaded</text>
        <text class="empty-text">Installed module contracts appear here after the shell publishes the debug snapshot.</text>
      </column>
    </empty-state>

    <list class="module-list" label="Installed module graph">
      {#for row in rows}
        <list-item class="module-card">
          <column class="module-copy">
            <row class="module-head">
              <text class="module-title">{row.module_id}</text>
              <text class="module-kind">{row.kind_label}</text>
            </row>
            <text class="module-meta">{row.status_label}</text>
            <text class="section-subtitle">Uses</text>
            <text class="module-metric">{row.uses_interfaces}</text>
            <text class="module-metric">{row.uses_resources}</text>
            <text class="section-subtitle">Provides</text>
            <text class="module-metric">{row.provides_interfaces}</text>
            <text class="module-metric">{row.provides_resources}</text>
            <text class="section-subtitle">Health</text>
            <text class="module-metric">{row.health_label}</text>
          </column>
        </list-item>
      {/for}
    </list>
  </column>
</template>

<script lang="luau">
hidden = false
rows = {}
</script>

<style>
  .modules-view,
  .module-list {
    gap: var(--spacing-md);
  }

  .module-filter {
    width: 100%;
  }

  .section-title,
  .section-subtitle,
  .empty-title,
  .module-title {
    font-size: var(--typography-size-sm);
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .section-copy,
  .empty-text,
  .module-meta,
  .module-metric {
    font-size: var(--typography-size-xs);
    color: var(--color-on-surface-variant);
  }

  .empty-card,
  .module-card {
    width: 100%;
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    background: var(--color-surface-container);
    border-width: 1px;
    border-style: solid;
    border-color: var(--color-outline-variant);
  }

  .empty-copy,
  .module-copy {
    gap: var(--spacing-xs);
  }

  .module-head {
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
  }

  .module-kind {
    padding-inline: var(--spacing-sm);
    padding-block: var(--spacing-xs);
    border-radius: var(--radius-full);
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    font-size: var(--typography-size-xs);
    font-weight: 700;
  }
</style>
