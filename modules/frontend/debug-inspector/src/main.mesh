local function count_list(value)
    if type(value) == "table" then
        return tostring(#value)
    end
    return "0"
end

local function sync_view_state()
    overview_hidden = active_view ~= "overview"
    modules_hidden = active_view ~= "modules"
    surfaces_hidden = active_view ~= "surfaces"
    backend_hidden = active_view ~= "backend_services"
    benchmark_hidden = active_view ~= "benchmark"
    overview_indicator_hidden = active_view ~= "overview"
    modules_indicator_hidden = active_view ~= "modules"
    surfaces_indicator_hidden = active_view ~= "surfaces"
    backend_services_indicator_hidden = active_view ~= "backend_services"
    benchmark_indicator_hidden = active_view ~= "benchmark"
end

local function service_view_id(value)
    local view = tostring(value or "")
    if view == "overview" or view == "modules" or view == "surfaces" or view == "backend_services" or view == "benchmark" then
        return view
    end
    return nil
end

local function sync_service_active_view()
    local service_view = service_view_id(debug_service and debug_service.active_view)
    if service_view ~= nil and service_view ~= last_service_active_view then
        active_view = service_view
        last_service_active_view = service_view
    end
end

local function sync_overview_state_flags()
    overview_off_hidden = overview_state_kind ~= "off"
    overview_warming_hidden = overview_state_kind ~= "warming"
    overview_idle_hidden = overview_state_kind ~= "idle"
end

local function list_size(value)
    if type(value) == "table" then
        return #value
    end
    return 0
end

local function micros_label(value)
    local numeric = tonumber(value) or 0
    return string.format("%dus", math.floor(numeric + 0.5))
end

local function stage_total_label(summary)
    if type(summary) ~= "table" then
        return "No recent samples yet"
    end
    local total = tonumber(summary.total_micros) or 0
    local count = tonumber(summary.sample_count) or 0
    return string.format("%s across %d samples", micros_label(total), count)
end

local function first_stage_label(stages)
    if type(stages) ~= "table" or #stages == 0 then
        return "No recent samples yet"
    end
    local summary = stages[1]
    local stage_name = tostring(summary.stage or "stage")
    return string.format("%s: %s", stage_name, stage_total_label(summary))
end

local function find_stage(stages, stage_name)
    if type(stages) ~= "table" then
        return nil
    end
    for _, summary in ipairs(stages) do
        if tostring(summary.stage or "") == stage_name then
            return summary
        end
    end
    return nil
end

local function paint_snapshot(snapshot)
    if type(snapshot) ~= "table" or type(snapshot.invalidation) ~= "table" then
        return nil
    end
    if type(snapshot.invalidation.paint) ~= "table" then
        return nil
    end
    return snapshot.invalidation.paint
end

local function numeric_counter(value)
    local numeric = tonumber(value)
    if numeric == nil then
        return nil
    end
    return numeric
end

local function paint_policy_label(snapshot)
    local paint = paint_snapshot(snapshot)
    if paint == nil or paint.repaint_policy == nil then
        return "Paint policy unavailable"
    end
    local fallback_count = numeric_counter(paint.filtered_fallback_count)
    if fallback_count == nil then
        return "Paint policy unavailable"
    end
    local policy = tostring(paint.repaint_policy or "unknown")
    return string.format("Paint policy %s; fallbacks %d", policy, fallback_count)
end

local function paint_filter_label(snapshot)
    local paint = paint_snapshot(snapshot)
    if paint == nil then
        return "Filtered paint counters unavailable"
    end
    local filtered = numeric_counter(paint.filtered_command_count)
    local skipped = numeric_counter(paint.filtered_commands_skipped)
    local spans = numeric_counter(paint.filtered_span_count)
    if filtered == nil or skipped == nil or spans == nil then
        return "Filtered paint counters unavailable"
    end
    return string.format("Filtered %d commands from %d spans; skipped %d", filtered, spans, skipped)
end

local benchmark_definitions = {
    {
        id = "hover",
        title = "Hover",
        target = "@mesh/navigation-bar",
    },
    {
        id = "surface_open_close",
        title = "Surface open/close",
        target = "@mesh/audio-popover",
    },
    {
        id = "pointer_update",
        title = "Pointer-driven update",
        target = "@mesh/navigation-bar audio controls",
    },
    {
        id = "keyboard_traversal",
        title = "Keyboard traversal",
        target = "@mesh/navigation-bar focus chain",
    },
    {
        id = "backend_update",
        title = "Backend-driven update",
        target = "mesh.audio -> @mesh/pipewire-audio",
    },
}

local function safe_string(value, fallback)
    if type(value) == "string" and value ~= "" then
        return value
    end
    return fallback
end

local function join_limited(values, limit)
    if type(values) ~= "table" or #values == 0 then
        return "none"
    end
    local parts = {}
    local max_count = math.min(#values, limit)
    for index = 1, max_count do
        parts[index] = tostring(values[index])
    end
    local joined = table.concat(parts, ", ")
    if #values > limit then
        return string.format("%s +%d", joined, #values - limit)
    end
    return joined
end

local function list_label(label, values)
    return string.format("%s: %s", label, join_limited(values, 3))
end

local function combined_resources(entry)
    if type(entry) ~= "table" then
        return "Resources: none"
    end
    local uses = entry.uses
    if type(uses) ~= "table" then
        uses = entry
    end
    local parts = {}
    if type(uses.icon_packs) == "table" and #uses.icon_packs > 0 then
        parts[#parts + 1] = "icons " .. join_limited(uses.icon_packs, 2)
    end
    if type(uses.i18n_packs) == "table" and #uses.i18n_packs > 0 then
        parts[#parts + 1] = "i18n " .. join_limited(uses.i18n_packs, 2)
    end
    if type(uses.theme_packs) == "table" and #uses.theme_packs > 0 then
        parts[#parts + 1] = "themes " .. join_limited(uses.theme_packs, 2)
    end
    if type(uses.font_packs) == "table" and #uses.font_packs > 0 then
        parts[#parts + 1] = "fonts " .. join_limited(uses.font_packs, 2)
    end
    if #parts == 0 then
        return "Resources: none"
    end
    return "Resources: " .. table.concat(parts, "; ")
end

local function provided_interfaces_label(entry)
    local interfaces = {}
    local provides = nil
    if type(entry) == "table" then
        provides = entry.provides
        if type(provides) ~= "table" then
            provides = entry
        end
    end
    if type(provides) == "table" and type(provides.interfaces) == "table" then
        for _, interface_name in ipairs(provides.interfaces) do
            interfaces[#interfaces + 1] = interface_name
        end
    end
    return list_label("Interfaces", interfaces)
end

local function provided_resources_label(entry)
    if type(entry) ~= "table" then
        return "Resources: none"
    end
    local provides = entry.provides
    if type(provides) ~= "table" then
        provides = entry
    end
    local parts = {}
    if type(provides.settings) == "table" and #provides.settings > 0 then
        parts[#parts + 1] = "settings " .. join_limited(provides.settings, 2)
    end
    if type(provides.i18n) == "table" and #provides.i18n > 0 then
        parts[#parts + 1] = "i18n " .. join_limited(provides.i18n, 2)
    end
    if type(provides.required_icons) == "table" and #provides.required_icons > 0 then
        parts[#parts + 1] = "icons " .. join_limited(provides.required_icons, 2)
    end
    if #parts == 0 then
        return "Resources: none"
    end
    return "Resources: " .. table.concat(parts, "; ")
end

local function module_health_label(entry)
    if type(entry) ~= "table" then
        return "Health: unavailable"
    end
    if type(entry.diagnostics) == "table" and #entry.diagnostics > 0 then
        return "Diagnostics: " .. join_limited(entry.diagnostics, 2)
    end
    if entry.enabled then
        return "Diagnostics: clear"
    end
    return "Diagnostics: disabled"
end

local function module_interface_uses_label(entry)
    if type(entry) ~= "table" then
        return "Interfaces: none"
    end
    local uses = entry.uses
    if type(uses) ~= "table" then
        uses = entry
    end
    local required = list_size(uses.interfaces)
    local optional = list_size(uses.optional_interfaces)
    if required == 0 and optional == 0 then
        return "Interfaces: none"
    end
    if optional == 0 then
        return list_label("Interfaces", uses.interfaces)
    end
    if required == 0 then
        return list_label("Optional interfaces", uses.optional_interfaces)
    end
    return string.format(
        "Interfaces: %s; optional %s",
        join_limited(uses.interfaces, 2),
        join_limited(uses.optional_interfaces, 2)
    )
end

local function set_module_slot(slot, hidden, module_id, kind_label, status_label, uses_interfaces, uses_resources, provides_interfaces, provides_resources, health_label)
    if slot == 1 then
        module_row_1_hidden = hidden
        module_row_1_module_id = module_id
        module_row_1_kind_label = kind_label
        module_row_1_status_label = status_label
        module_row_1_uses_interfaces = uses_interfaces
        module_row_1_uses_resources = uses_resources
        module_row_1_provides_interfaces = provides_interfaces
        module_row_1_provides_resources = provides_resources
        module_row_1_health_label = health_label
        return
    end
    if slot == 2 then
        module_row_2_hidden = hidden
        module_row_2_module_id = module_id
        module_row_2_kind_label = kind_label
        module_row_2_status_label = status_label
        module_row_2_uses_interfaces = uses_interfaces
        module_row_2_uses_resources = uses_resources
        module_row_2_provides_interfaces = provides_interfaces
        module_row_2_provides_resources = provides_resources
        module_row_2_health_label = health_label
        return
    end
    if slot == 3 then
        module_row_3_hidden = hidden
        module_row_3_module_id = module_id
        module_row_3_kind_label = kind_label
        module_row_3_status_label = status_label
        module_row_3_uses_interfaces = uses_interfaces
        module_row_3_uses_resources = uses_resources
        module_row_3_provides_interfaces = provides_interfaces
        module_row_3_provides_resources = provides_resources
        module_row_3_health_label = health_label
        return
    end
    module_row_4_hidden = hidden
    module_row_4_module_id = module_id
    module_row_4_kind_label = kind_label
    module_row_4_status_label = status_label
    module_row_4_uses_interfaces = uses_interfaces
    module_row_4_uses_resources = uses_resources
    module_row_4_provides_interfaces = provides_interfaces
    module_row_4_provides_resources = provides_resources
    module_row_4_health_label = health_label
end

local function module_slot(slot, entry)
    if entry == nil then
        set_module_slot(slot, true, "", "", "", "", "", "", "", "")
        return
    end
    local module_id = tostring(entry.module_id or "unknown-module")
    local kind_label = tostring(entry.kind or "module")
    local status_label = "Enabled"
    if not entry.enabled then
        status_label = "Disabled"
    end
    set_module_slot(
        slot,
        false,
        module_id,
        kind_label,
        status_label,
        module_interface_uses_label(entry),
        combined_resources(entry),
        provided_interfaces_label(entry),
        provided_resources_label(entry),
        module_health_label(entry)
    )
end

local function sync_module_rows()
    local graph = nil
    if debug_service and type(debug_service.module_graph) == "table" then
        graph = debug_service.module_graph
    end
    modules_empty = list_size(graph) == 0
    modules_empty_hidden = not modules_empty
    modules_state_copy = string.format(
        "%s installed graph entries expose declared dependencies, contributions, resources, and diagnostics.",
        tostring(list_size(graph))
    )
    module_slot(1, graph and graph[1] or nil)
    module_slot(2, graph and graph[2] or nil)
    module_slot(3, graph and graph[3] or nil)
    module_slot(4, graph and graph[4] or nil)
end

local function fallback_benchmark_status()
    if debug_service and debug_service.profiling_enabled then
        return "Waiting for samples"
    end
    return "Profiling off"
end

local function fallback_benchmark_action()
    if debug_service and debug_service.profiling_enabled then
        return "Run scenario"
    end
    return "Start profiling first"
end

local function find_benchmark_scenario(scenarios, scenario_id)
    if type(scenarios) ~= "table" then
        return nil
    end
    for _, scenario in ipairs(scenarios) do
        if type(scenario) == "table" and tostring(scenario.id or "") == scenario_id then
            return scenario
        end
    end
    return nil
end

local function apply_benchmark_slot(slot, definition, scenario)
    local title = definition.title
    local scenario_id = definition.id
    local target = definition.target
    local status = fallback_benchmark_status()
    local action_label = fallback_benchmark_action()
    local primary_metric = "No benchmark results yet"
    local secondary_metric = "No benchmark results yet"
    local hint = "Run a scenario while profiling is live to populate latest-session metrics."

    if type(scenario) == "table" then
        title = safe_string(scenario.label, title)
        target = safe_string(scenario.target, target)
        status = safe_string(scenario.status, status)
        primary_metric = safe_string(scenario.primary_metric, primary_metric)
        secondary_metric = safe_string(scenario.secondary_metric, secondary_metric)
        hint = safe_string(scenario.hint, hint)
    end

    if status == "Profiling off" then
        action_label = "Start profiling first"
    else
        action_label = "Run scenario"
    end

    local action_aria_label = string.format("%s for %s", action_label, title)

    if slot == 1 then
        benchmark_row_1_title = title
        benchmark_row_1_scenario_id = scenario_id
        benchmark_row_1_target = target
        benchmark_row_1_status = status
        benchmark_row_1_action_label = action_label
        benchmark_row_1_action_aria_label = action_aria_label
        benchmark_row_1_primary_metric = primary_metric
        benchmark_row_1_secondary_metric = secondary_metric
        benchmark_row_1_hint = hint
        return
    end
    if slot == 2 then
        benchmark_row_2_title = title
        benchmark_row_2_scenario_id = scenario_id
        benchmark_row_2_target = target
        benchmark_row_2_status = status
        benchmark_row_2_action_label = action_label
        benchmark_row_2_action_aria_label = action_aria_label
        benchmark_row_2_primary_metric = primary_metric
        benchmark_row_2_secondary_metric = secondary_metric
        benchmark_row_2_hint = hint
        return
    end
    if slot == 3 then
        benchmark_row_3_title = title
        benchmark_row_3_scenario_id = scenario_id
        benchmark_row_3_target = target
        benchmark_row_3_status = status
        benchmark_row_3_action_label = action_label
        benchmark_row_3_action_aria_label = action_aria_label
        benchmark_row_3_primary_metric = primary_metric
        benchmark_row_3_secondary_metric = secondary_metric
        benchmark_row_3_hint = hint
        return
    end
    if slot == 4 then
        benchmark_row_4_title = title
        benchmark_row_4_scenario_id = scenario_id
        benchmark_row_4_target = target
        benchmark_row_4_status = status
        benchmark_row_4_action_label = action_label
        benchmark_row_4_action_aria_label = action_aria_label
        benchmark_row_4_primary_metric = primary_metric
        benchmark_row_4_secondary_metric = secondary_metric
        benchmark_row_4_hint = hint
        return
    end
    benchmark_row_5_title = title
    benchmark_row_5_scenario_id = scenario_id
    benchmark_row_5_target = target
    benchmark_row_5_status = status
    benchmark_row_5_action_label = action_label
    benchmark_row_5_action_aria_label = action_aria_label
    benchmark_row_5_primary_metric = primary_metric
    benchmark_row_5_secondary_metric = secondary_metric
    benchmark_row_5_hint = hint
end

local function sync_benchmark_rows()
    local scenarios = nil
    if debug_service and type(debug_service.benchmarks) == "table" then
        scenarios = debug_service.benchmarks.scenarios
    end

    for index, definition in ipairs(benchmark_definitions) do
        apply_benchmark_slot(index, definition, find_benchmark_scenario(scenarios, definition.id))
    end
end

local function surface_slot(slot, snapshot)
    if slot == 1 then
        surface_row_1_hidden = snapshot == nil
        if snapshot == nil then return end
        surface_row_1_surface_id = tostring(snapshot.surface_id or "unknown-surface")
        surface_row_1_module_id = string.format("Module %s", tostring(snapshot.module_id or "unknown"))
        surface_row_1_stage_label = first_stage_label(snapshot.stages)
        surface_row_1_render_label = string.format(
            "Total render %s",
            micros_label(snapshot.total_surface_render_time_micros)
        )
        surface_row_1_redraw_label = string.format("Redraws %s", tostring(snapshot.redraw_count or 0))
        surface_row_1_paint_policy_label = paint_policy_label(snapshot)
        surface_row_1_paint_filter_label = paint_filter_label(snapshot)
        return
    end
    if slot == 2 then
        surface_row_2_hidden = snapshot == nil
        if snapshot == nil then return end
        surface_row_2_surface_id = tostring(snapshot.surface_id or "unknown-surface")
        surface_row_2_module_id = string.format("Module %s", tostring(snapshot.module_id or "unknown"))
        surface_row_2_stage_label = first_stage_label(snapshot.stages)
        surface_row_2_render_label = string.format(
            "Total render %s",
            micros_label(snapshot.total_surface_render_time_micros)
        )
        surface_row_2_redraw_label = string.format("Redraws %s", tostring(snapshot.redraw_count or 0))
        surface_row_2_paint_policy_label = paint_policy_label(snapshot)
        surface_row_2_paint_filter_label = paint_filter_label(snapshot)
        return
    end
    surface_row_3_hidden = snapshot == nil
    if snapshot == nil then return end
    surface_row_3_surface_id = tostring(snapshot.surface_id or "unknown-surface")
    surface_row_3_module_id = string.format("Module %s", tostring(snapshot.module_id or "unknown"))
    surface_row_3_stage_label = first_stage_label(snapshot.stages)
    surface_row_3_render_label = string.format(
        "Total render %s",
        micros_label(snapshot.total_surface_render_time_micros)
    )
    surface_row_3_redraw_label = string.format("Redraws %s", tostring(snapshot.redraw_count or 0))
    surface_row_3_paint_policy_label = paint_policy_label(snapshot)
    surface_row_3_paint_filter_label = paint_filter_label(snapshot)
end

local function runtime_label(interface_name, provider_id, runtimes)
    if type(runtimes) ~= "table" then
        return "No runtime health entry"
    end
    for _, runtime in ipairs(runtimes) do
        if tostring(runtime.interface or "") == interface_name and tostring(runtime.provider_id or "") == provider_id then
            local status = tostring(runtime.status or "unknown")
            local message = tostring(runtime.message or "No runtime detail")
            return string.format("%s: %s", status, message)
        end
    end
    return "No runtime health entry"
end

local function backend_slot(slot, snapshot, runtimes)
    local target_interface = ""
    local target_provider = ""
    local target_runtime = ""
    local target_poll = ""
    local target_command = ""
    local target_publish = ""

    if snapshot ~= nil then
        target_interface = tostring(snapshot.interface or "unknown")
        target_provider = tostring(snapshot.provider_id or "unknown")
        target_runtime = runtime_label(target_interface, target_provider, runtimes)
        target_poll = stage_total_label(find_stage(snapshot.stages, "poll_update"))
        target_command = stage_total_label(find_stage(snapshot.stages, "command_handling"))
        target_publish = stage_total_label(find_stage(snapshot.stages, "state_publish_delivery"))
    end

    if slot == 1 then
        backend_row_1_hidden = snapshot == nil
        backend_row_1_interface = target_interface
        backend_row_1_provider_id = target_provider
        backend_row_1_runtime_label = target_runtime
        backend_row_1_poll_update = target_poll
        backend_row_1_command_handling = target_command
        backend_row_1_state_publish_delivery = target_publish
        return
    end
    if slot == 2 then
        backend_row_2_hidden = snapshot == nil
        backend_row_2_interface = target_interface
        backend_row_2_provider_id = target_provider
        backend_row_2_runtime_label = target_runtime
        backend_row_2_poll_update = target_poll
        backend_row_2_command_handling = target_command
        backend_row_2_state_publish_delivery = target_publish
        return
    end
    backend_row_3_hidden = snapshot == nil
    backend_row_3_interface = target_interface
    backend_row_3_provider_id = target_provider
    backend_row_3_runtime_label = target_runtime
    backend_row_3_poll_update = target_poll
    backend_row_3_command_handling = target_command
    backend_row_3_state_publish_delivery = target_publish
end

function showOverview()
    active_view = "overview"
    sync_view_state()
end

function showModules()
    active_view = "modules"
    sync_view_state()
end

function showSurfaces()
    active_view = "surfaces"
    sync_view_state()
end

function showBackendServices()
    active_view = "backend_services"
    sync_view_state()
end

function showBenchmark()
    active_view = "benchmark"
    sync_view_state()
end

function onCloseInspector()
    mesh.events.publish("shell.toggle-debug-overlay", {})
end

function onToggleProfiling()
    mesh.events.publish("shell.toggle-debug-profiling", {})
end

function onToggleLayoutBounds()
    mesh.events.publish("shell.toggle-debug-layout-bounds", {})
end

local function runBenchmarkScenario(scenario_id)
    if not (debug_service and debug_service.profiling_enabled) then
        mesh.events.publish("shell.toggle-debug-profiling", {})
        return
    end
    mesh.events.publish("shell.run-debug-benchmark", { scenario_id = scenario_id })
end

function runHoverBenchmark()
    runBenchmarkScenario("hover")
end

function runSurfaceOpenCloseBenchmark()
    runBenchmarkScenario("surface_open_close")
end

function runPointerUpdateBenchmark()
    runBenchmarkScenario("pointer_update")
end

function runKeyboardTraversalBenchmark()
    runBenchmarkScenario("keyboard_traversal")
end

function runBackendUpdateBenchmark()
    runBenchmarkScenario("backend_update")
end

function onRender()
    if not debug_service then
        session_status = "Debug service unavailable"
        profiling_badge = "Unavailable"
        profiling_copy = "The shell debug service has not been published yet."
        overview_state_kind = "off"
        overview_state_title = "Profiling is off"
        overview_state_copy = "Enable profiling to collect rolling shell, surface, and backend timings."
        overlay_value = "Unavailable"
        layout_bounds_value = "Unavailable"
        layout_bounds_button_text = "Show layout bounds"
        layout_bounds_button_label = "Show debug layout bounds"
        session_value = "Session --"
        module_count = "0"
        active_surface_count = "0"
        backend_count = "0"
        shell_stage_label = "No recent samples yet"
        shell_render_label = "Total surface render: --"
        surfaces_empty = true
        surfaces_empty_hidden = false
        backend_empty = true
        backend_empty_hidden = false
        surface_slot(1, nil)
        surface_slot(2, nil)
        surface_slot(3, nil)
        backend_slot(1, nil, nil)
        backend_slot(2, nil, nil)
        backend_slot(3, nil, nil)
        sync_module_rows()
        sync_benchmark_rows()
        return
    end

    local profiling = debug_service.profiling
    local surface_samples = nil
    local backend_samples = nil
    sync_service_active_view()

    if debug_service.overlay_enabled then
        overlay_value = "Visible"
    else
        overlay_value = "Hidden"
    end

    if debug_service.layout_bounds_enabled then
        layout_bounds_value = "Visible"
        layout_bounds_button_text = "Hide layout bounds"
        layout_bounds_button_label = "Hide debug layout bounds"
    else
        layout_bounds_value = "Hidden"
        layout_bounds_button_text = "Show layout bounds"
        layout_bounds_button_label = "Show debug layout bounds"
    end

    session_value = string.format("Session %s", tostring(debug_service.profiling_session_id or 0))
    module_count = count_list(debug_service.modules)
    active_surface_count = count_list(debug_service.active_surfaces)
    backend_count = count_list(debug_service.backend_runtimes)

    if debug_service.profiling_enabled then
        profiling_badge = "Live"
        profiling_copy = "Profiling is collecting rolling samples through the existing debug path."
        profiling_button_text = "Stop profiling"
        profiling_button_label = "Stop debug profiling"

        if type(profiling) == "table" then
            session_status = "Profiling is live"
            overview_state_kind = "live"
            overview_state_title = "Recent samples available"
            overview_state_copy = "Live shell, surface, and backend summaries are updating in this panel."
            shell_stage_label = first_stage_label(profiling.shell and profiling.shell.stages)
            shell_render_label = string.format(
                "Total surface render: %s",
                micros_label(profiling.shell and profiling.shell.total_surface_render_time_micros)
            )
            surface_samples = profiling.surfaces
            backend_samples = profiling.backends

            if list_size(profiling.shell and profiling.shell.stages) == 0 then
                overview_state_kind = "idle"
                overview_state_title = "No recent samples yet"
                overview_state_copy = "Profiling is live but no recent timings have been captured yet."
            end
        else
            session_status = "Profiling is live but still collecting samples"
            overview_state_kind = "warming"
            overview_state_title = "Profiling is live but still collecting samples"
            overview_state_copy = "Interact with the shell to move from warm-up into rolling summaries."
            shell_stage_label = "collecting samples"
            shell_render_label = "Total surface render: warming up"
        end
    else
        profiling_badge = "Idle"
        profiling_copy = "Profiling stays off until you explicitly start it."
        profiling_button_text = "Start profiling"
        profiling_button_label = "Start debug profiling"
        session_status = "Inspector open without profiling"
        overview_state_kind = "off"
        overview_state_title = "Profiling is off"
        overview_state_copy = "Enable profiling to collect rolling shell, surface, and backend timings."
        shell_stage_label = "No recent samples yet"
        shell_render_label = "Total surface render: --"
    end

    surfaces_empty = list_size(surface_samples) == 0
    surfaces_empty_hidden = not surfaces_empty
    backend_empty = list_size(backend_samples) == 0
    backend_empty_hidden = not backend_empty
    surfaces_state_copy = "Compare per-surface timing, redraw activity, and retained paint filtering without leaving the right-side panel."
    backend_state_copy = "Runtime health and stage timing stay separated so lifecycle issues do not read like performance cost."
    sync_view_state()
    sync_overview_state_flags()
    sync_module_rows()

    surface_slot(1, surface_samples and surface_samples[1] or nil)
    surface_slot(2, surface_samples and surface_samples[2] or nil)
    surface_slot(3, surface_samples and surface_samples[3] or nil)

    backend_slot(1, backend_samples and backend_samples[1] or nil, debug_service.backend_runtimes)
    backend_slot(2, backend_samples and backend_samples[2] or nil, debug_service.backend_runtimes)
    backend_slot(3, backend_samples and backend_samples[3] or nil, debug_service.backend_runtimes)
    sync_benchmark_rows()
end
</script>

<style>
.inspector-shell {
    width: 100%;
    height: 100%;
    padding: var(--spacing-sm);
    background: transparent;
}

.inspector-root {
    width: 100%;
    height: 100%;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    color: var(--color-on-surface);
    border-width: 1px;
    border-style: solid;
    border-color: var(--color-outline-variant);
}

.inspector-header {
    width: 100%;
    align-items: start;
    gap: var(--spacing-sm);
}

.header-copy {
    flex-grow: 1;
    gap: 2px;
}

.inspector-title {
    font-size: var(--typography-size-md);
    font-weight: 700;
    color: var(--color-on-surface);
}

.inspector-status {
    font-size: var(--typography-size-xs);
    color: var(--color-on-surface-variant);
}

.header-close {
    min-width: 64px;
    height: 32px;
    padding-inline: var(--spacing-sm);
    justify-content: center;
    align-items: center;
    border-radius: var(--radius-md);
    background: var(--color-surface-container);
}

.header-close-text {
    font-size: var(--typography-size-sm);
    font-weight: 600;
    color: var(--color-on-surface);
}

.profiling-zone {
    gap: var(--spacing-xs);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    background: var(--color-surface-container-low);
    border-width: 1px;
    border-style: solid;
    border-color: var(--color-outline-variant);
}

.profiling-head {
    width: 100%;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-sm);
}

.profiling-title {
    font-size: var(--typography-size-sm);
    font-weight: 700;
    color: var(--color-on-surface);
}

.profiling-badge {
    padding-inline: var(--spacing-sm);
    padding-block: var(--spacing-xs);
    border-radius: var(--radius-full);
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    font-size: var(--typography-size-xs);
    font-weight: 700;
}

.profiling-copy {
    font-size: var(--typography-size-xs);
    color: var(--color-on-surface-variant);
}

.inspector-body {
    width: 100%;
    flex-grow: 1;
    gap: var(--spacing-md);
}

.benchmark-view {
    gap: var(--spacing-md);
}

.section-title {
    font-size: var(--typography-size-sm);
    font-weight: 700;
    color: var(--color-on-surface);
}

.section-copy {
