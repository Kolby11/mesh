<template>
  <dialog class="inspector-shell" aria-label="Debug Inspector">
    <column class="inspector-root">
      <row class="inspector-header">
        <column class="header-copy">
          <text class="inspector-title">Debug Inspector</text>
          <text class="inspector-status">{session_status}</text>
        </column>
        <button class="header-close" onclick={onCloseInspector} aria-label="Close debug inspector">
          <text class="header-close-text">Close</text>
        </button>
      </row>

      <column class="profiling-zone">
        <row class="profiling-head">
          <text class="profiling-title">Profiling</text>
          <text class="profiling-badge">{profiling_badge}</text>
        </row>
        <text class="profiling-copy">{profiling_copy}</text>
      </column>

      <ViewTabs
        onOverview={showOverview}
        onModules={showModules}
        onSurfaces={showSurfaces}
        onBackendServices={showBackendServices}
        onBenchmark={showBenchmark}
        overview_indicator_hidden={overview_indicator_hidden}
        modules_indicator_hidden={modules_indicator_hidden}
        surfaces_indicator_hidden={surfaces_indicator_hidden}
        backend_services_indicator_hidden={backend_services_indicator_hidden}
        benchmark_indicator_hidden={benchmark_indicator_hidden}
      />

      <column class="inspector-body">
        <OverviewView
          hidden={overview_hidden}
          state_title={overview_state_title}
          state_copy={overview_state_copy}
          off_hidden={overview_off_hidden}
          warming_hidden={overview_warming_hidden}
          idle_hidden={overview_idle_hidden}
          session_value={session_value}
          overlay_value={overlay_value}
          module_count={module_count}
          active_surface_count={active_surface_count}
          backend_count={backend_count}
          shell_stage_label={shell_stage_label}
          shell_render_label={shell_render_label}
          onToggleProfiling={onToggleProfiling}
          profiling_button_label={profiling_button_label}
          profiling_button_text={profiling_button_text}
          onToggleLayoutBounds={onToggleLayoutBounds}
          layout_bounds_button_label={layout_bounds_button_label}
          layout_bounds_button_text={layout_bounds_button_text}
          layout_bounds_value={layout_bounds_value}
        />

        <ModulesView
          hidden={modules_hidden}
