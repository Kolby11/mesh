<template>
  <popover class="language-popover-shell">
    <column class="language-popover">
      <column class="language-popover-inner">
        {#for locale in locales}
        <button
          class="{'language-option' .. (locale == selected_locale and ' language-option-selected' or '')}"
          onclick={onSelectLocale(locale)}
        >
          <text class="language-option-text">{t('language.' .. locale)}</text>
        </button>
        {/for}
      </column>
    </column>
  </popover>
</template>

<script lang="luau">
locales = { "en", "sk", "de", "fr", "es", "ja", "zh", "ko", "ar", "hi" }

selected_locale = "en"
surface_id = nil

local function get_surface_id()
    return surface_id or "@mesh/language-popover"
end

local function apply_selection(locale)
    selected_locale = locale
end

local function current_locale()
    local locale = mesh.locale.current()
    if type(locale) ~= "string" or locale == "" then
        return "en"
    end
    return locale
end

local function stored_locale(storage)
    local locale = storage and storage.language
    for _, valid in locales do
        if locale == valid then
            return locale
        end
    end
    return nil
end

local function select_locale(locale)
    apply_selection(locale)
    mesh.locale.set(locale)
    mesh.popover.hide(get_surface_id())
end

function init(self)
    surface_id = self and self.id or surface_id
    local locale = stored_locale(self.storage)
    if locale ~= nil then
        mesh.locale.set(locale)
    end
end

function render(self)
    surface_id = self and self.id or surface_id
    apply_selection(stored_locale(self.storage) or current_locale())
end

function onSelectLocale(locale, event)
    if locale then
        select_locale(locale)
    end
end
</script>

<style>
.language-popover-shell {
    width: 100%;
    height: fit-content;
    max-height: 200px;
    padding: var(--spacing-sm);
    background: transparent;
    opacity: 1;
    transition: opacity var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

.language-popover-shell.mesh-surface-exiting {
    opacity: 0;
}

.language-popover {
    width: 100%;
    max-width: 260px;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-surface-container);
    border-width: 1px;
    border-style: solid;
    border-color: var(--color-outline-variant);
}

.language-popover-inner {
    width: 100%;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm);
}

.language-option {
    width: 100%;
    flex-shrink: 0;
    justify-content: start;
    align-items: center;
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-radius var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
}

.language-option:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    border-radius: var(--radius-md);
}

.language-option:focus,
.language-option:focus-visible {
    background: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    border-radius: var(--radius-md);
}

.language-option:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    border-radius: var(--radius-full);
}

.language-option-selected {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
}

.language-option-text {
    font-size: var(--typography-size-sm);
    font-weight: 700;
    color: inherit;
    text-wrap: none;
}
</style>
