<template>
  <popover
    open={open}
    class="language-popover-shell"
    aria-label="{t('language.choose')}"
    anchor-ref="language-button"
    anchor="bottom"
    gravity="bottom"
    onpointerenter={onPopoverEnter}
    onpointerleave={onPopoverLeave}
  >
    <box class="bubble-popover-panel">
      <BubbleOptions
        label="{t('language.choose')}"
        item1_button_class="{item1_button_class}"
        item1_core_class="{item1_core_class}"
        item1_icon_class="bubble-option-icon bubble-option-hidden"
        item1_icon="palette"
        item1_text_class="bubble-option-text"
        item1_text="{item1_text}"
        item1_title="{item1_title}"
        onfirst={onSelectFirst}
        item2_button_class="{item2_button_class}"
        item2_core_class="{item2_core_class}"
        item2_icon_class="bubble-option-icon bubble-option-hidden"
        item2_icon="palette"
        item2_text_class="bubble-option-text"
        item2_text="{item2_text}"
        item2_title="{item2_title}"
        onsecond={onSelectSecond}
        item3_button_class="{item3_button_class}"
        item3_core_class="{item3_core_class}"
        item3_icon_class="bubble-option-icon bubble-option-hidden"
        item3_icon="palette"
        item3_text_class="bubble-option-text"
        item3_text="{item3_text}"
        item3_title="{item3_title}"
        onthird={onSelectThird}
        onscroll={onOptionScroll}
      />
    </box>
  </popover>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local BubbleOptions = require("../../shared/components/bubble-options.mesh")

locales = { "en", "sk", "de", "fr", "es", "ja", "zh", "ko", "ar", "hi" }

open = false
selected_locale = "en"
window_start = 1

item1_button_class = "bubble-option bubble-option-left"
item2_button_class = "bubble-option bubble-option-center"
item3_button_class = "bubble-option bubble-option-right"
item1_core_class = "bubble-option-core bubble-option-core-language bubble-option-core-language-left"
item2_core_class = "bubble-option-core bubble-option-core-language bubble-option-core-language-center"
item3_core_class = "bubble-option-core bubble-option-core-language bubble-option-core-language-right"
item1_text = "EN"
item2_text = "SK"
item3_text = "DE"
item1_title = "English"
item2_title = "Slovak"
item3_title = "German"

local function normalize_index(index)
    local count = #locales
    return ((index - 1) % count) + 1
end

local function locale_at(offset)
    return locales[normalize_index(window_start + offset)]
end

local function locale_label(locale)
    if type(locale) ~= "string" or locale == "" then
        return "??"
    end
    return string.upper(string.sub(locale, 1, 2))
end

local function apply_selection(locale)
    selected_locale = locale
end

local function current_locale()
    local locale = mesh.locale.current()
    if type(locale) ~= "string" or locale == "" then
        return "en"
    end
    return locale
end

local function stored_locale(storage)
    local locale = storage and storage.language
    for _, valid in locales do
        if locale == valid then
            return locale
        end
    end
    return nil
end

local function sync_window_to_locale(locale)
    for index, valid in locales do
        if valid == locale then
            window_start = normalize_index(index - 1)
            return
        end
    end
end

local function set_option(slot, locale)
    local button_class = "bubble-option"
    local slot_anim_class
    if slot == 1 then
        button_class = button_class .. " bubble-option-left"
        slot_anim_class = "bubble-option-core-language-left"
    elseif slot == 2 then
        button_class = button_class .. " bubble-option-center"
        slot_anim_class = "bubble-option-core-language-center"
    else
        button_class = button_class .. " bubble-option-right"
        slot_anim_class = "bubble-option-core-language-right"
    end
    local core_class = "bubble-option-core bubble-option-core-language " .. slot_anim_class
    if locale == selected_locale then
        button_class = button_class .. " bubble-option-active"
        core_class = core_class .. " bubble-option-core-active"
    end

    if slot == 1 then
        item1_button_class = button_class
        item1_core_class = core_class
        item1_text = locale_label(locale)
        item1_title = t("language." .. locale)
    elseif slot == 2 then
        item2_button_class = button_class
        item2_core_class = core_class
        item2_text = locale_label(locale)
        item2_title = t("language." .. locale)
    else
        item3_button_class = button_class
        item3_core_class = core_class
        item3_text = locale_label(locale)
        item3_title = t("language." .. locale)
    end
end

local function sync_options()
    set_option(1, locale_at(0))
    set_option(2, locale_at(1))
    set_option(3, locale_at(2))
end

-- Selecting a locale does not close the popover: it stays open so the user can
-- keep choosing. It closes on pointer leave (onPopoverLeave) or, for keyboard
-- activation, on focus leave.
local function select_locale(locale)
    apply_selection(locale)
    sync_window_to_locale(locale)
    sync_options()
    mesh.locale.set(locale)
end

function init(self)
    local locale = stored_locale(self.storage)
    if locale ~= nil then
        mesh.locale.set(locale)
    end
end

function render(self)
    apply_selection(stored_locale(self.storage) or current_locale())
    sync_window_to_locale(selected_locale)
    sync_options()
end

function onSelectFirst()
    select_locale(locale_at(0))
end

function onSelectSecond()
    select_locale(locale_at(1))
end

function onSelectThird()
    select_locale(locale_at(2))
end

function onOptionScroll(event)
    local delta = event and event.delta or {}
    local dy = tonumber(delta.y) or 0
    if dy >= 0 then
        window_start = normalize_index(window_start + 1)
    else
        window_start = normalize_index(window_start - 1)
    end
    sync_options()
end

function onPopoverEnter(event)
    self.PopoverEnter:fire(event)
end

function onPopoverLeave()
    open = false
    self.PopoverLeave:fire()
end

</script>

<style>
.language-popover-shell {
    width: 112px;
    height: 74px;
    padding: 0;
    background: transparent;
    opacity: 1;
    transform: translateY(0px) scale(1);
    transition: opacity 160ms var(--animation-curves-bezier-standard),
                transform 220ms var(--animation-curves-bezier-emphasized-decelerate);
}

.bubble-popover-panel {
    width: 112px;
    height: 74px;
    padding: 0;
    background: transparent;
}

.language-popover-shell.mesh-surface-entering {
    opacity: 0;
    transform: translateY(-8px) scale(0.92);
}

.language-popover-shell.mesh-surface-exiting {
    opacity: 0;
    transform: translateY(-6px) scale(0.94);
    transition: opacity 120ms var(--animation-curves-bezier-standard),
                transform 140ms var(--animation-curves-bezier-standard);
}
</style>
