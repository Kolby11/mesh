<props>
blur_enabled:    { type: "bool", default: true, label: "Backdrop blur" }
blur_radius:     { type: "size", default: "var(--effect-backdrop-blur-popup-radius)", label: "Blur radius" }
blur_background: { type: "color", default: "var(--effect-backdrop-blur-popup-background)", label: "Frosted background" }
</props>

<template>
    <popover
        open={open}
        class="language-popover-shell"
        aria-label={t('language.choose')}
        anchor-ref="language-button"
        anchor="bottom"
        gravity="bottom"
        onpointerenter={onPopoverEnter}
        onpointerleave={onPopoverLeave}
    >
        <BubbleOptions
            label={t('language.choose')}
            items={items}
            onselect={onSelectOption}
            onscroll={onOptionScroll}
        />
    </popover>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local BubbleOptions = require("../../shared/components/bubble-options.mesh")

locales = { "en", "sk", "de", "fr", "es", "ja", "zh", "ko", "ar", "hi" }

open = false
selected_locale = "en"
window_start = 1

-- One struct per visible slot (left/center/right); BubbleOptions only
-- iterates this array, so position and active-state classes are baked in here.
items = {}

local function normalize_index(index)
    local count = #locales
    return ((index - 1) % count) + 1
end

local function locale_at(offset)
    return locales[normalize_index(window_start + offset)]
end

local function locale_label(locale)
    if type(locale) ~= "string" or locale == "" then
        return "??"
    end
    return string.upper(string.sub(locale, 1, 2))
end

local function apply_selection(locale)
    selected_locale = locale
end

local function current_locale()
    local locale = mesh.locale.current()
    if type(locale) ~= "string" or locale == "" then
        return "en"
    end
    return locale
end

local function stored_locale(storage)
    local locale = storage and storage.language
    for _, valid in locales do
        if locale == valid then
            return locale
        end
    end
    return nil
end

local function sync_window_to_locale(locale)
    for index, valid in locales do
        if valid == locale then
            window_start = normalize_index(index - 1)
            return
        end
    end
end

local SLOTS = {
    { position = "left", anim = "bubble-option-core-language-left" },
    { position = "center", anim = "bubble-option-core-language-center" },
    { position = "right", anim = "bubble-option-core-language-right" },
}

local function build_option(slot, locale)
    local button_class = "bubble-option bubble-option-" .. slot.position
    local core_class = "bubble-option-core bubble-option-core-language " .. slot.anim
    if locale == selected_locale then
        button_class = button_class .. " bubble-option-active"
        core_class = core_class .. " bubble-option-core-active"
    end

    return {
        id = locale,
        button_class = button_class,
        core_class = core_class,
        motion_class = "bubble-options-motion bubble-options-motion-" .. slot.position,
        icon_class = "bubble-option-icon bubble-option-hidden",
        icon = "palette",
        text_class = "bubble-option-text",
        text = locale_label(locale),
        title = t("language." .. locale),
    }
end

local function sync_options()
    items = {
        build_option(SLOTS[1], locale_at(0)),
        build_option(SLOTS[2], locale_at(1)),
        build_option(SLOTS[3], locale_at(2)),
    }
end

-- Selecting a locale does not close the popover: it stays open so the user can
-- keep choosing. It closes on pointer leave (onPopoverLeave) or, for keyboard
-- activation, on focus leave.
local function select_locale(locale)
    apply_selection(locale)
    sync_window_to_locale(locale)
    sync_options()
    mesh.locale.set(locale)
end

function init(self)
    local locale = stored_locale(self.storage)
    if locale ~= nil then
        mesh.locale.set(locale)
    end
end

function render(self)
    apply_selection(stored_locale(self.storage) or current_locale())
    sync_window_to_locale(selected_locale)
    sync_options()
end

function onSelectOption(locale)
    select_locale(locale)
end

function onOptionScroll(event)
    local delta = event and event.delta or {}
    local dy = tonumber(delta.y) or 0
    if dy >= 0 then
        window_start = normalize_index(window_start + 1)
    else
        window_start = normalize_index(window_start - 1)
    end
    sync_options()
end

function onPopoverEnter(event)
    self.PopoverEnter:fire(event)
end

function onPopoverLeave()
    open = false
    self.PopoverLeave:fire()
end
</script>

<style>
    .language-popover-shell {
        /* Sized to the bounding box of the BubbleOptions content instead of a
        hardcoded size — <popover> isn't a container tag, so it needs the
        fit value explicitly (box/row/column default to it). */
        width: fit;
        height: fit;
        padding: 0;
        background: transparent;
        opacity: 1;
        transform: translateY(0px) scale(1);
        transition: transform 220ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 180ms var(--animation-curves-bezier-standard);
    }

    .language-popover-shell.mesh-surface-entering {
        opacity: 1;
        transform: translateY(-8px) scale(0.92);
    }

    .language-popover-shell.mesh-surface-exiting {
        opacity: 0;
        transform: translateY(-6px) scale(0.94);
        transition: transform 140ms var(--animation-curves-bezier-standard),
        opacity 180ms var(--animation-curves-bezier-standard);
    }
</style>
