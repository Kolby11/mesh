{
  "name": "@mesh/language-popover",
  "version": "0.1.0",
  "description": "Compact language selection popover anchored from the navigation bar.",
  "authors": [
    "MESH Project"
  ],
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "compatibility": {
      "mesh": ">=0.1.0",
      "compositors": [
        "wlr-layer-shell-v1"
      ]
    },
    "capabilities": {
      "required": [
        "shell.surface",
        "locale.read",
        "locale.write"
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": [
        "en",
        "sk"
      ]
    },
    "entrypoints": {
      "main": "src/main.mesh"
    },
    "contributes": {
      "i18n": [
        {
          "id": "en",
          "locale": "en",
          "path": "config/i18n/en.json"
        },
        {
          "id": "sk",
          "locale": "sk",
          "path": "config/i18n/sk.json"
        }
      ],
      "settings": {
        "namespace": "@mesh/language-popover",
        "schema": {
          "surface": {
            "type": "object",
            "description": "Placement and sizing for the language popover surface.",
            "properties": {
              "anchor": {
                "type": "enum",
                "values": [
                  "top",
                  "bottom",
                  "left",
                  "right"
                ],
                "default": "left",
                "description": "Screen edge this surface anchors to."
              },
              "layer": {
                "type": "enum",
                "values": [
                  "background",
                  "bottom",
                  "top",
                  "overlay"
                ],
                "default": "overlay",
                "description": "Layer-shell stacking layer."
              },
              "width": {
                "type": "integer",
                "default": 200,
                "min": 140,
                "max": 7680,
                "description": "Surface width in pixels."
              },
              "height": {
                "type": "integer",
                "default": 132,
                "min": 96,
                "max": 1080,
                "description": "Surface height in pixels."
              },
              "exclusive_zone": {
                "type": "integer",
                "default": 0,
                "min": 0,
                "max": 256,
                "description": "Reserved compositor space in pixels."
              },
              "keyboard_mode": {
                "type": "enum",
                "values": [
                  "none",
                  "exclusive",
                  "on_demand"
                ],
                "default": "on_demand",
                "description": "Keyboard interactivity policy for the surface."
              },
              "visible_on_start": {
                "type": "boolean",
                "default": false,
                "description": "Whether this surface starts visible when Mesh boots."
              },
              "display_transition": {
                "type": "object",
                "default": {
                  "show_ms": 120,
                  "hide_ms": 120
                },
                "description": "Display transition durations for mapping and unmapping this surface."
              }
            }
          }
        }
      }
    },
    "surfaceLayout": {
      "size_policy": "content_measured",
      "prefers_content_children_sizing": true,
      "min_width": 160,
      "max_width": 260,
      "min_height": 120,
      "max_height": 200
    },
    "accessibility": {
      "role": "menu",
      "label": "Language selection",
      "description": "Compact language selection popover"
    }
  }
}
