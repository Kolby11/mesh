{
  "name": "@mesh/language-popover",
  "version": "0.1.0",
  "description": "Compact language selection popover anchored from the navigation bar.",
  "authors": [
    "MESH Project"
  ],
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "compatibility": {
      "mesh": ">=0.1.0",
      "compositors": [
        "wlr-layer-shell-v1"
      ]
    },
    "uses": {
      "capabilities": [
        "shell.surface",
        "locale.read",
        "locale.write"
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": [
        "en",
        "sk"
      ]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "left",
      "layer": "overlay",
      "width": 200,
      "height": 132,
      "exclusive_zone": 0,
      "keyboard_mode": "on_demand",
      "visible_on_start": false,
      "size": "content_measured",
      "prefers_content_children_sizing": true,
      "min_width": 160,
      "max_width": 260,
      "min_height": 120,
      "max_height": 200,
      "display_transition": {
        "show_ms": 120,
        "hide_ms": 120
      }
    },
    "provides": {
      "i18n": [
        {
          "id": "en",
          "locale": "en",
          "path": "config/i18n/en.json"
        },
        {
          "id": "sk",
          "locale": "sk",
          "path": "config/i18n/sk.json"
        }
      ]
    },
    "accessibility": {
      "role": "menu",
      "label": "Language selection",
      "description": "Compact language selection popover"
    }
  }
}
