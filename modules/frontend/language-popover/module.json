{
  "name": "@mesh/language-popover",
  "version": "0.1.0",
  "description": "Compact language selection popover anchored from the navigation bar.",
  "authors": [
    "MESH Project"
  ],
  "mesh": {
    "apiVersion": "0.1",
    "kind": "component",
    "uses": {
      "resources": {
        "icons": [
          "@mesh/icons-material-symbols",
          "@mesh/icons-default"
        ]
      },
      "capabilities": [
        "locale.read",
        "locale.write"
      ]
    },
    "iconRequirements": {
      "required": [
        "palette"
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": [
        "en",
        "sk"
      ]
    },
    "entry": "src/main.mesh",
    "provides": {
      "i18n": [
        {
          "id": "en",
          "locale": "en",
          "path": "config/i18n/en.json"
        },
        {
          "id": "sk",
          "locale": "sk",
          "path": "config/i18n/sk.json"
        }
      ]
    },
    "accessibility": {
      "role": "menu",
      "label": "Language selection",
      "description": "Compact language selection popover"
    }
  }
}
