<template>
    <box class="bubble-options-stage" onscroll={onscroll} aria-label="{label}">
        <button class="{item1_button_class}" onclick={onfirst} data-tooltip-disabled="true" title="{item1_title}" aria-label="{item1_title}">
            <box class="bubble-options-motion bubble-options-motion-left">
                <box class="{item1_core_class}">
