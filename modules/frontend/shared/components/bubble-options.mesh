<template>
    <box class="bubble-options-stage" onscroll={onscroll} aria-label={label}>
        {#for item in items}
            <button class={item.button_class} onclick={onselect(item.id)} data-tooltip-disabled="true" title={item.title} aria-label={item.title}>
                <box class={item.motion_class}>
                    <box class={item.core_class}>
                        <icon class={item.icon_class} name={item.icon} size="14" />
                        <text class={item.text_class}>{item.text}</text>
                    </box>
                </box>
            </button>
        {/for}
    </box>
</template>

<script lang="luau">
label = "Options"

-- Each entry: { id, button_class, core_class, motion_class, icon_class, icon,
-- text_class, text, title }. Position (left/center/right) and active/hover
-- state are baked into button_class/core_class/motion_class by the caller,
-- since this component only iterates — it has no notion of slot position.
items = {}

-- Called with the selected item's `id` (onselect(item.id)).
onselect = nil
onscroll = nil
</script>

<style>
    .bubble-options-stage {
        /* box defaults to width/height: fit — sized to the bounding box of
        its absolutely-positioned option buttons, so it never needs a
        hardcoded size here. */
        position: relative;
        overflow: visible;
    }

    .bubble-option {
        position: absolute;
        width: 36px;
        height: 36px;
        justify-content: center;
        align-items: center;
        padding: 0;
        border-radius: var(--radius-full);
        /* Alpha must be nonzero: exact-0 alpha reads as "unset" and gets replaced with this tag's opaque default background. */
        background: #00000001;
        border-width: 0;
        opacity: 1;
        /* Overrides the theme's global background-color-first transition default. */
        transition: none;
    }

    .bubble-option-left {
        top: 8px;
        left: 10px;
    }

    .bubble-option-center {
        top: 32px;
        left: 38px;
    }

    .bubble-option-right {
        top: 8px;
        left: 66px;
    }

    .bubble-options-motion,
    .bubble-option-core {
        width: 36px;
        height: 36px;
        justify-content: center;
        align-items: center;
        border-radius: var(--radius-full);
    }

    .bubble-options-motion {
        opacity: 1;
        transform: translate(0px, 0px) scale(1);
        transition: transform 360ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 220ms var(--animation-curves-bezier-standard);
    }

    .bubble-options-motion-left {
        transition-delay: 0ms;
    }

    .bubble-options-motion-center {
        transition-delay: 45ms;
    }

    .bubble-options-motion-right {
        transition-delay: 90ms;
    }

    .bubble-options-motion-left.mesh-surface-entering {
        transform: translate(46px, 4px) scale(0.12);
    }

    .bubble-options-motion-left.mesh-surface-exiting {
        transform: translate(46px, 4px) scale(0.12);
        opacity: 0;
    }

    .bubble-options-motion-center.mesh-surface-entering {
        transform: translate(18px, -20px) scale(0.12);
    }

    .bubble-options-motion-center.mesh-surface-exiting {
        transform: translate(18px, -20px) scale(0.12);
        opacity: 0;
    }

    .bubble-options-motion-right.mesh-surface-entering {
        transform: translate(-10px, 4px) scale(0.12);
    }

    .bubble-options-motion-right.mesh-surface-exiting {
        transform: translate(-10px, 4px) scale(0.12);
        opacity: 0;
    }

    .bubble-options-motion.mesh-surface-exiting {
        transition: transform 180ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 140ms var(--animation-curves-bezier-standard);
    }

    .bubble-option-core {
        border-width: 2px;
        border-style: solid;
        border-color: transparent;
        box-shadow: 0px 6px 18px rgba(0, 0, 0, 0.34);
        color: var(--color-on-surface);
        /* Frosted glass: translucent core over compositor-blurred backdrop
        (org_kde_kwin_blur on the promoted popup surface); also blurs any
        in-surface content painted beneath the bubble. */
        backdrop-filter: blur(14px);
        opacity: 1;
        /* Overrides the theme's global background-color-first transition default. */
        transition: border-color var(--animation-duration-short) var(--animation-curves-bezier-standard);
        animation-duration: 2800ms;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
    }

    .bubble-option-core.mesh-surface-exiting {
        animation-name: none;
    }

    .bubble-option-core-active {
        border-color: var(--color-primary);
    }

    .bubble-option-core:hover {
        border-color: var(--color-secondary);
    }

    .bubble-option-core-dark {
        background: rgba(24, 26, 34, 0.62);
        color: #8394aa;
        animation-name: bubble-option-float-left;
        animation-delay: 360ms;
    }

    .bubble-option-core-light {
        background: rgba(24, 26, 34, 0.62);
        color: #e9c46a;
        animation-name: bubble-option-float-center;
        animation-delay: 430ms;
    }

    .bubble-option-core-gruvbox {
        background: rgba(24, 26, 34, 0.62);
        color: #d79921;
        animation-name: bubble-option-float-right;
        animation-delay: 500ms;
    }

    .bubble-option-core-language {
        background: rgba(24, 26, 34, 0.62);
        color: var(--color-on-surface);
    }

    .bubble-option-core-language-left {
        animation-name: bubble-option-float-left;
        animation-delay: 360ms;
    }

    .bubble-option-core-language-center {
        animation-name: bubble-option-float-center;
        animation-delay: 430ms;
    }

    .bubble-option-core-language-right {
        animation-name: bubble-option-float-right;
        animation-delay: 500ms;
    }

    .bubble-option-icon {
        width: 18px;
        height: 18px;
        color: inherit;
        opacity: 1;
        transition: none;
    }

    .bubble-option-text {
        color: inherit;
        font-size: var(--typography-size-sm);
        font-weight: 700;
        line-height: 1;
        text-wrap: none;
        opacity: 1;
        transition: none;
    }

    .bubble-option-hidden {
        display: none;
    }

    @keyframes bubble-option-float-left {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(-3px, -6px) scale(1.05);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    @keyframes bubble-option-float-center {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(0px, -7px) scale(1.04);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    @keyframes bubble-option-float-right {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(3px, -5px) scale(1.05);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
