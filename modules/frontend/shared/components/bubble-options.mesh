<props>
blur_enabled:    { type: "bool", default: true, label: "Backdrop blur" }
blur_radius:     { type: "size", default: "var(--effect-backdrop-blur-popup-radius)", label: "Blur radius" }
blur_background: { type: "color", default: "var(--effect-backdrop-blur-popup-background)", label: "Frosted background" }
</props>

<template>
    <box
        class="bubble-options-stage"
        style={bubbleStageStyle()}
        role="menu"
        onscroll={onscroll}
        aria-label={label}
    >
        {#for item in items}
            <button
                class="bubble-option"
                style={bubbleOptionStyle(item.id)}
                role="menuitemradio"
                aria-checked={item.active}
                onclick={onselect(item.id)}
                onpointerenter={onoptionpointerenter}
                onfocus={onoptionfocus}
                onblur={onoptionblur}
                onkeydown={onoptionkeydown}
                data-tooltip-disabled="true"
                title={item.title}
                aria-label={item.title}
            >
                <box class={bubbleMotionClass(item.id)}>
                    <box class={blurCoreClass(item.core_class)}>
                        <icon class={item.icon_class} name={item.icon} size="14" />
                        <text class={item.text_class}>{item.text}</text>
                    </box>
                </box>
            </button>
        {/for}
    </box>
</template>

<script lang="luau">
label = "Options"

-- Each entry: { id, core_class, icon_class, icon, text_class, text, title,
-- active }. This component owns layout and structural classes; callers only
-- describe the option's content and visual variant.
items = {}

-- Called with the selected item's `id` (onselect(item.id)).
onselect = nil
onscroll = nil
onoptionpointerenter = nil
onoptionfocus = nil
onoptionblur = nil
onoptionkeydown = nil

local ITEM_SIZE = 36
local HORIZONTAL_STEP = 28
local HORIZONTAL_PADDING = 10
local TOP_OFFSET = 8
local ARC_DEPTH = 24

local function itemIndex(id)
    for index, item in items do
        if item.id == id then
            return index
        end
    end
    return 1
end

function bubbleStageStyle()
    local count = math.max(#items, 1)
    local width = HORIZONTAL_PADDING * 2 + ITEM_SIZE + HORIZONTAL_STEP * (count - 1)
    return "width: " .. width .. "px; height: 74px;"
end

function bubbleOptionStyle(id)
    local count = math.max(#items, 1)
    local index = itemIndex(id)
    local left = HORIZONTAL_PADDING + HORIZONTAL_STEP * (index - 1)
    local top = TOP_OFFSET

    if count > 1 then
        local normalized = (2 * (index - 1) / (count - 1)) - 1
        top = TOP_OFFSET + ARC_DEPTH * (1 - normalized * normalized)
    end

    return string.format("left: %.2fpx; top: %.2fpx;", left, top)
end

function bubbleMotionClass(id)
    if #items ~= 3 then
        return "bubble-options-motion"
    end
    local variants = { "left", "center", "right" }
    return "bubble-options-motion bubble-options-motion-" .. variants[itemIndex(id)]
end

function blurCoreClass(core_class)
    if props.blur_enabled then
        return core_class .. " bubble-option-core-blur"
    end
    return core_class
end
</script>

<style>
    .bubble-options-stage {
        /* One continuous popup-local hitbox spans the gaps between bubbles. */
        position: relative;
        overflow: visible;
    }

    .bubble-option {
        position: absolute;
        width: 36px;
        height: 36px;
        justify-content: center;
        align-items: center;
        padding: 0;
        border-radius: var(--radius-full);
        /* The button is a stationary hit target while its child animates in.
        It must not emit a paint primitive at the final resting position. */
        background: transparent;
        border-width: 0;
        opacity: 1;
        /* Overrides the theme's global background-color-first transition default. */
        transition: none;
    }

    .bubble-options-motion,
    .bubble-option-core {
        width: 36px;
        height: 36px;
        justify-content: center;
        align-items: center;
        border-radius: var(--radius-full);
    }

    .bubble-options-motion {
        opacity: 1;
        transform: translate(0px, 0px) scale(1);
        transition: transform 360ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 220ms var(--animation-curves-bezier-standard);
    }

    .bubble-options-motion-left {
        transition-delay: 0ms;
    }

    .bubble-options-motion-center {
        transition-delay: 45ms;
    }

    .bubble-options-motion-right {
        transition-delay: 90ms;
    }

    .bubble-options-motion-left.mesh-surface-entering {
        transform: translate(46px, 4px) scale(0.12);
    }

    .bubble-options-motion-left.mesh-surface-exiting {
        transform: translate(46px, 4px) scale(0.12);
        opacity: 0;
    }

    .bubble-options-motion-center.mesh-surface-entering {
        transform: translate(18px, -20px) scale(0.12);
    }

    .bubble-options-motion-center.mesh-surface-exiting {
        transform: translate(18px, -20px) scale(0.12);
        opacity: 0;
    }

    .bubble-options-motion-right.mesh-surface-entering {
        transform: translate(-10px, 4px) scale(0.12);
    }

    .bubble-options-motion-right.mesh-surface-exiting {
        transform: translate(-10px, 4px) scale(0.12);
        opacity: 0;
    }

    .bubble-options-motion.mesh-surface-exiting {
        transition: transform 180ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 140ms var(--animation-curves-bezier-standard);
    }

    .bubble-option-core {
        border-width: 2px;
        border-style: solid;
        border-color: transparent;
        /* No drop shadow: the core's frosted background is translucent, and the
        renderer paints the shadow disc *behind* the fill where it shows through
        the translucency as an opaque dark backing — hiding the compositor blur
        that should read as the button's background. */
        box-shadow: none;
        color: var(--color-on-surface);
        /* Frosted glass: translucent core over compositor-blurred backdrop
        (org_kde_kwin_blur on the promoted popup surface); also blurs any
        in-surface content painted beneath the bubble. */
        opacity: 1;
        /* Overrides the theme's global background-color-first transition default. */
        transition: border-color var(--animation-duration-short) var(--animation-curves-bezier-standard);
        animation-duration: 2800ms;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
    }

    .bubble-option-core-blur {
        backdrop-filter: blur(prop(blur_radius));
    }

    .bubble-option-core.mesh-surface-exiting {
        animation-name: none;
    }

    .bubble-option-core-active {
        border-color: var(--color-primary);
    }

    .bubble-option-core:hover {
        border-color: var(--color-secondary);
    }

    .bubble-option-core-dark {
        background-color: prop(blur_background);
        color: #8394aa;
        animation-name: bubble-option-float-left;
        animation-delay: 360ms;
    }

    .bubble-option-core-light {
        background-color: prop(blur_background);
        color: #e9c46a;
        animation-name: bubble-option-float-center;
        animation-delay: 430ms;
    }

    .bubble-option-core-gruvbox {
        background-color: prop(blur_background);
        color: #d79921;
        animation-name: bubble-option-float-right;
        animation-delay: 500ms;
    }

    .bubble-option-core-language {
        background-color: prop(blur_background);
        color: var(--color-on-surface);
    }

    .bubble-option-core-language-left {
        animation-name: bubble-option-float-left;
        animation-delay: 360ms;
    }

    .bubble-option-core-language-center {
        animation-name: bubble-option-float-center;
        animation-delay: 430ms;
    }

    .bubble-option-core-language-right {
        animation-name: bubble-option-float-right;
        animation-delay: 500ms;
    }

    .bubble-option-icon {
        width: 18px;
        height: 18px;
        color: inherit;
        opacity: 1;
        transition: none;
    }

    .bubble-option-text {
        color: inherit;
        font-size: var(--typography-size-sm);
        font-weight: 700;
        line-height: 1;
        text-wrap: none;
        opacity: 1;
        transition: none;
    }

    .bubble-option-hidden {
        display: none;
    }

    @keyframes bubble-option-float-left {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(-3px, -6px) scale(1.05);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    @keyframes bubble-option-float-center {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(0px, -7px) scale(1.04);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    @keyframes bubble-option-float-right {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(3px, -5px) scale(1.05);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }
</style>
