{
  "name": "@mesh/theme-selector",
  "version": "0.1.0",
  "description": "Theme selection popover for the navigation bar.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "capabilities": {
      "required": [
        "shell.surface",
        "theme.read"
      ]
    },
    "entrypoints": {
      "main": "src/main.mesh"
    },
    "contributes": {
      "settings": {
        "namespace": "@mesh/theme-selector",
        "schema": {
          "surface": {
            "type": "object",
            "description": "Placement and sizing for the theme selector popover.",
            "properties": {
              "anchor": {
                "type": "enum",
                "values": ["top", "bottom", "left", "right"],
                "default": "top",
                "description": "Screen edge anchor."
              },
              "layer": {
                "type": "enum",
                "values": ["background", "bottom", "top", "overlay"],
                "default": "overlay",
                "description": "Layer-shell stacking layer."
              },
              "width": {
                "type": "integer",
                "default": 0,
                "min": 0,
                "max": 480,
                "description": "Surface width in pixels. Use 0 for content-measured width."
              },
              "height": {
                "type": "integer",
                "default": 0,
                "min": 0,
                "max": 480,
                "description": "Surface height in pixels. Use 0 for content-measured height."
              },
              "keyboard_mode": {
                "type": "enum",
                "values": ["none", "on_demand"],
                "default": "on_demand",
                "description": "Keyboard interactivity policy."
              },
              "visible_on_start": {
                "type": "boolean",
                "default": false,
                "description": "Whether this surface starts visible."
              }
            }
          }
        }
      }
    },
    "surfaceLayout": {
      "size_policy": "content_measured"
    },
    "accessibility": {
      "role": "menu"
    }
  }
}
