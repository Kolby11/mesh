{
  "name": "@mesh/theme-selector",
  "version": "0.1.0",
  "description": "Theme selection popover for the navigation bar.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "interfaces": {
        "mesh.theme": ">=1.0"
      },
      "resources": {
        "icons": ["@mesh/icons-material-symbols", "@mesh/icons-default"]
      },
      "capabilities": [
        "shell.surface",
        "theme.read"
      ]
    },
    "iconRequirements": {
      "required": [
        "palette",
        "weather-clear",
        "weather-clear-night"
      ]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "left",
      "layer": "overlay",
      "width": 112,
      "height": 116,
      "exclusive_zone": 0,
      "keyboard_mode": "on_demand",
      "visible_on_start": false,
      "size": "content_measured",
      "prefers_content_children_sizing": true,
      "min_width": 112,
      "max_width": 112,
      "min_height": 116,
      "max_height": 116,
      "display_transition": {
        "show_ms": 120,
        "hide_ms": 120
      }
    },
    "accessibility": {
      "role": "menu"
    }
  }
}
