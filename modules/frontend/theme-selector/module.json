{
  "name": "@mesh/theme-selector",
  "version": "0.1.0",
  "description": "Theme selection popover for the navigation bar.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "component",
    "uses": {
      "interfaces": {
        "mesh.theme": ">=1.0"
      },
      "resources": {
        "icons": [
          "@mesh/icons-material-symbols",
          "@mesh/icons-default"
        ]
      },
      "capabilities": [
        "theme.read"
      ]
    },
    "iconRequirements": {
      "required": [
        "palette",
        "weather-clear",
        "weather-clear-night"
      ]
    },
    "entry": "src/main.mesh",
    "accessibility": {
      "role": "menu"
    }
  }
}
