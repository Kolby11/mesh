{
  "name": "@mesh/theme-selector",
  "version": "0.1.0",
  "description": "Theme selection popover for the navigation bar.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "interfaces": {
        "mesh.theme": ">=1.0"
      },
      "capabilities": [
        "shell.surface",
        "theme.read"
      ]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "top",
      "layer": "overlay",
      "width": 0,
      "height": 0,
      "keyboard_mode": "on_demand",
      "visible_on_start": false,
      "size": "content_measured"
    },
    "accessibility": {
      "role": "menu"
    }
  }
}
