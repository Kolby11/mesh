<template>
    <popover class="theme-float-shell" onmouseleave={onSelectorLeave} aria-label="Select theme">
        <box class="theme-float-stage">
            <button class="{dark_class}" onclick={onDark} aria-label="Default Dark">
                <box class="theme-bubble-core theme-bubble-core-dark">
                    <icon class="theme-bubble-icon" name="weather-clear-night" size="14" />
                </box>
            </button>
            <button class="{light_class}" onclick={onLight} aria-label="Default Light">
                <box class="theme-bubble-core theme-bubble-core-light">
                    <icon class="theme-bubble-icon" name="weather-clear" size="14" />
                </box>
            </button>
            <button class="{gruvbox_class}" onclick={onGruvbox} aria-label="Gruvbox">
                <box class="theme-bubble-core theme-bubble-core-gruvbox">
                    <icon class="theme-bubble-icon" name="palette" size="14" />
                </box>
            </button>
        </box>
    </popover>
</template>

<script lang="luau">
local theme = require("mesh.theme")

dark_class = "theme-bubble theme-bubble-dark"
light_class = "theme-bubble theme-bubble-light"
gruvbox_class = "theme-bubble theme-bubble-gruvbox"

local THEME_DARK = "mesh-default-dark"
local THEME_LIGHT = "mesh-default-light"
local THEME_GRUVBOX = "gruvbox-dark"

local function sync_classes(current)
    dark_class = "theme-bubble theme-bubble-dark"
    light_class = "theme-bubble theme-bubble-light"
    gruvbox_class = "theme-bubble theme-bubble-gruvbox"

    if current == THEME_DARK then
        dark_class = dark_class .. " theme-bubble-active"
    elseif current == THEME_LIGHT then
        light_class = light_class .. " theme-bubble-active"
    elseif current == THEME_GRUVBOX then
        gruvbox_class = gruvbox_class .. " theme-bubble-active"
    end
end

function render(self)
    if theme then
        local current = theme.current or theme.theme_id or THEME_DARK
        sync_classes(current)
    end
end

local function apply_theme(id)
    sync_classes(id)
    mesh.events.publish("shell.set-theme", { theme_id = id })
    mesh.popover.hide("@mesh/theme-selector")
end

function onDark()
    apply_theme(THEME_DARK)
end
function onLight()
    apply_theme(THEME_LIGHT)
end
function onGruvbox()
    apply_theme(THEME_GRUVBOX)
end

function onSelectorLeave()
    mesh.popover.hide("@mesh/theme-selector")
end
</script>

<style>
    .theme-float-shell {
        width: 100%;
        height: 100%;
        padding: 0;
        background: transparent;
        opacity: 1;
        transition: opacity var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    .theme-float-shell.mesh-surface-exiting {
        opacity: 0;
    }

    .theme-float-stage {
        width: 112px;
        height: 116px;
        position: relative;
        overflow: visible;
    }

    .theme-bubble {
        position: absolute;
        top: 40px;
        left: 56px;
        width: 36px;
        height: 36px;
        justify-content: center;
        align-items: center;
        padding: 0;
        border-radius: var(--radius-full);
        background: transparent;
        border-width: 0;
        opacity: 1;
        transition: transform 360ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 220ms var(--animation-curves-bezier-standard);
    }

    .theme-bubble-core {
        width: 36px;
        height: 36px;
        justify-content: center;
        align-items: center;
        border-radius: var(--radius-full);
        border-width: 2px;
        border-style: solid;
        border-color: transparent;
        box-shadow: 0px 6px 18px rgba(0, 0, 0, 0.34);
        color: var(--color-on-surface);
        animation-duration: 2800ms;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
    }

    .theme-bubble-dark {
        transform: translate(-46px, 2px) scale(1);
        transition-delay: 0ms;
    }

    .theme-bubble-light {
        transform: translate(-18px, 26px) scale(1);
        transition-delay: 45ms;
    }

    .theme-bubble-gruvbox {
        transform: translate(10px, 2px) scale(1);
        transition-delay: 90ms;
    }

    .theme-bubble.mesh-surface-entering {
        transform: translate(0px, -18px) scale(0.12);
        opacity: 0;
    }

    .theme-bubble.mesh-surface-exiting {
        transform: translate(0px, -18px) scale(0.12);
        opacity: 0;
        animation-name: none;
        transition: transform 160ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 120ms var(--animation-curves-bezier-standard);
    }

    .theme-bubble-core.mesh-surface-exiting {
        animation-name: none;
    }

    .theme-bubble-dark .theme-bubble-core {
        background: #121821;
        animation-name: theme-bubble-float-dark;
        animation-delay: 360ms;
    }

    .theme-bubble-light .theme-bubble-core {
        background: #f3ead7;
        color: #443a2b;
        animation-name: theme-bubble-float-light;
        animation-delay: 430ms;
    }

    .theme-bubble-gruvbox .theme-bubble-core {
        background: #5b4636;
        color: #f2e5bc;
        animation-name: theme-bubble-float-gruvbox;
        animation-delay: 500ms;
    }

    .theme-bubble-active .theme-bubble-core {
        border-color: var(--color-primary);
    }

    .theme-bubble:hover .theme-bubble-core {
        border-color: var(--color-secondary);
    }

    .theme-bubble-icon {
        width: 18px;
        height: 18px;
        color: inherit;
    }

    @keyframes theme-bubble-float-dark {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(-3px, -6px) scale(1.05);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    @keyframes theme-bubble-float-light {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(0px, -7px) scale(1.04);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    @keyframes theme-bubble-float-gruvbox {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        54% {
            transform: translate(3px, -5px) scale(1.05);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }
</style>
