<template>
    <popover
        class="theme-float-shell"
        aria-label="Select theme"
    >
        <BubbleOptions
            label="Select theme"
            item1_button_class="{dark_class}"
            item1_core_class="{dark_core_class}"
            item1_icon_class="bubble-option-icon"
            item1_icon="weather-clear-night"
            item1_text_class="bubble-option-text bubble-option-hidden"
            item1_text=""
            item1_title="Default Dark"
            onfirst={onDark}
            item2_button_class="{light_class}"
            item2_core_class="{light_core_class}"
            item2_icon_class="bubble-option-icon"
            item2_icon="weather-clear"
            item2_text_class="bubble-option-text bubble-option-hidden"
            item2_text=""
            item2_title="Default Light"
            onsecond={onLight}
            item3_button_class="{gruvbox_class}"
            item3_core_class="{gruvbox_core_class}"
            item3_icon_class="bubble-option-icon"
            item3_icon="palette"
            item3_text_class="bubble-option-text bubble-option-hidden"
            item3_text=""
            item3_title="Gruvbox"
            onthird={onGruvbox}
            onscroll={onThemeScroll}
        />
    </popover>
</template>

<script lang="luau">
local theme = require("mesh.theme")
local BubbleOptions = require("../../shared/components/bubble-options.mesh")

dark_class = "bubble-option bubble-option-left"
light_class = "bubble-option bubble-option-center"
gruvbox_class = "bubble-option bubble-option-right"
dark_core_class = "bubble-option-core bubble-option-core-dark"
light_core_class = "bubble-option-core bubble-option-core-light"
gruvbox_core_class = "bubble-option-core bubble-option-core-gruvbox"

local THEME_DARK = "mesh-default-dark"
local THEME_LIGHT = "mesh-default-light"
local THEME_GRUVBOX = "gruvbox-dark"

local function sync_classes(current)
    dark_class = "bubble-option bubble-option-left"
    light_class = "bubble-option bubble-option-center"
    gruvbox_class = "bubble-option bubble-option-right"
    dark_core_class = "bubble-option-core bubble-option-core-dark"
    light_core_class = "bubble-option-core bubble-option-core-light"
    gruvbox_core_class = "bubble-option-core bubble-option-core-gruvbox"

    if current == THEME_DARK then
        dark_class = dark_class .. " bubble-option-active"
        dark_core_class = dark_core_class .. " bubble-option-core-active"
    elseif current == THEME_LIGHT then
        light_class = light_class .. " bubble-option-active"
        light_core_class = light_core_class .. " bubble-option-core-active"
    elseif current == THEME_GRUVBOX then
        gruvbox_class = gruvbox_class .. " bubble-option-active"
        gruvbox_core_class = gruvbox_core_class .. " bubble-option-core-active"
    end
end

function render(self)
    if theme then
        local current = theme.current or theme.theme_id or THEME_DARK
        sync_classes(current)
    end
end

-- Selecting a theme does not close the popover: it stays open so the user can
-- keep choosing. It closes on pointer leave (onPopoverLeave) or, for keyboard
-- activation, on focus leave.
local function apply_theme(id)
    mesh.events.publish("shell.set-theme", { theme_id = id })
end

function onDark()
    apply_theme(THEME_DARK)
end

function onLight()
    apply_theme(THEME_LIGHT)
end

function onGruvbox()
    apply_theme(THEME_GRUVBOX)
end

function onThemeScroll(_event)
    -- Theme currently has exactly three options, but the shared bubble control
    -- supports scroll cycling for callers with larger option sets.
end

</script>

<style>
    .theme-float-shell {
        width: 100%;
        height: 100%;
        padding: 0;
        background: transparent;
        opacity: 1;
        transition: opacity var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    .theme-float-shell.mesh-surface-exiting {
        opacity: 0;
    }
</style>
