<props>
    blur_enabled:    { type: "bool", default: true, label: "Backdrop blur" }
    blur_radius:     { type: "size", default: "var(--effect-backdrop-blur-popup-radius)", label: "Blur radius" }
    blur_background: { type: "color", default: "var(--effect-backdrop-blur-popup-background)", label: "Frosted background" }
</props>

<template>
    <popover
        open={open}
        class="theme-float-shell"
        aria-label="Select theme"
        anchor-ref="themeButton"
        anchor="bottom"
        gravity="bottom"
        onpointerenter={onPopoverEnter}
        onpointerleave={onPopoverLeave}
    >
        <BubbleOptions
            label="Select theme"
            items={items}
            onselect={onSelectTheme}
            onscroll={onThemeScroll}
            onoptionpointerenter={onOptionPointerEnter}
            onoptionfocus={onOptionFocus}
            onoptionblur={onOptionBlur}
            onoptionkeydown={onOptionKeyDown}
        />
    </popover>
</template>

<script lang="luau">
local theme = require("mesh.theme")
local BubbleOptions = require("../../shared/components/bubble-options.mesh")

open = false
local CLOSE_BRIDGE_KEY = "theme-popover-close"
local CLOSE_BRIDGE_DELAY_MS = 400

local function cancel_bridge_close()
    mesh.events.publish("shell.cancel-handler", { key = CLOSE_BRIDGE_KEY })
end

local function schedule_bridge_close()
    mesh.events.publish("shell.schedule-handler", {
        key = CLOSE_BRIDGE_KEY,
        handler = "closeThemePopoverBridge",
        delay_ms = CLOSE_BRIDGE_DELAY_MS,
    })
end

-- One descriptor per visible slot; BubbleOptions owns its structural classes.
items = {}

local THEME_DARK = "mesh-default-dark"
local THEME_LIGHT = "mesh-default-light"
local THEME_GRUVBOX = "gruvbox-dark"

local THEME_OPTIONS = {
    { id = THEME_DARK, core = "bubble-option-core-dark", icon = "weather-clear-night" },
    { id = THEME_LIGHT, core = "bubble-option-core-light", icon = "weather-clear" },
    { id = THEME_GRUVBOX, core = "bubble-option-core-gruvbox", icon = "palette" },
}

local THEME_LABELS = {
    [THEME_DARK] = "Default Dark",
    [THEME_LIGHT] = "Default Light",
    [THEME_GRUVBOX] = "Gruvbox",
}

local function build_option(option, current)
    local core_class = "bubble-option-core " .. option.core
    if option.id == current then
        core_class = core_class .. " bubble-option-core-active"
    end

    return {
        id = option.id,
        core_class = core_class,
        icon_class = "bubble-option-icon",
        icon = option.icon,
        text_class = "bubble-option-text bubble-option-hidden",
        text = "",
        title = THEME_LABELS[option.id],
        active = option.id == current,
    }
end

local function sync_options(current)
    local next_items = {}
    for index, option in THEME_OPTIONS do
        next_items[index] = build_option(option, current)
    end
    items = next_items
end

function render(self)
    if theme then
        local current = theme.current or theme.theme_id or THEME_DARK
        sync_options(current)
    end
end

-- Selecting a theme does not close the popover: it stays open so the user can
-- keep choosing. It closes on pointer leave (onPopoverLeave) or, for keyboard
-- activation, on focus leave.
function onSelectTheme(theme_id)
    mesh.events.publish("shell.set-theme", { theme_id = theme_id })
end

function onThemeScroll(_event)
    -- Theme currently has exactly three options, but the shared bubble control
    -- supports scroll cycling for callers with larger option sets.
end

function onPopoverEnter(event)
    cancel_bridge_close()
    self.PopoverEnter:fire(event)
end

function onPopoverLeave()
    schedule_bridge_close()
    self.PopoverLeave:fire()
end

function onOptionFocus(event)
    cancel_bridge_close()
    self.PopoverEnter:fire(event)
end

function onOptionPointerEnter(event)
    cancel_bridge_close()
    self.PopoverEnter:fire(event)
end

function onOptionBlur(_event)
    schedule_bridge_close()
end

function onOptionKeyDown(event)
    if event and event.key == "Escape" then
        cancel_bridge_close()
        open = false
        self.KeyboardDismissRequested:fire()
    end
end

function closeThemePopoverBridge()
    open = false
    self.CloseRequested:fire()
end
</script>

<style>
    .theme-float-shell {
        /* Sized to the bounding box of the BubbleOptions content instead of a
        hardcoded size — <popover> isn't a container tag, so it needs the
        fit value explicitly (box/row/column default to it). */
        width: fit;
        height: fit;
        padding: 0;
        background: transparent;
        opacity: 1;
        transform: translateY(0px) scale(1);
        transition: transform 220ms var(--animation-curves-bezier-emphasized-decelerate),
        opacity 180ms var(--animation-curves-bezier-standard);
    }

    .theme-float-shell.mesh-surface-entering {
        opacity: 1;
        transform: translateY(-8px) scale(0.92);
    }

    .theme-float-shell.mesh-surface-exiting {
        opacity: 0;
        transform: translateY(-6px) scale(0.94);
        transition: transform 140ms var(--animation-curves-bezier-standard),
        opacity 180ms var(--animation-curves-bezier-standard);
    }
</style>
