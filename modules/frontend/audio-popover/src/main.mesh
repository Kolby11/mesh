<template>
  <popover class="audio-popover-shell" aria-label="Audio controls">
    <column class="audio-popover">
      <slider
        class="audio-slider"
        min="0"
        max="100"
        value="{slider_value}"
        orient="vertical"
        onchange={onVolumeChange}
        onrelease={onVolumeRelease}
      />
      <text class="audio-percent">{audio_percent_label}</text>
    </column>
  </popover>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "mesh.audio@>=1.0")
if not audio_ok then audio = nil end

audio_percent_label = "--%"
slider_value = 0
volume_dragging = false
pending_slider_value = nil
last_sent_slider_value = nil

local function clamp_percent(value)
    local numeric = tonumber(value) or 0
    if numeric < 0 then return 0 end
    if numeric > 100 then return 100 end
    return math.floor(numeric + 0.5)
end

local function sync_audio_copy(percent)
    local safe = clamp_percent(percent)
    slider_value = safe
    audio_percent_label = string.format("%d%%", safe)
end

if audio_ok and audio and audio.VolumeChanged then
    audio.VolumeChanged:on(function(event)
        local percent = clamp_percent(event.level)
        -- While the user is actively dragging, keep showing the drag
        -- position instead of snapping to a stale backend value.
        if not volume_dragging then
            pending_slider_value = nil
            sync_audio_copy(percent)
        end
    end)
end

function render(self)
    if not audio_ok or not audio or audio.available == false then
        audio_percent_label = "--%"
        slider_value = 0
        volume_dragging = false
        pending_slider_value = nil
        return
    end

    -- While the slider is mid-drag, keep the drag position
    -- (already set by onVolumeChange). Don't read from the
    -- backend until the user releases.
    if volume_dragging then
        return
    end

    local percent = clamp_percent(audio.percent)

    -- If a pending value still exists (drag just ended), converge
    -- toward the backend value. Once they match, clear the pending
    -- state so future renders track the backend normally.
    if pending_slider_value ~= nil then
        if math.abs(percent - pending_slider_value) <= 2 then
            pending_slider_value = nil
        else
            sync_audio_copy(pending_slider_value)
            return
        end
    end

    sync_audio_copy(percent)
end

function onVolumeChange(value)
    local pct = clamp_percent(value)
    volume_dragging = true
    pending_slider_value = pct
    sync_audio_copy(pct)
    if audio_ok and audio and audio.available ~= false then
        if last_sent_slider_value == nil or math.abs(last_sent_slider_value - pct) >= 1 then
            last_sent_slider_value = pct
            audio.set_volume("default", pct / 100)
        end
    end
end

function onVolumeRelease(value)
    volume_dragging = false
    pending_slider_value = clamp_percent(value)
    last_sent_slider_value = nil
end
</script>

<style>
.audio-popover-shell {
    width: 100%;
    height: 100%;
    padding: 0 token(spacing.sm) token(spacing.sm) token(spacing.sm);
    background: transparent;
    opacity: 1;
    transition: opacity token(animation.duration.short) token(animation.curves.bezier.standard);
}

.audio-popover-shell.mesh-surface-exiting {
    opacity: 0;
}

.audio-popover {
    gap: token(spacing.xs);
    padding: token(spacing.xs);
    align-items: center;
    border-radius: token(radius.lg);
    background: token(color.surface-container);
    color: token(color.on-surface);
}

.audio-slider {
    width: 32px;
    height: 160px;
}

.audio-slider:focus-visible {
    border-radius: token(radius.md);
}

.audio-percent {
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface);
    text-align: center;
}
</style>
