<template>
  <box class="audio-popover-shell">
    <column class="audio-popover">
      <row class="audio-header">
        <icon class="audio-icon" name="{icon_name}" size="18" />
        <column class="audio-copy">
          <text class="audio-title">{audio_title}</text>
          <text class="audio-status">{audio_status}</text>
        </column>
        <text class="audio-percent">{audio_percent_label}</text>
      </row>

      <slider
        class="audio-slider"
        min="0"
        max="1"
        value="{slider_value}"
        onchange={onVolumeChange}
        onrelease={onVolumeRelease}
      />

      <row class="audio-actions">
        <button class="audio-action audio-action-compact" onclick={onVolumeDown} aria-label="Lower volume">
          <text class="audio-action-text">-</text>
        </button>
        <button class="audio-action" onclick={onToggleMute} aria-label="{mute_button_label}">
          <text class="audio-action-text">{mute_button_text}</text>
        </button>
        <button class="audio-action audio-action-compact" onclick={onVolumeUp} aria-label="Raise volume">
          <text class="audio-action-text">+</text>
        </button>
      </row>
    </column>
  </box>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "mesh.audio@>=1.0")
if not audio_ok then audio = nil end

icon_name = "audio-volume-muted"
audio_title = "Audio unavailable"
audio_status = "Audio service unavailable"
audio_percent_label = "--%"
slider_value = 0.0
mute_button_text = "Mute"
mute_button_label = "Toggle mute"
volume_dragging = false
pending_slider_value = nil
audio_muted = false
last_sent_slider_value = nil

local function clamp_unit(value)
    local numeric = tonumber(value) or 0
    if numeric < 0 then return 0.0 end
    if numeric > 1 then return 1.0 end
    return numeric
end

local function clamp_percent(value)
    local numeric = tonumber(value) or 0
    if numeric < 0 then return 0 end
    if numeric > 100 then return 100 end
    return math.floor(numeric + 0.5)
end

local function sync_audio_copy(percent, muted)
    local safe_percent = clamp_percent(percent)
    slider_value = clamp_unit(safe_percent / 100)
    audio_percent_label = string.format("%d%%", safe_percent)
    audio_muted = muted and true or false

    if muted or safe_percent == 0 then
        icon_name = "audio-volume-muted"
    elseif safe_percent < 34 then
        icon_name = "audio-volume-low"
    elseif safe_percent < 67 then
        icon_name = "audio-volume-medium"
    else
        icon_name = "audio-volume-high"
    end

    if muted then
        audio_title = "Audio muted"
        audio_status = string.format("Muted at %d%%", safe_percent)
        mute_button_text = "Unmute"
        mute_button_label = "Unmute audio"
    else
        audio_title = "Audio output"
        audio_status = string.format("Volume %d%%", safe_percent)
        mute_button_text = "Mute"
        mute_button_label = "Mute audio"
    end
end

function onRender()
    if not audio_ok or not audio or audio.available == false then
        icon_name = "audio-volume-muted"
        audio_title = "Audio unavailable"
        audio_status = "Audio service unavailable"
        audio_percent_label = "--%"
        slider_value = 0.0
        mute_button_text = "Mute"
        mute_button_label = "Audio unavailable"
        volume_dragging = false
        pending_slider_value = nil
        return
    end

    local percent = clamp_percent(audio.percent)
    local muted = audio.muted or false

    local backend_value = clamp_unit(percent / 100)
    if pending_slider_value ~= nil then
        if math.abs(backend_value - pending_slider_value) <= 0.02 then
            pending_slider_value = nil
        else
            sync_audio_copy(pending_slider_value * 100, muted)
            return
        end
    end

    sync_audio_copy(percent, muted)
end

function onVolumeChange(value)
    local normalized = clamp_unit(value)
    volume_dragging = true
    pending_slider_value = normalized
    sync_audio_copy(normalized * 100, audio_muted)
    if audio_ok and audio and audio.available ~= false then
        if last_sent_slider_value == nil or math.abs(last_sent_slider_value - normalized) >= 0.01 then
            last_sent_slider_value = normalized
            audio.set_volume("default", normalized)
        end
    else
        audio_status = "Audio controls unavailable"
    end
end

function onVolumeRelease(value)
    volume_dragging = false
    pending_slider_value = clamp_unit(value)
    last_sent_slider_value = nil
end

function onToggleMute()
    if audio_ok and audio and audio.available ~= false then
        local next_muted = not (audio.muted or false)
        if type(audio.set_muted) == "function" then
            audio.set_muted("default", next_muted)
        else
            audio.toggle_mute()
        end
    else
        audio_status = "Audio controls unavailable"
    end
end

function onVolumeDown()
    if audio_ok and audio and audio.available ~= false then
        local next_value = clamp_unit(slider_value - 0.05)
        pending_slider_value = next_value
        sync_audio_copy(next_value * 100, audio_muted)
        audio.set_volume("default", next_value)
    else
        audio_status = "Audio controls unavailable"
    end
end

function onVolumeUp()
    if audio_ok and audio and audio.available ~= false then
        local next_value = clamp_unit(slider_value + 0.05)
        pending_slider_value = next_value
        sync_audio_copy(next_value * 100, audio_muted)
        audio.set_volume("default", next_value)
    else
        audio_status = "Audio controls unavailable"
    end
end
</script>

<style>
.audio-popover-shell {
    width: 100%;
    height: 100%;
    padding: 0 token(spacing.sm) token(spacing.sm) token(spacing.sm);
    background: transparent;
    opacity: 1;
    transition: opacity token(animation.duration.short) token(animation.curves.bezier.standard);
}

.audio-popover-shell.mesh-surface-exiting {
    opacity: 0;
}

.audio-popover {
    width: 100%;
    height: 100%;
    gap: token(spacing.md);
    padding: token(spacing.md);
    border-radius: token(radius.lg);
    background: token(color.surface-container);
    color: token(color.on-surface);
}

.audio-header {
    width: 100%;
    align-items: center;
    gap: token(spacing.sm);
}

.audio-icon {
    width: 28px;
    height: 28px;
    justify-content: center;
    align-items: center;
    color: token(color.on-secondary-container);
}

.audio-copy {
    flex-grow: 1;
    gap: 2px;
}

.audio-title {
    font-size: token(typography.size.sm);
    font-weight: 700;
    color: token(color.on-surface);
}

.audio-status {
    font-size: token(typography.size.xs);
    color: token(color.on-surface-variant);
}

.audio-percent {
    font-size: token(typography.size.sm);
    font-weight: 700;
    color: token(color.on-surface);
}

.audio-slider {
    width: 100%;
    height: 28px;
}

.audio-slider:focus-visible {
    border-radius: token(radius.md);
}

.audio-actions {
    width: 100%;
    gap: token(spacing.sm);
    align-items: center;
}

.audio-action {
    height: 36px;
    padding: 0 token(spacing.md);
    justify-content: center;
    align-items: center;
    border-radius: token(radius.md);
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    transform: scale(1);
    transition: background-color token(animation.duration.short) token(animation.curves.bezier.standard),
                color token(animation.duration.short) token(animation.curves.bezier.standard),
                border-radius token(animation.duration.short) token(animation.curves.bezier.emphasized-decelerate),
                transform token(animation.duration.short) token(animation.curves.bezier.emphasized-decelerate);
}

.audio-action-compact {
    width: 36px;
    padding: 0;
}

.audio-action:focus-visible {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
    border-radius: token(radius.md);
}

.audio-action:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
    border-radius: token(radius.md);
    transform: scale(1.03);
}

.audio-action:active {
    background: token(color.primary);
    color: token(color.on-primary);
    border-radius: token(radius.full);
    transform: scale(0.96);
}

.audio-action-text {
    font-size: token(typography.size.sm);
    font-weight: 700;
}
</style>
