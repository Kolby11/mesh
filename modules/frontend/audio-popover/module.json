{
  "id": "@mesh/audio-popover",
  "name": "Audio Popover",
  "version": "0.1.0",
  "type": "surface",
  "api_version": "0.1",
  "description": "Compact audio controls surface anchored from the navigation bar.",
  "authors": [
    "MESH Project"
  ],
  "compatibility": {
    "mesh": ">=0.1.0",
    "compositors": [
      "wlr-layer-shell-v1"
    ]
  },
  "capabilities": {
    "required": [
      "shell.surface",
      "service.audio.read",
      "service.audio.control",
      "locale.read"
    ]
  },
  "dependencies": {
    "icon_packs": {
      "required": [
        "system"
      ]
    }
  },
  "icon_requirements": {
    "required": [
      "audio-volume-muted",
      "audio-volume-low",
      "audio-volume-medium",
      "audio-volume-high"
    ]
  },
  "entrypoints": {
    "main": "src/main.mesh"
  },
  "settings": {
    "namespace": "@mesh/audio-popover",
    "schema": {
      "surface": {
        "type": "object",
        "description": "Placement and sizing for the audio popover surface.",
        "properties": {
          "anchor": {
            "type": "enum",
            "values": [
              "top",
              "bottom",
              "left",
              "right"
            ],
            "default": "left",
            "description": "Screen edge this surface anchors to."
          },
          "layer": {
            "type": "enum",
            "values": [
              "background",
              "bottom",
              "top",
              "overlay"
            ],
            "default": "overlay",
            "description": "Layer-shell stacking layer."
          },
          "width": {
            "type": "integer",
            "default": 280,
            "min": 160,
            "max": 7680,
            "description": "Surface width in pixels."
          },
          "height": {
            "type": "integer",
            "default": 164,
            "min": 96,
            "max": 1080,
            "description": "Surface height in pixels."
          },
          "exclusive_zone": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 256,
            "description": "Reserved compositor space in pixels."
          },
          "keyboard_mode": {
            "type": "enum",
            "values": [
              "none",
              "exclusive",
              "on_demand"
            ],
            "default": "none",
            "description": "Keyboard interactivity policy for the surface."
          },
          "visible_on_start": {
            "type": "boolean",
            "default": false,
            "description": "Whether this surface starts visible when Mesh boots."
          }
        }
      }
    }
  },
  "surface_layout": {
    "size_policy": "fixed"
  },
  "accessibility": {
    "role": "dialog",
    "label": "Audio controls",
    "description": "Compact audio controls popover"
  }
}
