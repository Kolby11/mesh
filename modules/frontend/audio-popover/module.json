{
  "name": "@mesh/audio-popover",
  "version": "0.1.0",
  "description": "Compact audio controls surface anchored from the navigation bar.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "interfaces": {
        "mesh.audio": ">=1.0"
      },
      "capabilities": ["shell.surface", "service.audio.read", "service.audio.control"]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "left",
      "layer": "overlay",
      "width": 40,
      "height": 200,
      "exclusive_zone": 0,
      "keyboard_mode": "on_demand",
      "visible_on_start": false,
      "size": "content_measured",
      "prefers_content_children_sizing": true,
      "min_width": 36,
      "max_width": 48,
      "min_height": 180,
      "max_height": 260,
      "display_transition": {
        "show_ms": 120,
        "hide_ms": 120
      }
    },
    "accessibility": {
      "role": "dialog",
      "label": "Audio controls",
      "description": "Compact audio controls popover"
    }
  }
}
