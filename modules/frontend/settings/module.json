{
  "name": "@mesh/settings",
  "version": "0.1.0",
  "description": "Shell settings surface for modules, providers, theme, and language.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "interfaces": {
        "mesh.debug": ">=1.0",
        "mesh.theme": ">=1.0",
        "mesh.locale": ">=1.0"
      },
      "capabilities": [
        "shell.surface",
        "service.debug.read",
        "theme.read",
        "theme.write",
        "locale.read",
        "locale.write"
      ]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "right",
      "layer": "overlay",
      "exclusive_zone": 0,
      "keyboard_mode": "on_demand",
      "visible_on_start": false
    },
    "accessibility": {
      "role": "dialog",
      "label": "Settings",
      "description": "Manage installed modules, active providers, theme, and language"
    }
  }
}
