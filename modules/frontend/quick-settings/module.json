{
  "name": "@mesh/quick-settings",
  "version": "0.1.0",
  "description": "Quick settings panel with volume, brightness, theme and language controls.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "modules": {
        "@mesh/settings": ">=0.1.0"
      },
      "interfaces": {
        "mesh.audio": ">=1.0",
        "mesh.power": ">=1.0",
        "mesh.theme": ">=1.0"
      },
      "optionalInterfaces": {
        "mesh.brightness": ">=1.0"
      },
      "capabilities": [
        "shell.surface",
        "service.audio.read",
        "service.audio.control",
        "service.power.read",
        "service.brightness.read",
        "service.brightness.control",
        "theme.read",
        "locale.read",
        "locale.write"
      ]
    },
    "entry": "src/main.mesh",
    "surface": {
      "anchor": "top",
      "layer": "overlay",
      "keyboard_mode": "on_demand",
      "visible_on_start": false
    },
    "accessibility": {
      "role": "dialog"
    }
  }
}
