{
  "i18n": {
    "available_locales": [
      "en",
      "sk"
    ],
    "default_locale": "sk"
  },
  "surface": {
    "anchor": "top",
    "layer": "top",
    "width": 0,
    "height": 50,
    "exclusive_zone": 50,
    "keyboard_mode": "on_demand",
    "visible_on_start": true
  },
  "keyboard": {
    "shortcuts": {
      "mute": {
        "key": "m",
        "handler": "onMuteShortcut",
        "target_ref": "volume-button"
      }
    }
  }
}