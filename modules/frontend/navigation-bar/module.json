{
  "name": "@mesh/navigation-bar",
  "version": "0.1.0",
  "description": "Top-edge navigation bar surface with declarative keybind metadata for localized shortcut labels.",
  "mesh": {
    "apiVersion": "0.1",
    "kind": "frontend",
    "uses": {
      "modules": {
        "@mesh/audio-popover": ">=0.1.0",
        "@mesh/language-popover": ">=0.1.0",
        "@mesh/theme-selector": ">=0.1.0",
        "@mesh/quick-settings": ">=0.1.0"
      },
      "interfaces": {
        "mesh.audio": ">=1.0",
        "mesh.power": ">=1.0",
        "mesh.wm": ">=1.0",
        "mesh.theme": ">=1.0"
      },
      "optionalInterfaces": {
        "mesh.brightness": ">=1.0",
        "mesh.media": ">=1.0"
      },
      "resources": {
        "icons": ["@mesh/icons-default"]
      },
      "capabilities": [
        "shell.surface",
        "service.audio.read",
        "service.audio.control",
        "service.power.read",
        "service.brightness.read",
        "service.brightness.control",
        "service.wm.read",
        "service.wm.control",
        "service.media.read",
        "theme.read",
        "locale.read",
        "locale.write"
      ]
    },
    "i18n": {
      "defaultLocale": "en"
    },
    "iconRequirements": {
      "required": [
        "preferences-system",
        "preferences-desktop-locale",
        "weather-clear-night",
        "weather-clear",
        "audio-volume-muted",
        "audio-volume-low",
        "audio-volume-medium",
        "audio-volume-high",
        "battery-empty",
        "battery-caution",
        "battery-low",
        "battery-good",
        "battery-full",
        "media-playback-start",
        "window-close"
      ]
    },
    "entry": "src/main.mesh",
    "keybinds": {
      "mute": {
        "label": {
          "t": "keybind.mute.label",
          "fallback": "Mute audio"
        },
        "description": {
          "t": "keybind.mute.description",
          "fallback": "Toggle audio mute"
        },
        "category": {
          "t": "keybind.category.audio",
          "fallback": "Audio"
        },
        "trigger": {
          "kind": "shortcut",
          "key": "m"
        }
      }
    },
    "surface": {
      "anchor": "top",
      "layer": "top",
      "exclusive_zone": 56,
      "keyboard_mode": "none",
      "visible_on_start": true
    },
    "provides": {
      "i18n": [
        {
          "id": "en",
          "locale": "en",
          "path": "config/i18n/en.json"
        },
        {
          "id": "sk",
          "locale": "sk",
          "path": "config/i18n/sk.json"
        }
      ],
      "layout": [
        {
          "id": "main",
          "entrypoint": "src/main.mesh",
          "label": "Navigation Bar"
        }
      ],
      "settings": {
        "namespace": "@mesh/navigation-bar",
        "schema": {
          "keyboard": {
            "type": "object",
            "description": "Focused-surface keyboard defaults for the navigation bar. The manifest keybinds section declares keybind ids and default triggers; frontend components subscribe handlers to those ids.",
            "properties": {
              "shortcuts": {
                "type": "object",
                "description": "Shortcut definitions keyed by keybind id. Shell settings may remap the effective key per surface."
              }
            }
          }
        }
      }
    },
    "accessibility": {
      "role": "toolbar"
    }
  }
}
