<template>
  <stack class="nav-root">
    <row class="nav-shell">
      <column class="status-cluster">
        <row class="status-head">
          <text ref="status-primary" class="status-primary">{primary_status}</text>
          <box class="status-accent">
            <MetaPill />
          </box>
        </row>
        <column class="status-copy">
          <row ref="status-secondary" class="status-secondary-row">
            <MetaLabel />
            <text class="status-secondary">{secondary_status}</text>
            <BatteryButton />
          </row>
        </column>
      </column>
      <spacer class="nav-spacer" />
      <row ref="control-cluster" class="control-cluster">
        <row class="control-button-cell">
          <VolumeButton
            onActivate={onToggleAudioSurface}
          />
        </row>
        <row class="control-button-cell">
          <ThemeButton />
        </row>
        <row class="control-button-cell">
          <SettingsButton />
        </row>
      </row>
    </row>
    <AudioPopover hidden={audio_surface_hidden} />
  </stack>
</template>

<script lang="luau">
import AudioPopover from "@mesh/audio-popover"
import BatteryButton from "./components/battery-button.mesh"
import MetaLabel from "./components/meta-label.mesh"
import MetaPill from "./components/meta-pill.mesh"
import SettingsButton from "./components/settings-button.mesh"
import VolumeButton from "./components/volume-button.mesh"
import ThemeButton from "./components/theme-button.mesh"

local audio_ok, audio = pcall(require, "mesh.audio@>=1.0")
if not audio_ok then audio = nil end

audio_surface_id = "@mesh/audio-popover"
audio_surface_hidden = true
primary_status = "Shell surface active"
secondary_status = "Audio service offline"

local function clamp_percent(value)
    local percent = math.floor(tonumber(value) or 0)
    if percent < 0 then percent = 0 end
    if percent > 100 then percent = 100 end
    return percent
end

function onRender()
    if audio_ok and audio and audio.available ~= false then
        local percent = clamp_percent(audio.percent)
        if audio.muted then
            secondary_status = string.format("Audio muted at %d%%", percent)
        else
            secondary_status = string.format("Audio steady at %d%%", percent)
        end
    else
        secondary_status = "Audio service offline"
    end
end

function onToggleAudioSurface(event)
    local position = event.current_target.position or {}
    local margin_left = tonumber(position.margin_left) or 0
    -- Layer-shell places this popover in the usable area below the navbar's
    -- exclusive zone, so vertical margin is relative to that boundary.
    local margin_top = 0

    if audio_surface_hidden then
        audio_surface_hidden = false
        mesh.events.publish("shell.position-surface", {
            surface_id = audio_surface_id,
            margin_top = margin_top,
            margin_left = margin_left
        })
        -- Register the trigger so Tab from the volume button transfers
        -- focus into the popover, and Shift+Tab from inside returns here.
        mesh.popover.activate(audio_surface_id, event, { focus = true })
    else
        audio_surface_hidden = true
    end
end

function onMuteShortcut()
    if audio_ok and audio and audio.available ~= false then
        audio.toggle_mute()
    end
end
</script>

<style>
.nav-root {
    width: 100%;
    height: 100%;
}

.nav-shell {
    width: 100%;
    height: 100%;
    container-type: inline-size;
    justify-content: start;
    align-items: center;
    gap: token(spacing.lg);
    padding-inline: token(spacing.lg);
    background: token(color.surface);
    color: token(color.on-surface);
    transition: background-color token(animation.duration.short) token(animation.curves.bezier.standard),
                color token(animation.duration.short) token(animation.curves.bezier.standard),
                gap token(animation.duration.short) token(animation.curves.bezier.standard);
}

.status-cluster {
    justify-content: center;
    gap: 2px;
}

.status-copy {
    gap: 2px;
}

.status-head {
    align-items: center;
    gap: token(spacing.sm);
}

.nav-spacer {
    flex-grow: 1;
}

.status-primary {
    color: token(color.on-surface);
    font-size: token(typography.size.md);
    font-weight: 700;
    text-wrap: none;
}

.status-secondary-row {
    align-items: center;
    gap: token(spacing.xs);
    min-width: 0;
    transition: gap token(animation.duration.short) token(animation.curves.bezier.standard);
}

.status-secondary {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.sm);
    font-weight: 500;
    text-wrap: none;
}

.status-accent {
    flex-shrink: 0;
    animation-name: status-pulse;
    animation-duration: token(animation.duration.long);
    animation-timing-function: token(animation.curves.bezier.standard);
    animation-delay: 0ms;
    animation-iteration-count: 2;
    animation-direction: alternate;
    animation-fill-mode: both;
}

.control-cluster {
    height: 100%;
    flex-shrink: 0;
    align-items: center;
    gap: token(spacing.xs);
}

.control-button-cell {
    height: 40px;
    flex-shrink: 0;
    align-items: center;
}

@keyframes status-pulse {
    0% {
        opacity: 0.86;
        transform: scale(1);
    }

    55% {
        opacity: 1;
        transform: scale(1.03);
    }

    100% {
        opacity: 0.92;
        transform: scale(1);
    }
}

@container (max-width: 860px) {
    .nav-shell {
        gap: token(spacing.md);
    }

    .status-secondary {
        max-width: 180px;
    }
}

@container (max-width: 720px) {
    .nav-shell {
        gap: token(spacing.sm);
        padding-inline: token(spacing.md);
    }

    .status-secondary-row {
        gap: token(spacing.xs);
    }

    .status-secondary {
        display: none;
    }
}

@container (max-width: 560px) {
    .status-head {
        gap: token(spacing.xs);
    }

    .status-accent {
        display: none;
    }

    .status-primary {
        font-size: token(typography.size.sm);
    }
}
</style>
