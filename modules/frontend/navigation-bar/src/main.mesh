<template>
  <row class="nav-shell">
    <box class="meta">
        <SettingsButton onfocus={onSettingsFocus} onblur={onNavControlBlur} />
        <VolumeButton
          onActivate={audio_surface_handler}
          onfocus={onVolumeFocus}
          onblur={onNavControlBlur}
        />
        <ThemeButton onfocus={onThemeFocus} onblur={onNavControlBlur} />
    </box>
    <AudioPopover hidden={audio_surface_hidden} />
  </row>
</template>

<script lang="luau">
import AudioPopover from "@mesh/audio-popover"
import MetaLabel from "./components/meta-label.mesh"
import SettingsButton from "./components/settings-button.mesh"
import VolumeButton from "./components/volume-button.mesh"
import ThemeButton from "./components/theme-button.mesh"

local audio_ok, audio = pcall(require, "@mesh/audio@>=1.0")
if not audio_ok then audio = nil end

audio_surface_id = "@mesh/audio-popover"
audio_surface_hidden = true
audio_surface_handler = "__mesh_embed__::@mesh/navigation-bar::onToggleAudioSurface"

function onToggleAudioSurface(event)
    local position = event.current_target.position or {}
    local margin_left = tonumber(position.margin_left) or 0
    local margin_top = (tonumber(position.margin_bottom) or 0) + 8

    if audio_surface_hidden then
        audio_surface_hidden = false
        mesh.events.publish("shell.position-surface", {
            surface_id = audio_surface_id,
            margin_top = margin_top,
            margin_left = margin_left
        })
        -- Register the trigger so Tab from the volume button transfers
        -- focus into the popover, and Shift+Tab from inside returns here.
        pcall(function()
            mesh.popover.activate(audio_surface_id, event, { focus = true })
        end)
    else
        audio_surface_hidden = true
        mesh.events.publish("shell.hide-surface", {
            surface_id = audio_surface_id
        })
        pcall(function()
            mesh.popover.hide(audio_surface_id)
        end)
    end
end

function onMuteShortcut()
    if audio_ok and audio and audio.available ~= false then
        audio.toggle_mute()
    end
end
</script>

<style>
.nav-shell {
    --nav-surface: token(color.surface);
    width: 100%;
    height: 100%;
    justify-content: start;
    align-items: center;
    padding-inline: token(spacing.lg);
    background: var(--nav-surface);
    color: token(color.on-surface);
    transition: background-color 150ms ease-out;
}

.brand {
    align-items: center;
    gap: token(spacing.sm);
}

.brand-mark {
    width: 42px;
    height: 42px;
    justify-content: center;
    align-items: center;
    border-radius: token(radius.md);
    background: token(color.primary-container);
}

.brand-mark-text {
    color: token(color.on-primary-container);
    font-weight: 800;
    font-size: token(typography.size.lg);
}

.brand-copy {
    gap: 2px;
}

.eyebrow {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.xs);
}

.brand-name {
    font-size: token(typography.size.md);
    font-weight: 700;
}

.links {
    flex-grow: 1;
    justify-content: center;
    align-items: center;
    gap: token(spacing.xs);
}

.link {
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.full);
    background: token(color.surface-container);
}

.active {
    background: token(color.secondary-container);
}

.link-text {
    color: token(color.on-surface);
    font-size: token(typography.size.sm);
    font-weight: 600;
}

.meta {
    width: 100%;
    justify-content: start;
    align-items: center;
    gap: token(spacing.xs);
}

.focus-diagnostic {
    min-width: 172px;
    height: 36px;
    justify-content: center;
    align-items: center;
    padding-inline: token(spacing.md);
    border-radius: token(radius.full);
    background: token(color.surface-container-high);
    border-width: 1px;
    border-style: solid;
    border-color: token(color.outline-variant);
    transition: background-color 180ms ease-out,
                border-color 180ms ease-out,
                min-width 220ms ease-out;
}

.focus-diagnostic-label {
    color: token(color.on-surface);
    font-size: token(typography.size.xs);
    font-weight: 700;
    transition: color 180ms ease-out, letter-spacing 200ms ease-out;
}

@container (max-width: 760px) {
    .brand-copy {
        display: none;
    }

    .links {
        justify-content: end;
        gap: token(spacing.xs);
    }

    .link {
        padding-inline: token(spacing.sm);
    }

    .focus-diagnostic {
        min-width: 148px;
        padding-inline: token(spacing.sm);
    }
}
</style>
