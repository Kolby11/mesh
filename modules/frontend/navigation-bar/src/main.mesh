<template>
    <stack class="nav-root">
        <row class="nav-shell">

            <!-- Left: workspaces, active window, now playing -->
            <row class="left-cluster">
                <WorkspaceList />
                <WindowTitle />
                <NowPlaying />
            </row>

            <!-- Center: clock with date -->
            <ClockButton />

            <spacer class="nav-spacer" />

            <!-- Right: brightness, audio, theme, language, battery, settings -->
            <row class="right-cluster">
                <BrightnessButton />
                <row class="control-button-cell">
                    <VolumeButton onMuteKeybind={onMuteShortcut} />
                </row>
                <row class="control-button-cell">
                    <ThemeButton />
                </row>
                <row class="control-button-cell">
                    <LanguageButton />
                </row>
                <row class="control-button-cell">
                    <BatteryButton />
                </row>
                <row class="control-button-cell">
                    <SettingsButton />
                </row>
            </row>

        </row>
    </stack>
</template>

<script lang="luau">
local BatteryButton = require("./components/battery-button.mesh")
local BrightnessButton = require("./components/brightness-button.mesh")
local ClockButton = require("./components/clock-button.mesh")
local LanguageButton = require("./components/language-button.mesh")
local NowPlaying = require("./components/now-playing.mesh")
local SettingsButton = require("./components/settings-button.mesh")
local ThemeButton = require("./components/theme-button.mesh")
local VolumeButton = require("./components/volume-button.mesh")
local WindowTitle = require("./components/window-title.mesh")
local WorkspaceList = require("./components/workspace-list.mesh")

local audio = require("mesh.audio")

function onMuteShortcut()
    if audio and audio.available ~= false then
        if type(audio.set_muted) == "function" then
            audio.set_muted("default", not (audio.muted or false))
        else
            audio.toggle_mute()
        end
    end
end
</script>

<style>
    .nav-root {
        display: flex;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .nav-shell {
        width: 100%;
        height: 100%;
        container-type: inline-size;
        justify-content: start;
        align-items: center;
        gap: var(--spacing-md);
        padding-inline: var(--spacing-lg);
        overflow-x: hidden;
        overflow-y: hidden;
        background: rgba(10, 10, 14, 0.75);
        backdrop-filter: blur(20px);
        color: var(--color-on-surface);
        transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        gap var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    .left-cluster {
        align-items: center;
        gap: var(--spacing-sm);
        min-width: 0;
        flex-shrink: 1;
        transition: gap var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    .nav-spacer {
        flex-grow: 1;
    }

    .right-cluster {
        height: 100%;
        flex-shrink: 0;
        align-items: center;
        gap: 2px;
        transition: gap var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    .control-button-cell {
        height: 40px;
        flex-shrink: 0;
        align-items: center;
        padding-inline: 1px;
        padding-block: 0;
    }

    @container (max-width: 860px) {
        .nav-shell {
            gap: var(--spacing-sm);
        }
    }

    @container (max-width: 720px) {
        .nav-shell {
            gap: var(--spacing-sm);
            padding-inline: var(--spacing-md);
        }

        .right-cluster {
            gap: 1px;
        }
    }
</style>
