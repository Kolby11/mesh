<template>
  <stack class="nav-button-shell">
    <button
      class="nav-button"
      onclick={onSettingsToggle}
      onpointerenter={onSettingsEnter}
      onpointerleave={onSettingsLeave}
      aria-haspopup="true"
      title={t('nav.open_settings')}
      aria-label={t('nav.open_settings')}
    >
      <icon class="nav-button-glyph" name="preferences-system" size="18" />
    </button>
    <QuickSettings hidden={settings_surface_hidden} />
  </stack>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local QuickSettings = require("@mesh/quick-settings")

settings_surface_id = "@mesh/quick-settings"
settings_surface_hidden = true

local function show_settings_selector(event)
    if settings_surface_hidden then
        mesh.events.publish("shell.position-surface", {
            surface_id = settings_surface_id,
            margin_top = 0,
            margin_left = tonumber((event.current_target.position or {}).margin_left) or 0,
        })
        local focus = event.trigger ~= nil and event.trigger.type == "keyboard"
        mesh.popover.activate(settings_surface_id, event, { focus = focus })
        settings_surface_hidden = false
    end
end

local function hide_settings_selector(bridge)
    if not settings_surface_hidden then
        mesh.popover.hide(settings_surface_id, { bridge = bridge == true })
        settings_surface_hidden = true
    end
end

function onSettingsToggle(event)
    if settings_surface_hidden then
        show_settings_selector(event)
    else
        hide_settings_selector(false)
    end
end

-- Hover opens quick settings; leaving the trigger starts a core-owned hover
-- bridge so the pointer can cross into the promoted popup.
function onSettingsEnter(event)
    show_settings_selector(event)
end

function onSettingsLeave()
    hide_settings_selector(true)
end
</script>

<style>
.nav-button-shell {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
}

.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-xs);
    border-radius: var(--radius-full);
    transform: translateY(0px) scale(1);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-color var(--animation-duration-long) var(--animation-curves-bezier-standard),
                transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
}

.nav-button:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    transform: translateY(0px) scale(0.94);
}

.nav-button-glyph {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
    transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

@container (max-width: 720px) {
    .nav-button-shell {
        width: 36px;
        height: 36px;
    }

    .nav-button {
        width: 36px;
        height: 36px;
    }
}
</style>
