<template>
  <button
    class="nav-button"
    onclick={onButtonClick}
    aria-haspopup="true"
    title="{t('nav.open_settings')}"
    aria-label="{t('nav.open_settings')}"
  >
    <icon class="nav-button-glyph" name="preferences-system" size="18" />
  </button>
</template>

<script lang="luau">
onActivate = nil

function onButtonClick(event)
    if type(onActivate) == "function" then
        onActivate(event)
    end
end
</script>

<style>
.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-xs);
    border-radius: var(--radius-full);
    transform: translateY(0px) scale(1);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-color var(--animation-duration-long) var(--animation-curves-bezier-standard),
                transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
}

.nav-button:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    transform: translateY(0px) scale(0.94);
}

.nav-button-glyph {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
    transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}
</style>
