<template>
  <stack class="nav-button-shell">
    <button
      ref="language-button"
      class="{trigger_class}"
      onclick={onLanguageToggle}
      onpointerenter={onLanguageEnter}
      onpointerleave={onLanguageLeave}
      data-tooltip-disabled="{language_tooltip_disabled}"
      title="{language_tooltip}"
      aria-label="{t('nav.language_menu')}"
    >
      <label class="language-label">{current_locale_label}</label>
    </button>
    <LanguagePopover hidden={language_surface_hidden} />
  </stack>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local LanguagePopover = require("@mesh/language-popover")

current_locale_label = "EN"
language_surface_id = "@mesh/language-popover"
language_surface_hidden = true
language_tooltip = ""
language_tooltip_disabled = "false"
trigger_class = "nav-button"

local function locale_code()
    local locale = mesh.locale.current()
    if type(locale) ~= "string" or locale == "" then
        return "en"
    end
    return locale
end

local function locale_label(locale)
    if locale == "sk" or string.find(locale or "", "sk-", 1, true) == 1 then
        return "SK"
    end
    return "EN"
end

local function stored_locale(storage)
    local locale = storage and storage.language
    if locale == "en" or locale == "sk" then
        return locale
    end
    return nil
end

function init(self)
    local locale = stored_locale(self.storage)
    if locale ~= nil then
        mesh.locale.set(locale)
    end
    current_locale_label = locale_label(locale or locale_code())
end

local function sync_trigger_state()
    trigger_class = language_surface_hidden and "nav-button" or "nav-button nav-button-open"
    if language_surface_hidden then
        language_tooltip = t("nav.language_menu")
        language_tooltip_disabled = "false"
    else
        language_tooltip = ""
        language_tooltip_disabled = "true"
    end
end

local function target_bounds(event)
    local current = event and (event.current_target or event.current) or {}
    return current.bounds or {}
end

local function target_left_and_width(event)
    local bounds = target_bounds(event)
    local left = tonumber(bounds.left)
    local width = tonumber(bounds.width)
    if left == nil or width == nil then
        local position = (event and event.current_target and event.current_target.position) or {}
        left = tonumber(position.margin_left) or 0
        width = tonumber(position.width) or 40
    end
    return left, width
end

function render(self)
    current_locale_label = locale_label(locale_code())
    sync_trigger_state()
end

local function show_language_selector(event)
    if language_surface_hidden then
        local trigger_left, trigger_width = target_left_and_width(event)
        mesh.events.publish("shell.position-surface", {
            surface_id = language_surface_id,
            margin_top = -18,
            margin_left = trigger_left + (trigger_width / 2) - 56,
        })
        local focus = event.trigger ~= nil and event.trigger.type == "keyboard"
        mesh.popover.activate(language_surface_id, event, { focus = focus })
        language_surface_hidden = false
        sync_trigger_state()
    end
end

-- `bridge` defers the close through the core hover-bridge controller so the
-- cursor can travel from the trigger onto the promoted popup without it
-- closing underneath. Keyboard close passes false for an immediate hide.
local function hide_language_selector(bridge)
    if not language_surface_hidden then
        mesh.popover.hide(language_surface_id, { bridge = bridge == true })
        language_surface_hidden = true
        sync_trigger_state()
    end
end

-- Mouse interaction is hover-only (see onLanguageEnter/onLanguageLeave); a
-- click should never be required to open. Only keyboard activation toggles,
-- which also transfers focus into the popover so it closes on focus leave.
function onLanguageToggle(event)
    local keyboard = event ~= nil and event.trigger ~= nil and event.trigger.type == "keyboard"
    if not keyboard then
        return
    end
    if language_surface_hidden then
        show_language_selector(event)
    else
        hide_language_selector(false)
    end
end

-- Hover opens the selector; leaving the trigger starts a core-owned hover
-- bridge so the pointer can cross into the promoted popup before it closes.
function onLanguageEnter(event)
    show_language_selector(event)
end

function onLanguageLeave()
    hide_language_selector(true)
end
</script>

<style>
.nav-button-shell {
    width: 40px;
    height: 40px;
    position: relative;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    overflow: visible;
}

.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-xs);
    border-radius: var(--radius-full);
    transform: translateY(0px) scale(1);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
}

.nav-button-open {
    background: var(--color-primary-container);
    color: var(--color-on-primary-container);
    border-color: var(--color-primary);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    transform: translateY(0px) scale(0.94);
}

.language-label {
    color: inherit;
    font-size: var(--typography-size-sm);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.05em;
    user-select: none;
    transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

@container (max-width: 720px) {
    .nav-button-shell {
        width: 36px;
        height: 36px;
    }

    .nav-button {
        width: 36px;
        height: 36px;
    }
}
</style>
