<template>
  <stack class="nav-button-shell">
    <button
      ref="languageButton"
      class="{trigger_class}"
      onclick={onLanguageToggle}
      onpointerenter={onLanguageEnter}
      onpointerleave={onLanguageLeave}
      aria-haspopup="true"
      aria-expanded="{language_aria_expanded}"
      data-tooltip-disabled="{language_tooltip_disabled}"
      title="{language_tooltip}"
      aria-label="{t('nav.language_menu')}"
    >
      <label class="language-label">{current_locale_label}</label>
    </button>
    <LanguagePopover bind:this={lang_popover} />
  </stack>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local LanguagePopover = require("@mesh/language-popover")

current_locale_label = "EN"
language_surface_hidden = true
language_aria_expanded = "false"
language_tooltip = ""
language_tooltip_disabled = "false"
trigger_class = "nav-button"

lang_popover = nil
local lang_popover_connected = false
local CLOSE_BRIDGE_KEY = "language-popover-close"
local CLOSE_BRIDGE_DELAY_MS = 400

local function cancel_bridge_close()
    mesh.events.publish("shell.cancel-handler", { key = CLOSE_BRIDGE_KEY })
end

local function schedule_bridge_close()
    mesh.events.publish("shell.schedule-handler", {
        key = CLOSE_BRIDGE_KEY,
        handler = "closeLanguageBridge",
        delay_ms = CLOSE_BRIDGE_DELAY_MS,
    })
end

local function locale_code()
    local locale = mesh.locale.current()
    if type(locale) ~= "string" or locale == "" then
        return "en"
    end
    return locale
end

local function locale_label(locale)
    if locale == "sk" or string.find(locale or "", "sk-", 1, true) == 1 then
        return "SK"
    end
    return "EN"
end

local function stored_locale(storage)
    local locale = storage and storage.language
    if locale == "en" or locale == "sk" then
        return locale
    end
    return nil
end

function init(self)
    local locale = stored_locale(self.storage)
    if locale ~= nil then
        mesh.locale.set(locale)
    end
    current_locale_label = locale_label(locale or locale_code())
end

local function sync_trigger_state()
    trigger_class = language_surface_hidden and "nav-button" or "nav-button nav-button-open"
    language_aria_expanded = language_surface_hidden and "false" or "true"
    if language_surface_hidden then
        language_tooltip = t("nav.language_menu")
        language_tooltip_disabled = "false"
    else
        language_tooltip = ""
        language_tooltip_disabled = "true"
    end
end

local function do_open()
    if lang_popover and language_surface_hidden then
        cancel_bridge_close()
        lang_popover.open = true
        language_surface_hidden = false
        sync_trigger_state()
    end
end

local function do_close()
    cancel_bridge_close()
    if lang_popover and not language_surface_hidden then
        lang_popover.open = false
        language_surface_hidden = true
        sync_trigger_state()
    end
end

function render(self)
    current_locale_label = locale_label(locale_code())
    sync_trigger_state()

    -- Subscribe to popover events once the bound instance is available.
    if lang_popover ~= nil and not lang_popover_connected then
        lang_popover_connected = true
        lang_popover.PopoverEnter:on(function()
            cancel_bridge_close()
        end)
        lang_popover.CloseRequested:on(function()
            do_close()
        end)
        lang_popover.KeyboardDismissRequested:on(function()
            do_close()
        end)
    end
end

-- Keyboard-only toggle; hover opens/closes.
function onLanguageToggle(event)
    local keyboard = event ~= nil and event.trigger ~= nil and event.trigger.type == "keyboard"
    if not keyboard then
        return
    end
    if language_surface_hidden then
        do_open()
    else
        do_close()
    end
end

function onLanguageEnter(event)
    cancel_bridge_close()
    do_open()
end

function onLanguageLeave()
    if not language_surface_hidden then
        schedule_bridge_close()
    end
end

function closeLanguageBridge()
    do_close()
end
</script>

<style>
.nav-button-shell {
    width: 40px;
    height: 40px;
    position: relative;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    overflow: visible;
}

.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-xs);
    border-radius: var(--radius-full);
    transform: translateY(0px) scale(1);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
}

.nav-button-open {
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-color: var(--color-primary);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    transform: translateY(0px) scale(0.94);
}

.language-label {
    color: inherit;
    font-size: var(--typography-size-sm);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.05em;
    user-select: none;
    transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

@container (max-width: 720px) {
    .nav-button-shell {
        width: 36px;
        height: 36px;
    }

    .nav-button {
        width: 36px;
        height: 36px;
    }
}
</style>
