<template>
  <button
    class="brightness-button {brightness_button_class}"
    onscroll={onBrightnessScroll}
    ontwofingerscroll={onBrightnessScroll}
    title={t('nav.brightness') .. ' ' .. brightness_label}
    aria-label={t('nav.brightness') .. ' ' .. brightness_label}
  >
    <icon class="brightness-icon" name="{brightness_icon}" size="18" />
  </button>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
-- Optional interface: nil until a mesh.brightness provider is installed.
-- Without a provider the whole control hides instead of pretending to work.
local brightness = require("mesh.brightness")

brightness_level = 100
brightness_label = "100%"
brightness_icon = "display-brightness-high"
brightness_button_class = brightness and "" or "brightness-unavailable"

local function update_brightness_copy(level)
    brightness_level = math.max(0, math.min(100, math.floor(tonumber(level) or 100)))
    brightness_label = string.format("%d%%", brightness_level)

    if brightness_level == 0 then
        brightness_icon = "display-brightness-off"
    elseif brightness_level < 34 then
        brightness_icon = "display-brightness-low"
    elseif brightness_level < 67 then
        brightness_icon = "display-brightness-medium"
    else
        brightness_icon = "display-brightness-high"
    end
end

function render(self)
    if brightness and brightness.level ~= nil then
        update_brightness_copy(brightness.level)
    end
end

function onBrightnessScroll(event)
    if not brightness then
        return
    end

    local delta = event and event.delta or {}
    local dy = tonumber(delta.y) or 0
    if dy == 0 then
        return
    end

    -- The input boundary normalizes wheel and trackpad deltas alike:
    -- positive is up and negative is down.
    if dy > 0 then
        update_brightness_copy(brightness_level + 5)
        brightness.increase(5)
    else
        update_brightness_copy(brightness_level - 5)
        brightness.decrease(5)
    end
end
</script>

<style>
.brightness-button {
    width: 40px;
    height: 40px;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
    padding: 0;
    border-radius: var(--radius-full);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-width: 0;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

.brightness-button:hover {
    background: var(--color-surface-container-high);
}

.brightness-button:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
}

.brightness-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: inherit;
}

.brightness-unavailable {
    display: none;
}

@container (max-width: 720px) {
    .brightness-button {
        display: none;
    }
}
</style>
