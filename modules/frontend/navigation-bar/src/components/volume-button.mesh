<template>
  <button
    ref="volume-button"
    class="nav-button"
    keybind="{keybinds.mute}"
    onclick={onActivate}
    onkeybind={onMuteKeybind}
    title="{audio_tooltip}"
    aria-label="{t('nav.open_audio')}"
  >
    <icon class="nav-button-glyph" name="{icon_name}" size="18" />
  </button>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "mesh.audio@>=1.0")
if not audio_ok then audio = nil end

icon_name = "audio-volume-muted"
audio_tooltip = "Volume unavailable"
audio_percent = 0

local function update_audio_copy(percent, muted)
    audio_percent = percent

    if muted or percent == 0 then
        icon_name = "audio-volume-muted"
    elseif percent < 34 then
        icon_name = "audio-volume-low"
    elseif percent < 67 then
        icon_name = "audio-volume-medium"
    else
        icon_name = "audio-volume-high"
    end

    if muted then
        audio_tooltip = string.format("Volume muted at %d%%", percent)
    else
        audio_tooltip = string.format("Volume %d%%", percent)
    end
end

function onRender()
    if not audio_ok or not audio or audio.available == false then
        icon_name = "audio-volume-muted"
        audio_tooltip = "Audio service unavailable"
        audio_percent = 0
        return
    end

    local percent = math.floor(tonumber(audio.percent) or 0)
    if percent < 0 then percent = 0 end
    if percent > 100 then percent = 100 end
    local muted = audio.muted or false
    update_audio_copy(percent, muted)
end

</script>

<style>
.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: token(spacing.xs);
    border-radius: token(radius.lg);
    transform: translateY(0px) scale(1);
    background: token(color.surface-container);
    color: token(color.on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color token(animation.duration.short) token(animation.curves.bezier.standard),
                color token(animation.duration.short) token(animation.curves.bezier.standard),
                border-radius token(animation.duration.fast) token(animation.curves.bezier.standard),
                transform token(animation.duration.fast) token(animation.curves.bezier.standard);
}

.nav-button:hover {
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    border-radius: token(radius.full);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-radius: token(radius.full);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    border-radius: token(radius.full);
    transform: translateY(0px) scale(0.96);
}

.nav-button-glyph {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
    --icon-fill: 0;
    --icon-weight: 400;
    transition: color token(animation.duration.short) token(animation.curves.bezier.standard);
}

.nav-button:hover .nav-button-glyph {
    --icon-fill: 1;
    --icon-weight: 500;
}

.nav-button:active .nav-button-glyph {
    --icon-fill: 1;
    --icon-weight: 600;
}

@container (max-width: 720px) {
    .nav-button {
        width: 40px;
        padding: token(spacing.xs);
    }
}
</style>
