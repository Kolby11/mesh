<template>
  <button
    ref="volume-button"
    class="nav-button"
    keybind="{this.keybinds.mute.id}"
    onclick={onActivate}
    onkeybind={onMuteKeybind}
    title="{t(audio_tooltip_key) .. audio_tooltip_value}"
    aria-label="{t('nav.open_audio')}"
  >
    <icon class="nav-button-glyph" name="{icon_name}" size="18" />
  </button>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local audio = require("mesh.audio")

icon_name = "audio-volume-muted"
audio_tooltip_key = "nav.volume_unavailable"
audio_tooltip_value = ""
audio_percent = 0

local function update_audio_copy(percent, muted)
    audio_percent = percent

    if muted or percent == 0 then
        icon_name = "audio-volume-muted"
    elseif percent < 34 then
        icon_name = "audio-volume-low"
    elseif percent < 67 then
        icon_name = "audio-volume-medium"
    else
        icon_name = "audio-volume-high"
    end

    if muted then
        audio_tooltip_key = "nav.volume_muted_at"
    else
        audio_tooltip_key = "nav.volume_level"
    end
    audio_tooltip_value = string.format(" %d%%", percent)
end

if audio and audio.VolumeChanged then
    audio.VolumeChanged:on(function(event)
        local percent = math.floor(tonumber(event.level) or 0)
        if percent < 0 then percent = 0 end
        if percent > 100 then percent = 100 end
        local muted = audio.muted or false
        update_audio_copy(percent, muted)
    end)
end

function render(self)
    if not audio or audio.available == false then
        icon_name = "audio-volume-muted"
        audio_tooltip_key = "nav.audio_service_unavailable"
        audio_tooltip_value = ""
        audio_percent = 0
        return
    end

    local percent = math.floor(tonumber(audio.percent) or 0)
    if percent < 0 then percent = 0 end
    if percent > 100 then percent = 100 end
    local muted = audio.muted or false
    update_audio_copy(percent, muted)
end

</script>

<style>
.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-xs);
    border-radius: var(--radius-full);
    transform: translateY(0px) scale(1);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
}

.nav-button:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    transform: translateY(0px) scale(0.94);
}

.nav-button-glyph {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
    --icon-fill: 0;
    --icon-weight: 400;
    transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

.nav-button:hover .nav-button-glyph {
    --icon-fill: 1;
    --icon-weight: 500;
}

.nav-button:active .nav-button-glyph {
    --icon-fill: 1;
    --icon-weight: 600;
}

@container (max-width: 720px) {
    .nav-button {
        width: 36px;
        height: 36px;
    }
}
</style>
