<template>
  <row class="volume-widget" title="{audio_tooltip}">
    <button
      ref="volume-button"
      class="volume-button"
      onclick={onActivate}
      onfocus={onfocus}
      onblur={onblur}
      title="{audio_tooltip}"
      aria-label="{t('nav.open_audio')}"
    >
      <icon class="volume-glyph" name="{icon_name}" size="18" />
    </button>
  </row>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "@mesh/audio@>=1.0")
if not audio_ok then audio = nil end

icon_name = "audio-volume-muted"
audio_tooltip = "Volume unavailable"
audio_percent = 0

local function update_audio_copy(percent, muted)
    audio_percent = percent

    if muted or percent == 0 then
        icon_name = "audio-volume-muted"
    elseif percent < 34 then
        icon_name = "audio-volume-low"
    elseif percent < 67 then
        icon_name = "audio-volume-medium"
    else
        icon_name = "audio-volume-high"
    end

    if muted then
        audio_tooltip = string.format("Volume muted at %d%%", percent)
    else
        audio_tooltip = string.format("Volume %d%%", percent)
    end
end

function onRender()
    if not audio_ok or not audio or audio.available == false then
        icon_name = "audio-volume-muted"
        audio_tooltip = "Audio service unavailable"
        audio_percent = 0
        return
    end

    local percent = math.floor(tonumber(audio.percent) or 0)
    if percent < 0 then percent = 0 end
    if percent > 100 then percent = 100 end
    local muted = audio.muted or false
    update_audio_copy(percent, muted)
end

function onActivate()
end
</script>

<style>
.volume-widget {
    width: 44px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.xs);
    gap: token(spacing.xs);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    transition: background-color 140ms ease-out, border-radius 140ms ease-out;
}

.volume-widget:hover {
    background: token(color.secondary-container);
    border-radius: token(radius.full);
}

.volume-widget:focus-visible {
    background: token(color.tertiary-container);
    border-radius: token(radius.full);
}

.volume-button {
    width: 100%;
    height: 32px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.xs);
    border-radius: token(radius.sm);
    background: transparent;
    color: token(color.on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    transition: background-color 140ms ease-out, color 140ms ease-out, border-color 140ms ease-out, border-radius 140ms ease-out;
}

.volume-button:hover {
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    border-color: token(color.outline);
    border-radius: token(radius.full);
}

.volume-button:focus {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-color: token(color.primary);
}

.volume-button:focus-visible {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-color: token(color.primary);
}

.volume-glyph {
    width: 30px;
    height: 28px;
    justify-content: center;
    align-items: center;
    color: inherit;
}

</style>
