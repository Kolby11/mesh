<template>
    <stack class="nav-button-shell">
        <button
            ref="theme-button"
            class="{trigger_class}"
            onclick={onThemeToggle}
            onpointerenter={onThemeEnter}
            onpointerleave={onThemeLeave}
            aria-haspopup="true"
            data-tooltip-disabled="{theme_tooltip_disabled}"
            title="{theme_tooltip}"
            aria-label={t(theme_tooltip_key)}
        >
            <icon class="nav-button-glyph" name="{theme_icon}" size="18" />
        </button>
        <ThemeSelector bind:this={theme_popover} />
    </stack>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local theme = require("mesh.theme")
local ThemeSelector = require("@mesh/theme-selector")

theme_icon = "weather-clear-night"
theme_tooltip_key = "nav.select_theme"
theme_tooltip = ""
theme_tooltip_disabled = "false"
theme_is_dark = true
theme_surface_hidden = true
trigger_class = "nav-button"

theme_popover = nil
local theme_popover_connected = false
local CLOSE_BRIDGE_KEY = "theme-popover-close"
local CLOSE_BRIDGE_DELAY_MS = 180

local function cancel_bridge_close()
    mesh.events.publish("shell.cancel-handler", { key = CLOSE_BRIDGE_KEY })
end

local function schedule_bridge_close()
    mesh.events.publish("shell.schedule-handler", {
        key = CLOSE_BRIDGE_KEY,
        handler = "closeThemeBridge",
        delay_ms = CLOSE_BRIDGE_DELAY_MS,
    })
end

local function read_theme_is_dark()
    if theme then
        local current_is_dark = theme.is_dark
        if current_is_dark == nil and theme.state then
            current_is_dark = theme.state.is_dark
        end
        if current_is_dark ~= nil then
            return current_is_dark == true
        end

        local current = theme.current or theme.theme_id
        if current == nil and theme.state then
            current = theme.state.current or theme.state.theme_id
        end
        if type(current) == "string" then
            return string.find(current, "dark", 1, true) ~= nil
        end
    end
    return theme_is_dark
end

local function sync_trigger_state()
    trigger_class = theme_surface_hidden and "nav-button" or "nav-button nav-button-open"
    if theme_surface_hidden then
        theme_tooltip = t(theme_tooltip_key)
        theme_tooltip_disabled = "false"
    else
        theme_tooltip = ""
        theme_tooltip_disabled = "true"
    end
end

local function do_open()
    if theme_popover and theme_surface_hidden then
        cancel_bridge_close()
        theme_popover.open = true
        theme_surface_hidden = false
        sync_trigger_state()
    end
end

local function do_close()
    cancel_bridge_close()
    if theme_popover and not theme_surface_hidden then
        theme_popover.open = false
        theme_surface_hidden = true
        sync_trigger_state()
    end
end

function render(self)
    theme_is_dark = read_theme_is_dark()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip_key = "nav.select_theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip_key = "nav.select_theme"
    end
    sync_trigger_state()

    if theme_popover ~= nil and not theme_popover_connected then
        theme_popover_connected = true
        theme_popover.PopoverEnter:on(function()
            cancel_bridge_close()
        end)
        theme_popover.PopoverLeave:on(function()
            do_close()
        end)
    end
end

-- Keyboard-only toggle; hover opens/closes.
function onThemeToggle(event)
    local keyboard = event ~= nil and event.trigger ~= nil and event.trigger.type == "keyboard"
    if not keyboard then
        return
    end
    if theme_surface_hidden then
        do_open()
    else
        do_close()
    end
end

function onThemeEnter(event)
    cancel_bridge_close()
    do_open()
end

function onThemeLeave()
    if not theme_surface_hidden then
        schedule_bridge_close()
    end
end

function closeThemeBridge()
    do_close()
end
</script>

<style>
    .nav-button-shell {
        width: 40px;
        height: 40px;
        position: relative;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        overflow: visible;
    }

    .nav-button {
        width: 40px;
        height: 40px;
        position: relative;
        z-index: 3;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        padding: var(--spacing-xs);
        border-radius: var(--radius-full);
        transform: translateY(0px) scale(1);
        background: var(--color-surface-container);
        color: var(--color-on-surface);
        border-width: 2px;
        border-style: solid;
        border-color: transparent;
        text-wrap: none;
        transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
    }

    .nav-button-open {
        background: var(--color-primary-container);
        color: var(--color-on-primary-container);
        border-color: var(--color-primary);
        transform: translateY(-1px) scale(1.03);
    }

    .nav-button:hover {
        background: var(--color-secondary-container);
        color: var(--color-on-secondary-container);
        transform: translateY(-1px) scale(1.04);
    }

    .nav-button:focus,
    .nav-button:focus-visible {
        background: var(--color-tertiary-container);
        color: var(--color-on-tertiary-container);
        transform: translateY(-1px) scale(1.03);
    }

    .nav-button:active {
        background: var(--color-primary);
        color: var(--color-on-primary);
        border-color: var(--color-primary);
        transform: translateY(0px) scale(0.94);
    }

    .nav-button-glyph {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        color: inherit;
        transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    @container (max-width: 720px) {
        .nav-button-shell {
            width: 36px;
            height: 36px;
        }

        .nav-button {
            width: 36px;
            height: 36px;
        }
    }
</style>
