<template>
    <stack class="nav-button-shell">
        <button
            class="{trigger_class}"
            onclick={onThemeToggle}
            onmouseenter={onThemeEnter}
            aria-haspopup="true"
            title={t(theme_tooltip_key)}
            aria-label={t(theme_tooltip_key)}
        >
            <icon class="nav-button-glyph" name="{theme_icon}" size="18" />
        </button>
        <ThemeSelector hidden={theme_surface_hidden} />
    </stack>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local theme = require("mesh.theme")
local ThemeSelector = require("@mesh/theme-selector")

theme_icon = "weather-clear-night"
theme_tooltip_key = "nav.select_theme"
theme_is_dark = true
theme_surface_id = "@mesh/theme-selector"
theme_surface_hidden = true
trigger_class = "nav-button"

local function read_theme_is_dark()
    if theme then
        local current_is_dark = theme.is_dark
        if current_is_dark == nil and theme.state then
            current_is_dark = theme.state.is_dark
        end
        if current_is_dark ~= nil then
            return current_is_dark == true
        end

        local current = theme.current or theme.theme_id
        if current == nil and theme.state then
            current = theme.state.current or theme.state.theme_id
        end
        if type(current) == "string" then
            return string.find(current, "dark", 1, true) ~= nil
        end
    end
    return theme_is_dark
end

function render(self)
    theme_is_dark = read_theme_is_dark()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip_key = "nav.select_theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip_key = "nav.select_theme"
    end
    trigger_class = theme_surface_hidden and "nav-button" or "nav-button nav-button-open"
end

local function show_theme_selector(event)
    if theme_surface_hidden then
        local position = event.current_target.position or {}
        local trigger_left = tonumber(position.margin_left) or 0
        local trigger_width = tonumber(position.width) or 40
        mesh.events.publish("shell.position-surface", {
            surface_id = theme_surface_id,
            margin_top = -40,
            margin_left = trigger_left + (trigger_width / 2) - 56,
        })
        mesh.popover.activate(theme_surface_id, event, { focus = false })
        theme_surface_hidden = false
        trigger_class = "nav-button nav-button-open"
    end
end

function onThemeEnter(event)
    show_theme_selector(event)
end

function onThemeToggle(event)
    if theme_surface_hidden then
        show_theme_selector(event)
    else
        mesh.popover.hide(theme_surface_id)
        theme_surface_hidden = true
        trigger_class = "nav-button"
    end
end
</script>

<style>
    .nav-button-shell {
        width: 40px;
        height: 40px;
        position: relative;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        overflow: visible;
    }

    .nav-button {
        width: 40px;
        height: 40px;
        position: relative;
        z-index: 3;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        padding: var(--spacing-xs);
        border-radius: var(--radius-full);
        transform: translateY(0px) scale(1);
        background: var(--color-surface-container);
        color: var(--color-on-surface);
        border-width: 2px;
        border-style: solid;
        border-color: transparent;
        text-wrap: none;
        transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
    }

    .nav-button-open {
        background: var(--color-primary-container);
        color: var(--color-on-primary-container);
        border-color: var(--color-primary);
        transform: translateY(-1px) scale(1.03);
    }

    .nav-button:hover {
        background: var(--color-secondary-container);
        color: var(--color-on-secondary-container);
        transform: translateY(-1px) scale(1.04);
    }

    .nav-button:focus,
    .nav-button:focus-visible {
        background: var(--color-tertiary-container);
        color: var(--color-on-tertiary-container);
        transform: translateY(-1px) scale(1.03);
    }

    .nav-button:active {
        background: var(--color-primary);
        color: var(--color-on-primary);
        border-color: var(--color-primary);
        transform: translateY(0px) scale(0.94);
    }

    .nav-button-glyph {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        color: inherit;
        transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    @container (max-width: 720px) {
        .nav-button-shell {
            width: 36px;
            height: 36px;
        }

        .nav-button {
            width: 36px;
            height: 36px;
        }
    }
</style>
