<template>
    <stack class="nav-button-shell">
        <button
            class="{trigger_class}"
            onclick={onThemeToggle}
            onpointerenter={onThemeEnter}
            onpointerleave={onThemeLeave}
            aria-haspopup="true"
            data-tooltip-disabled="{theme_tooltip_disabled}"
            title="{theme_tooltip}"
            aria-label={t(theme_tooltip_key)}
        >
            <icon class="nav-button-glyph" name="{theme_icon}" size="18" />
        </button>
        <ThemeSelector hidden={theme_surface_hidden} />
    </stack>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local theme = require("mesh.theme")
local ThemeSelector = require("@mesh/theme-selector")

theme_icon = "weather-clear-night"
theme_tooltip_key = "nav.select_theme"
theme_tooltip = ""
theme_tooltip_disabled = "false"
theme_is_dark = true
theme_surface_id = "@mesh/theme-selector"
theme_surface_hidden = true
trigger_class = "nav-button"

local function read_theme_is_dark()
    if theme then
        local current_is_dark = theme.is_dark
        if current_is_dark == nil and theme.state then
            current_is_dark = theme.state.is_dark
        end
        if current_is_dark ~= nil then
            return current_is_dark == true
        end

        local current = theme.current or theme.theme_id
        if current == nil and theme.state then
            current = theme.state.current or theme.state.theme_id
        end
        if type(current) == "string" then
            return string.find(current, "dark", 1, true) ~= nil
        end
    end
    return theme_is_dark
end

local function sync_trigger_state()
    trigger_class = theme_surface_hidden and "nav-button" or "nav-button nav-button-open"
    if theme_surface_hidden then
        theme_tooltip = t(theme_tooltip_key)
        theme_tooltip_disabled = "false"
    else
        theme_tooltip = ""
        theme_tooltip_disabled = "true"
    end
end

local function target_bounds(event)
    local current = event and (event.current_target or event.current) or {}
    return current.bounds or {}
end

local function target_left_and_width(event)
    local bounds = target_bounds(event)
    local left = tonumber(bounds.left)
    local width = tonumber(bounds.width)
    if left == nil or width == nil then
        local position = (event and event.current_target and event.current_target.position) or {}
        left = tonumber(position.margin_left) or 0
        width = tonumber(position.width) or 40
    end
    return left, width
end

function render(self)
    theme_is_dark = read_theme_is_dark()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip_key = "nav.select_theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip_key = "nav.select_theme"
    end
    sync_trigger_state()
end

local function show_theme_selector(event)
    if theme_surface_hidden then
        local trigger_left, trigger_width = target_left_and_width(event)
        mesh.events.publish("shell.position-surface", {
            surface_id = theme_surface_id,
            margin_top = -18,
            margin_left = trigger_left + (trigger_width / 2) - 56,
        })
        local focus = event ~= nil and event.trigger ~= nil and event.trigger.type == "keyboard"
        mesh.popover.activate(theme_surface_id, event, { focus = focus })
        theme_surface_hidden = false
        sync_trigger_state()
    end
end

-- `bridge` defers the close through the core hover-bridge controller so the
-- cursor can travel from the trigger onto the promoted popup without it
-- closing underneath. Keyboard close passes false for an immediate hide.
local function hide_theme_selector(bridge)
    if not theme_surface_hidden then
        mesh.popover.hide(theme_surface_id, { bridge = bridge == true })
        theme_surface_hidden = true
        sync_trigger_state()
    end
end

-- Mouse interaction is hover-only (see onThemeEnter/onThemeLeave); a click
-- should never be required to open. Only keyboard activation toggles, which
-- also transfers focus into the popover so it closes on focus leave.
function onThemeToggle(event)
    local keyboard = event ~= nil and event.trigger ~= nil and event.trigger.type == "keyboard"
    if not keyboard then
        return
    end
    if theme_surface_hidden then
        show_theme_selector(event)
    else
        hide_theme_selector(false)
    end
end

-- Hover opens the selector; leaving the trigger starts a core-owned hover
-- bridge so the pointer can cross into the promoted popup before it closes.
function onThemeEnter(event)
    show_theme_selector(event)
end

function onThemeLeave()
    hide_theme_selector(true)
end
</script>

<style>
    .nav-button-shell {
        width: 40px;
        height: 40px;
        position: relative;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        overflow: visible;
    }

    .nav-button {
        width: 40px;
        height: 40px;
        position: relative;
        z-index: 3;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        padding: var(--spacing-xs);
        border-radius: var(--radius-full);
        transform: translateY(0px) scale(1);
        background: var(--color-surface-container);
        color: var(--color-on-surface);
        border-width: 2px;
        border-style: solid;
        border-color: transparent;
        text-wrap: none;
        transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        border-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
        transform var(--animation-duration-short) var(--animation-curves-bezier-emphasized-decelerate);
    }

    .nav-button-open {
        background: var(--color-primary-container);
        color: var(--color-on-primary-container);
        border-color: var(--color-primary);
        transform: translateY(-1px) scale(1.03);
    }

    .nav-button:hover {
        background: var(--color-secondary-container);
        color: var(--color-on-secondary-container);
        transform: translateY(-1px) scale(1.04);
    }

    .nav-button:focus,
    .nav-button:focus-visible {
        background: var(--color-tertiary-container);
        color: var(--color-on-tertiary-container);
        transform: translateY(-1px) scale(1.03);
    }

    .nav-button:active {
        background: var(--color-primary);
        color: var(--color-on-primary);
        border-color: var(--color-primary);
        transform: translateY(0px) scale(0.94);
    }

    .nav-button-glyph {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        justify-content: center;
        align-items: center;
        color: inherit;
        transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
    }

    @container (max-width: 720px) {
        .nav-button-shell {
            width: 36px;
            height: 36px;
        }

        .nav-button {
            width: 36px;
            height: 36px;
        }
    }
</style>
