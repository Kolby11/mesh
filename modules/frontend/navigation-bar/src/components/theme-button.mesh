<template>
  <button
    class="theme-button"
    onclick={onThemeToggle}
    title="{theme_tooltip}"
    aria-label="{theme_tooltip}"
  >
    <icon class="theme-glyph" name="{theme_icon}" size="18" />
  </button>
</template>

<script lang="luau">
theme_icon = "weather-clear-night"
theme_tooltip = "Switch to light theme"
theme_is_dark = true

function onRender()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip = "Switch to light theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip = "Switch to dark theme"
    end
end

function onThemeToggle()
    local next_theme
    if theme_is_dark then
        next_theme = "mesh-default-light"
    else
        next_theme = "mesh-default-dark"
    end
    theme_is_dark = not theme_is_dark
    mesh.events.publish("shell.set-theme", { theme_id = next_theme })
end
</script>

<style>
.theme-button {
    width: 44px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.xs);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    text-wrap: none;
}

.theme-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
    border-radius: token(radius.full);
}

.theme-glyph {
    width: 28px;
    height: 26px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: token(color.on-tertiary-container);
}
</style>
