<template>
  <button
    class="theme-button"
    onclick={onThemeToggle}
    onfocus={onfocus}
    onblur={onblur}
    title="{theme_tooltip}"
    aria-label="{theme_tooltip}"
  >
    <icon class="theme-glyph" name="{theme_icon}" size="18" />
  </button>
</template>

<script lang="luau">
theme_icon = "weather-clear-night"
theme_tooltip = "Switch to light theme"
theme_is_dark = true

function onRender()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip = "Switch to light theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip = "Switch to dark theme"
    end
end

function onThemeToggle()
    local next_theme
    if theme_is_dark then
        next_theme = "mesh-default-light"
    else
        next_theme = "mesh-default-dark"
    end
    theme_is_dark = not theme_is_dark
    mesh.events.publish("shell.set-theme", { theme_id = next_theme })
end
</script>

<style>
.theme-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.xs);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color 140ms ease-out, color 140ms ease-out, border-color 140ms ease-out, border-radius 140ms ease-out;
}

.theme-button:hover {
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    border-color: token(color.outline);
    border-radius: token(radius.full);
}

.theme-button:focus {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-color: token(color.primary);
    border-radius: token(radius.full);
}

.theme-button:focus-visible {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-color: token(color.primary);
    border-radius: token(radius.full);
}

.theme-glyph {
    width: 28px;
    height: 26px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
}
</style>
