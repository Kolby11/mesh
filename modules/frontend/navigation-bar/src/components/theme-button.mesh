<template>
  <button
    class="nav-button"
    onclick={onThemeToggle}
    onfocus={onfocus}
    onblur={onblur}
    title="{theme_tooltip}"
    aria-label="{theme_tooltip}"
  >
    <icon class="nav-button-glyph" name="{theme_icon}" size="18" />
  </button>
</template>

<script lang="luau">
theme_icon = "weather-clear-night"
theme_tooltip = "Switch to light theme"
theme_is_dark = true

function onRender()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip = "Switch to light theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip = "Switch to dark theme"
    end
end

function onThemeToggle()
    local next_theme
    if theme_is_dark then
        next_theme = "mesh-default-light"
    else
        next_theme = "mesh-default-dark"
    end
    theme_is_dark = not theme_is_dark
    mesh.events.publish("shell.set-theme", { theme_id = next_theme })
end
</script>

<style>
.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: token(spacing.xs);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color 180ms ease-out,
                color 180ms ease-out,
                border-color 180ms ease-out,
                border-radius 220ms ease-out,
                transform 180ms ease-out,
                padding 180ms ease-out;
}

.nav-button:hover {
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    border-color: token(color.outline);
    border-radius: token(radius.full);
    transform: scale(1.06);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-color: token(color.primary);
    border-radius: token(radius.full);
    transform: scale(1.04);
}

.nav-button:active {
    transform: scale(0.94);
    border-radius: token(radius.full);
}

.nav-button-glyph {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
    transition: color 180ms ease-out, transform 200ms ease-out;
}

.nav-button:hover .nav-button-glyph {
    transform: scale(1.08) rotate(15deg);
}

@container (max-width: 760px) {
    .nav-button {
        width: 40px;
        padding: token(spacing.xs);
    }
}
</style>
