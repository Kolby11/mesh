<template>
  <button
    class="nav-button"
    onclick={onThemeToggle}
    title="{theme_tooltip}"
    aria-label="{theme_tooltip}"
  >
    <icon class="nav-button-glyph" name="{theme_icon}" size="18" />
  </button>
</template>

<script lang="luau">
theme_icon = "weather-clear-night"
theme_tooltip = "Switch to light theme"
theme_is_dark = true

local theme_ok, theme = pcall(function()
    return require("mesh.theme")
end)
if not theme_ok then theme = nil end

local function read_theme_is_dark()
    if theme_ok and theme then
        local current_is_dark = theme.is_dark
        if current_is_dark == nil and theme.state then
            current_is_dark = theme.state.is_dark
        end
        if current_is_dark ~= nil then
            return current_is_dark == true
        end

        local current = theme.current or theme.theme_id
        if current == nil and theme.state then
            current = theme.state.current or theme.state.theme_id
        end
        if type(current) == "string" then
            return string.find(current, "dark", 1, true) ~= nil
        end
    end

    return theme_is_dark
end

local function sync_theme_state()
    theme_is_dark = read_theme_is_dark()
end

function onRender()
    sync_theme_state()
    if theme_is_dark then
        theme_icon = "weather-clear-night"
        theme_tooltip = "Switch to light theme"
    else
        theme_icon = "weather-clear"
        theme_tooltip = "Switch to dark theme"
    end
end

function onThemeToggle()
    sync_theme_state()
    local next_theme
    if theme_is_dark then
        next_theme = "mesh-default-light"
    else
        next_theme = "mesh-default-dark"
    end
    theme_is_dark = not theme_is_dark
    mesh.events.publish("shell.set-theme", { theme_id = next_theme })
end
</script>

<style>
.nav-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding: token(spacing.xs);
    border-radius: token(radius.lg);
    transform: translateY(0px) scale(1);
    background: token(color.surface-container);
    color: token(color.on-surface);
    border-width: 2px;
    border-style: solid;
    border-color: transparent;
    text-wrap: none;
    transition: background-color token(animation.duration.short) token(animation.curves.bezier.standard),
                color token(animation.duration.short) token(animation.curves.bezier.standard),
                border-radius token(animation.duration.fast) token(animation.curves.bezier.standard),
                transform token(animation.duration.fast) token(animation.curves.bezier.standard);
}

.nav-button:hover {
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    border-radius: token(radius.full);
    transform: translateY(-1px) scale(1.04);
}

.nav-button:focus,
.nav-button:focus-visible {
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    border-radius: token(radius.full);
    transform: translateY(-1px) scale(1.03);
}

.nav-button:active {
    border-radius: token(radius.full);
    transform: translateY(0px) scale(0.96);
}

.nav-button-glyph {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: inherit;
    transition: color token(animation.duration.short) token(animation.curves.bezier.standard);
}

@container (max-width: 720px) {
    .nav-button {
        width: 40px;
        padding: token(spacing.xs);
    }
}
</style>
