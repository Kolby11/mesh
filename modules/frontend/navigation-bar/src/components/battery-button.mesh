<template>
  <box
    class="battery-widget"
    title="{battery_tooltip}"
    aria-label="{battery_aria_label}"
  >
    <icon class="battery-glyph" name="{battery_icon_name}" size="18" />
    <text class="battery-value">{battery_label}</text>
  </box>
</template>

<script lang="luau">
local power_ok, power = pcall(require, "@mesh/power@>=1.0")
if not power_ok then power = nil end

battery_icon_name = "battery-empty"
battery_label = "--%"
battery_tooltip = "Battery status unavailable"
battery_aria_label = "Battery status unavailable"

function round_percent(level_value)
    local safe = level_value or 0
    if safe < 0 then safe = 0 end
    if safe <= 1 then
        safe = safe * 100
    end
    if safe > 100 then safe = 100 end
    return math.floor(safe + 0.5)
end

function format_minutes(total_minutes)
    if total_minutes == nil or total_minutes <= 0 then
        return "Unavailable"
    end
    local hours = math.floor(total_minutes / 60)
    local minutes = total_minutes % 60
    if hours > 0 and minutes > 0 then
        return string.format("%dh %dm", hours, minutes)
    end
    if hours > 0 then
        return string.format("%dh", hours)
    end
    return string.format("%dm", minutes)
end

function format_watts(watts)
    if watts == nil or watts <= 0 then
        return "Unavailable"
    end
    return string.format("%.1f W", watts)
end

function format_capacity(energy_now, energy_full)
    if energy_now == nil or energy_full == nil or energy_full <= 0 then
        return "Unavailable"
    end
    return string.format("%.1f / %.1f Wh", energy_now, energy_full)
end

function battery_icon_for(percent_value)
    if percent_value >= 95 then return "battery-full" end
    if percent_value >= 70 then return "battery-good" end
    if percent_value >= 45 then return "battery-low" end
    if percent_value >= 20 then return "battery-caution" end
    return "battery-empty"
end

function onRender()
    if not power_ok or not power or not power.available then
        battery_icon_name = "battery-empty"
        battery_label = "N/A"
        battery_tooltip = "Battery status unavailable"
        battery_aria_label = "Battery status unavailable"
        return
    end

    local percent_value = round_percent(power.level)
    local charging = power.charging or false
    local remaining_label = charging
        and format_minutes(power.time_to_full_minutes)
        or format_minutes(power.time_remaining_minutes)
    local remaining_prefix = charging and "Time to full" or "Estimated remaining"
    local status_label = charging and "Charging" or "On battery"

    battery_icon_name = battery_icon_for(percent_value)
    battery_label = string.format("%d%%", percent_value)
    battery_tooltip = string.format(
        "%s at %d%%. %s: %s. Power draw: %s. Charge: %s.",
        status_label,
        percent_value,
        remaining_prefix,
        remaining_label,
        format_watts(power.power_draw_watts),
        format_capacity(power.energy_now_watt_hours, power.energy_full_watt_hours)
    )
    battery_aria_label = string.format("Battery %d percent, %s", percent_value, status_label)
end
</script>

<style>
.battery-widget {
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    gap: token(spacing.xs);
    padding-inline: token(spacing.sm);
    border-radius: token(radius.full);
    background: token(color.surface-container);
    color: token(color.on-surface);
    text-wrap: none;
    transition: background-color token(animation.duration.short) token(animation.curves.bezier.standard),
                color token(animation.duration.short) token(animation.curves.bezier.standard),
                gap token(animation.duration.short) token(animation.curves.bezier.standard),
                transform token(animation.duration.short) token(animation.curves.bezier.standard);
}

.battery-widget:hover {
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    gap: token(spacing.sm);
    transform: scale(1.04);
}

.battery-glyph {
    width: 24px;
    height: 24px;
    justify-content: center;
    align-items: center;
    color: inherit;
    transition: color token(animation.duration.short) token(animation.curves.bezier.standard),
                transform token(animation.duration.short) token(animation.curves.bezier.standard);
}

.battery-widget:hover .battery-glyph {
    transform: scale(1.1);
}

.battery-value {
    color: inherit;
    font-size: token(typography.size.sm);
    font-weight: 700;
}

@container (max-width: 720px) {
    .battery-value {
        display: none;
    }

    .battery-widget {
        width: 44px;
        padding-inline: token(spacing.xs);
    }
}
</style>
