<template>
  <box
    class="battery-widget"
    title="{t(battery_tooltip_key) .. battery_tooltip_value}"
    aria-label="{t(battery_aria_key) .. battery_aria_value}"
  >
    <icon class="battery-glyph" name="{battery_icon_name}" size="18" />
    <text class="battery-value">{battery_label}</text>
  </box>
</template>

<script lang="luau">
local t = import("mesh.i18n", "t")
local power = require("mesh.power")

battery_icon_name = "battery-empty"
battery_label = "--%"
battery_tooltip_key = "nav.battery_unavailable"
battery_tooltip_value = ""
battery_aria_key = "nav.battery_unavailable"
battery_aria_value = ""

function round_percent(level_value)
    local safe = level_value or 0
    if safe < 0 then safe = 0 end
    if safe <= 1 then
        safe = safe * 100
    end
    if safe > 100 then safe = 100 end
    return math.floor(safe + 0.5)
end

function format_minutes(total_minutes)
    if total_minutes == nil or total_minutes <= 0 then
        return "--"
    end
    local hours = math.floor(total_minutes / 60)
    local minutes = total_minutes % 60
    if hours > 0 and minutes > 0 then
        return string.format("%dh %dm", hours, minutes)
    end
    if hours > 0 then
        return string.format("%dh", hours)
    end
    return string.format("%dm", minutes)
end

function format_watts(watts)
    if watts == nil or watts <= 0 then
        return "--"
    end
    return string.format("%.1f W", watts)
end

function format_capacity(energy_now, energy_full)
    if energy_now == nil or energy_full == nil or energy_full <= 0 then
        return "--"
    end
    return string.format("%.1f / %.1f Wh", energy_now, energy_full)
end

function battery_icon_for(percent_value)
    if percent_value >= 95 then return "battery-full" end
    if percent_value >= 70 then return "battery-good" end
    if percent_value >= 45 then return "battery-low" end
    if percent_value >= 20 then return "battery-caution" end
    return "battery-empty"
end

function render(self)
    if not power or not power.available then
        battery_icon_name = "battery-empty"
        battery_label = "N/A"
        battery_tooltip_key = "nav.battery_unavailable"
        battery_tooltip_value = ""
        battery_aria_key = "nav.battery_unavailable"
        battery_aria_value = ""
        return
    end

    local percent_value = round_percent(power.level)
    local charging = power.charging or false
    local remaining_label = charging
        and format_minutes(power.time_to_full_minutes)
        or format_minutes(power.time_remaining_minutes)
    local status_key = charging and "nav.charging" or "nav.on_battery"

    battery_icon_name = battery_icon_for(percent_value)
    battery_label = string.format("%d%%", percent_value)
    battery_tooltip_key = status_key
    battery_tooltip_value = string.format(
        " %d%%. %s. %s. %s.",
        percent_value,
        remaining_label,
        format_watts(power.power_draw_watts),
        format_capacity(power.energy_now_watt_hours, power.energy_full_watt_hours)
    )
    battery_aria_key = "nav.battery"
    battery_aria_value = string.format(" %d%%", percent_value)
end
</script>

<style>
.battery-widget {
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-xs);
    padding-inline: var(--spacing-sm);
    border-radius: var(--radius-full);
    background: var(--color-surface-container);
    color: var(--color-on-surface);
    text-wrap: none;
    transition: background-color var(--animation-duration-short) var(--animation-curves-bezier-standard),
                color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

.battery-widget:hover {
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
}

.battery-glyph {
    width: 24px;
    height: 24px;
    justify-content: center;
    align-items: center;
    color: inherit;
    transition: color var(--animation-duration-short) var(--animation-curves-bezier-standard);
}

.battery-value {
    color: inherit;
    font-size: var(--typography-size-sm);
    font-weight: 700;
}

@container (max-width: 720px) {
    .battery-value {
        display: none;
    }

    .battery-widget {
        width: 44px;
        padding-inline: var(--spacing-xs);
    }
}
</style>
