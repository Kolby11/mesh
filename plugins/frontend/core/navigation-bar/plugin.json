{
  "id": "@mesh/navigation-bar",
  "name": "Navigation Bar",
  "version": "0.1.0",
  "type": "surface",
  "api_version": "0.1",
  "description": "Top-edge navigation bar surface.",
  "authors": ["MESH Project"],
  "compatibility": {
    "mesh": ">=0.1.0",
    "compositors": ["wlr-layer-shell-v1"]
  },
  "capabilities": {
    "required": [
      "shell.surface",
      "service.audio.read",
      "theme.read",
      "locale.read"
    ]
  },
  "dependencies": {
    "plugins": {
      "@mesh/audio-interface": ">=1.0.0, <2.0.0"
    }
  },
  "entrypoints": {
    "main": "src/main.mesh"
  },
  "accessibility": {
    "role": "toolbar",
    "label": "Navigation bar",
    "description": "Top-level navigation bar surface"
  }
}
