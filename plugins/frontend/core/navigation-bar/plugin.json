{
  "id": "@mesh/navigation-bar",
  "name": "Navigation Bar",
  "version": "0.1.0",
  "type": "surface",
  "api_version": "0.1",
  "description": "Top-edge navigation bar surface.",
  "authors": [
    "MESH Project"
  ],
  "compatibility": {
    "mesh": ">=0.1.0",
    "compositors": [
      "wlr-layer-shell-v1"
    ]
  },
  "capabilities": {
    "required": [
      "shell.surface",
      "service.audio.read",
      "service.power.read",
      "service.theme.read",
      "theme.read",
      "locale.read"
    ]
  },
  "dependencies": {
    "plugins": {
      "@mesh/audio-interface": ">=1.0.0, <2.0.0",
      "@mesh/power-interface": ">=1.0.0, <2.0.0",
      "@mesh/shell-theme": ">=0.1.0, <1.0.0"
    }
  },
  "entrypoints": {
    "main": "src/main.mesh"
  },
  "settings": {
    "namespace": "@mesh/navigation-bar",
    "schema": {
      "surface": {
        "type": "object",
        "description": "Placement and sizing for the navigation bar surface.",
        "properties": {
          "anchor": {
            "type": "enum",
            "values": [
              "top",
              "bottom",
              "left",
              "right"
            ],
            "default": "top",
            "description": "Screen edge this surface anchors to."
          },
          "layer": {
            "type": "enum",
            "values": [
              "background",
              "bottom",
              "top",
              "overlay"
            ],
            "default": "top",
            "description": "Layer-shell stacking layer."
          },
          "width": {
            "type": "integer",
            "default": 1920,
            "min": 320,
            "max": 7680,
            "description": "Surface width in pixels."
          },
          "height": {
            "type": "integer",
            "default": 56,
            "min": 32,
            "max": 160,
            "description": "Surface height in pixels."
          },
          "exclusive_zone": {
            "type": "integer",
            "default": 56,
            "min": 0,
            "max": 256,
            "description": "Reserved compositor space in pixels."
          },
          "keyboard_mode": {
            "type": "enum",
            "values": [
              "none",
              "exclusive",
              "on_demand"
            ],
            "default": "none",
            "description": "Keyboard interactivity policy for the surface."
          },
          "visible_on_start": {
            "type": "boolean",
            "default": true,
            "description": "Whether this surface starts visible when Mesh boots."
          }
        }
      }
    }
  },
  "surface_layout": {
    "size_policy": "fixed"
  },
  "accessibility": {
    "role": "toolbar",
    "label": "Navigation bar",
    "description": "Top-level navigation bar surface"
  }
}