<template>
  <nav class="nav-shell">
    <div class="meta">
      <span class="meta-label">{t("nav.current")}</span>
      <div class="meta-pill">
        <span class="meta-pill-text">{t(active_key)}</span>
      </div>
      <button
        class="volume-widget"
        onclick={onVolumeClick}
        title="{audio.tooltip}"
        aria-label="{t('nav.open_audio')}"
      >
        <span class="volume-glyph" aria-hidden="true">{audio.glyph}</span>
        <div class="volume-copy">
          <span class="volume-label">{t("nav.volume")}</span>
          <span class="volume-value">{audio.label}</span>
