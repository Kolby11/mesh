<template>
  <nav class="nav-shell">
    <div class="meta">
      <span class="meta-label">{t("nav.current")}</span>
      <div class="meta-pill">
        <span class="meta-pill-text">{t("nav.dashboard")}</span>
      </div>
      <button
        class="settings-button"
        onclick={onSettingsClick}
        title="{t('nav.open_settings')}"
        aria-label="{t('nav.open_settings')}"
      >
        <icon class="settings-glyph" name="settings" size="18" />
        <span class="settings-label">{t("nav.settings")}</span>
      </button>
      <button
        class="volume-widget"
        onclick={onVolumeClick}
        title="{audio.tooltip}"
        aria-label="{t('nav.open_audio')}"
      >
        <icon class="volume-glyph" name="{audio.icon_name}" size="18" />
      </button>
    </div>
  </nav>
</template>

<script lang="luau">
function onVolumeClick()
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/volume-bar" })
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/quick-settings" })
end

function onSettingsClick()
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/quick-settings" })
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/volume-bar" })
end
</script>

