<template>
  <nav class="nav-shell">
    <div class="meta">
        <MetaLabel />
        <MetaPill />
        <SettingsButton />
        <VolumeButton />
        <BatteryButton />
    </div>
  </nav>
</template>

<script lang="luau">
import "@src/components/meta-label" as MetaLabel
import "@src/components/meta-pill" as MetaPill
import "@src/components/settings-button" as SettingsButton
import "@src/components/volume-button" as VolumeButton
import "@src/components/battery-button" as BatteryButton
mesh.state.set("icon_name", "audio-volume-muted")
mesh.state.set("audio_tooltip", "Volume unavailable")
mesh.state.set("battery_icon_name", "battery-empty")
mesh.state.set("battery_label", "--%")
mesh.state.set("battery_tooltip", "Battery status unavailable")
mesh.state.set("battery_aria_label", "Battery status unavailable")

mesh.service.bind("audio.muted", "audio_muted")
mesh.service.bind("audio.percent", "audio_percent")
mesh.service.on("audio", "sync_audio_state")
mesh.service.bind("power.available", "power_available")
mesh.service.bind("power.level", "power_level")
mesh.service.bind("power.charging", "power_charging")
mesh.service.bind("power.time_remaining_minutes", "power_time_remaining_minutes")
mesh.service.bind("power.time_to_full_minutes", "power_time_to_full_minutes")
mesh.service.bind("power.power_draw_watts", "power_draw_watts")
mesh.service.bind("power.energy_now_watt_hours", "power_energy_now_watt_hours")
mesh.service.bind("power.energy_full_watt_hours", "power_energy_full_watt_hours")
mesh.service.on("power", "sync_power_state")

function sync_audio_state()
    if audio_muted then
        icon_name = "audio-volume-muted"
    else
        if audio_percent == 0 then
            icon_name = "audio-volume-muted"
        else
            if audio_percent < 34 then
                icon_name = "audio-volume-low"
            else
                if audio_percent < 67 then
                    icon_name = "audio-volume-medium"
                else
                    icon_name = "audio-volume-high"
                end
            end
        end
    end

    local safe_percent = audio_percent or 0
    if audio_muted then
        audio_tooltip = string.format("Volume muted at %d%%", safe_percent)
    else
        audio_tooltip = string.format("Volume %d%%", safe_percent)
    end
end

function onSettingsClick(event)
    local trigger_left = event.current_target.position.margin_left or 0
    local quick_settings_width = 480
    local trigger_width = 44
    mesh.events.publish("shell.position-surface", {
        surface_id = "@mesh/quick-settings",
        margin_top = event.current_target.position.margin_top,
        margin_left = math.max(0, trigger_left - (quick_settings_width - trigger_width)),
    })
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/quick-settings" })
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/volume-bar" })
end

function onVolumeClick(event)
    mesh.events.publish("shell.position-surface", {
        surface_id = "@mesh/volume-bar",
        margin_top = event.current_target.position.margin_top,
        margin_left = event.current_target.position.margin_left,
    })
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/volume-bar" })
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/quick-settings" })
end

function onBatteryClick(event)
    mesh.events.publish("shell.position-surface", {
        surface_id = "@mesh/power-details",
        margin_top = event.current_target.position.margin_top,
        margin_left = event.current_target.position.margin_left,
    })
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/power-details" })
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/volume-bar" })
end

function round_percent(level_value)
    local safe = level_value or 0
    if safe < 0 then
        safe = 0
    end
    if safe > 1 then
        safe = 1
    end
    return math.floor((safe * 100) + 0.5)
end

function format_minutes(total_minutes)
    if total_minutes == nil or total_minutes <= 0 then
        return "Unavailable"
    end

    local hours = math.floor(total_minutes / 60)
    local minutes = total_minutes % 60

    if hours > 0 and minutes > 0 then
        return string.format("%dh %dm", hours, minutes)
    end

    if hours > 0 then
        return string.format("%dh", hours)
    end

    return string.format("%dm", minutes)
end

function format_watts(watts)
    if watts == nil or watts <= 0 then
        return "Unavailable"
    end
    return string.format("%.1f W", watts)
end

function format_capacity(energy_now, energy_full)
    if energy_now == nil or energy_full == nil or energy_full <= 0 then
        return "Unavailable"
    end
    return string.format("%.1f / %.1f Wh", energy_now, energy_full)
end

function battery_icon_for(percent_value)
    if percent_value >= 95 then
        return "battery-full"
    end
    if percent_value >= 70 then
        return "battery-good"
    end
    if percent_value >= 45 then
        return "battery-low"
    end
    if percent_value >= 20 then
        return "battery-caution"
    end
    return "battery-empty"
end

function sync_power_state()
    if not power_available then
        battery_icon_name = "battery-empty"
        battery_label = "N/A"
        battery_tooltip = "Battery status unavailable"
        battery_aria_label = "Battery status unavailable"
        return
    end

    local percent_value = round_percent(power_level)
    local remaining_label = power_charging and format_minutes(power_time_to_full_minutes) or format_minutes(power_time_remaining_minutes)
    local remaining_prefix = power_charging and "Time to full" or "Estimated remaining"
    local status_label = power_charging and "Charging" or "On battery"

    battery_icon_name = battery_icon_for(percent_value)
    battery_label = string.format("%d%%", percent_value)
    battery_tooltip = string.format(
        "%s at %d%%. %s: %s. Power draw: %s. Charge: %s.",
        status_label,
        percent_value,
        remaining_prefix,
        remaining_label,
        format_watts(power_draw_watts),
        format_capacity(power_energy_now_watt_hours, power_energy_full_watt_hours)
    )
    battery_aria_label = string.format("Battery %d percent, %s", percent_value, status_label)
end

</script>

<style>
.nav-shell {
    width: 100%;
    height: 100%;
    border-radius: token(radius.md);
    justify-content: start;
    align-items: center;
    padding-inline: token(spacing.lg);
    padding-block: token(spacing.sm);
    background: token(color.surface);
    color: token(color.on-surface);
}

.brand {
    align-items: center;
    gap: token(spacing.sm);
}

.brand-mark {
    width: 42px;
    height: 42px;
    justify-content: center;
    align-items: center;
    border-radius: token(radius.md);
    background: token(color.primary-container);
}

.brand-mark-text {
    color: token(color.on-primary-container);
    font-weight: 800;
    font-size: token(typography.size.lg);
}

.brand-copy {
    gap: 2px;
}

.eyebrow {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.xs);
}

.brand-name {
    font-size: token(typography.size.md);
    font-weight: 700;
}

.links {
    flex-grow: 1;
    justify-content: center;
    align-items: center;
    gap: token(spacing.xs);
}

.link {
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.full);
    background: token(color.surface-container);
}

.active {
    background: token(color.secondary-container);
}

.link-text {
    color: token(color.on-surface);
    font-size: token(typography.size.sm);
    font-weight: 600;
}

.meta {
    width: 100%;
    justify-content: start;
    align-items: center;
    gap: token(spacing.xs);
}

@container (max-width: 760px) {
    .brand-copy {
        display: none;
    }

    .links {
        justify-content: end;
        gap: token(spacing.xs);
    }

    .link {
        padding-inline: token(spacing.sm);
    }
}
</style>
