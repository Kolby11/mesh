<template>
  <div class="section">
    <div class="section-header">
      <span class="section-title">Wi-Fi Networks</span>
    </div>
    <div class="section-list">
      {#if wifi_enabled and wifi_networks and #wifi_networks > 0}
        {#for network in wifi_networks}
          <WiFiItem network_id="{network.id}" network_name="{network.name}" network_strength="{network.strength}" />
        {/for}
      {:else if wifi_enabled}
        <div class="section-message">Scanning for networks…</div>
      {:else}
        <div class="section-message">Wi-Fi is disabled</div>
      {/if}
    </div>
  </div>
</template>

