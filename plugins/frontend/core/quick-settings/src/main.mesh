<template>
  <section class="quick-settings">
    <div class="header">
      <span class="title">Quick Settings</span>
      <button class="close-button" onclick={onClose} title="Close quick settings" aria-label="Close quick settings">Close</button>
    </div>
    <div class="toggles">
      <button class="chip">Wi-Fi</button>
      <button class="chip">Bluetooth</button>
      <button class="chip wide">Do Not Disturb</button>
    </div>
    <section class="audio-widget">
      <div class="audio-header">
        <div class="audio-copy">
          <span class="audio-title">Audio</span>
          <span class="audio-subtitle">{audio.source_plugin}</span>
        </div>
        <span class="audio-value">{audio.label}</span>
      </div>
      <div class="volume-row">
        <button class="volume-button" onclick={onVolumeDown} title="Volume down" aria-label="Volume down">-</button>
        <slider class="volume-slider" min="0" max="100" value="{audio.percent}" mesh-action="audio-volume" title="{audio.tooltip}" aria-label="Volume" />
        <button class="volume-button" onclick={onVolumeUp} title="Volume up" aria-label="Volume up">+</button>
      </div>
      <div class="audio-actions">
        <button class="mute-button" onclick={onToggleMute} title="Toggle mute" aria-label="Toggle mute">
          <icon class="mute-icon" name="{icon_name}" size="18" />
        </button>
      </div>
    </section>
  </section>
</template>

<script lang="luau">
local icon_name = "audio-volume-muted"
local muted = mesh.service.bind("audio.muted")
local percent = mesh.service.bind("audio.percent")

function on_audio_update()
    if muted then
        icon_name = "audio-volume-muted"
    else
        if percent == 0 then
            icon_name = "audio-volume-muted"
        else
            if percent < 34 then
                icon_name = "audio-volume-low"
            else
                if percent < 67 then
                    icon_name = "audio-volume-medium"
                else
                    icon_name = "audio-volume-high"
                end
            end
        end
    end
end

function onClose()
    mesh.events.publish("shell.close-quick-settings", {})
end

function onVolumeDown()
    mesh.events.publish("mesh.audio.volume-down", {})
end

function onVolumeUp()
    mesh.events.publish("mesh.audio.volume-up", {})
end

function onToggleMute()
    mesh.events.publish("mesh.audio.toggle-mute", {})
end
</script>

<style>
.quick-settings {
    background: token(color.surface);
    color: token(color.on-surface);
    padding: token(spacing.lg);
    gap: token(spacing.md);
    width: 100%;
    height: 100%;
}

.header {
    justify-content: space-between;
    align-items: center;
    gap: token(spacing.md);
}

.title {
    font-size: token(typography.size.lg);
    font-weight: 700;
}

.close-button {
    width: content;
    flex-shrink: 0;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.sm);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    text-wrap: none;
}

.close-button:hover {
    background: token(color.surface-container-high);
}

.toggles {
    flex-wrap: nowrap;
    gap: token(spacing.sm);
}

.chip {
    width: content;
    flex-shrink: 0;
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    text-wrap: none;
}

.wide {
    width: 172px;
}

.chip:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.audio-widget {
    width: 100%;
    gap: token(spacing.md);
    padding: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
}

.audio-header {
    justify-content: space-between;
    align-items: center;
    gap: token(spacing.md);
}

.audio-copy {
    flex-direction: column;
    gap: 2px;
}

.audio-title {
    font-size: token(typography.size.md);
    font-weight: 700;
}

.audio-subtitle {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.xs);
}

.audio-value {
    width: 72px;
    justify-content: end;
    color: token(color.on-surface);
    font-size: token(typography.size.lg);
    font-weight: 800;
    text-wrap: none;
}

.volume-row {
    align-items: center;
    gap: token(spacing.sm);
}

.volume-button {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    border-radius: token(radius.sm);
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    font-size: token(typography.size.lg);
    font-weight: 800;
}

.volume-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.volume-slider {
    width: 100%;
    height: 40px;
    flex-grow: 1;
    color: token(color.primary);
}

.audio-actions {
    justify-content: start;
    align-items: center;
}

.mute-button {
    width: content;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface);
    text-wrap: none;
}

.mute-icon {
    width: 18px;
    height: 18px;
    color: token(color.on-surface);
}

.mute-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}
</style>
