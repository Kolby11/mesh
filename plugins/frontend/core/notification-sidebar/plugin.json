{
  "id": "@mesh/notification-sidebar",
  "name": "MESH Notification Sidebar",
  "version": "0.1.0",
  "type": "widget",
  "api_version": "0.1",
  "description": "Embeddable notification center sidebar widget",
  "authors": ["MESH Project"],
  "compatibility": {
    "mesh": ">=0.1.0"
  },
  "capabilities": {
    "required": [
      "theme.read",
      "locale.read"
    ]
  },
  "entrypoints": {
    "main": "src/main.mesh"
  },
  "exports": {
    "component": {
      "tag": "NotificationSidebar"
    }
  },
  "accessibility": {
    "role": "region",
    "label": "Notification sidebar",
    "description": "Sidebar shortcuts for the notification center"
  }
}
