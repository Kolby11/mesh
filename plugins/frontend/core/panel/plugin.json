{
  "id": "@mesh/panel",
  "name": "MESH Panel",
  "version": "0.1.0",
  "type": "surface",
  "api_version": "0.1",
  "description": "Top panel shell surface",
  "authors": ["MESH Project"],
  "compatibility": {
    "mesh": ">=0.1.0",
    "compositors": ["wlr-layer-shell-v1"]
  },
  "capabilities": {
    "required": [
      "shell.surface",
      "service.audio.read",
      "service.network.read",
      "service.power.read",
      "theme.read",
      "locale.read"
    ]
  },
  "dependencies": {
    "plugins": {
      "@mesh/audio-interface": ">=1.0.0, <2.0.0",
      "@mesh/network-interface": ">=1.0.0, <2.0.0",
      "@mesh/power-interface": ">=1.0.0, <2.0.0"
    }
  },
  "entrypoints": {
    "main": "src/main.mesh"
  },
  "settings": {
    "namespace": "@mesh/panel",
    "schema": {
      "surface": {
        "type": "object",
        "description": "Placement and sizing for the top panel shell surface.",
        "properties": {
          "anchor": {
            "type": "enum",
            "values": ["top", "bottom", "left", "right"],
            "default": "top",
            "description": "Screen edge this surface anchors to."
          },
          "layer": {
            "type": "enum",
            "values": ["background", "bottom", "top", "overlay"],
            "default": "top",
            "description": "Layer-shell stacking layer."
          },
          "width": {
            "type": "integer",
            "default": 1920,
            "min": 320,
            "max": 7680,
            "description": "Surface width in pixels."
          },
          "height": {
            "type": "integer",
            "default": 32,
            "min": 24,
            "max": 128,
            "description": "Surface height in pixels."
          },
          "exclusive_zone": {
            "type": "integer",
            "default": 32,
            "min": 0,
            "max": 256,
            "description": "Reserved compositor space in pixels."
          },
          "keyboard_mode": {
            "type": "enum",
            "values": ["none", "exclusive", "on_demand"],
            "default": "none",
            "description": "Keyboard interactivity policy for the surface."
          },
          "visible_on_start": {
            "type": "boolean",
            "default": false,
            "description": "Whether this surface starts visible when Mesh boots."
          }
        }
      }
    }
  },
  "surface_layout": {
    "size_policy": "fixed"
  },
  "accessibility": {
    "role": "toolbar",
    "label": "System panel",
    "description": "Default top panel with clock, system tray, and status indicators"
  }
}
