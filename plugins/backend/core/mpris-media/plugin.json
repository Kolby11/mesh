{
  "id": "@mesh/mpris-media",
  "name": "MESH MPRIS Media",
  "version": "0.1.0",
  "type": "backend",
  "api_version": "0.1",
  "description": "Media playback backend using MPRIS D-Bus protocol",
  "authors": ["MESH Project"],
  "capabilities": {
    "required": [
      "service.media.read",
      "service.media.control",
      "dbus.session"
    ]
  },
  "dependencies": {
    "plugins": {
      "@mesh/media-interface": ">=1.0.0, <2.0.0"
    }
  },
  "entrypoints": {
    "main": "src/main.luau"
  },
  "provides": [
    {
      "interface": "mesh.media",
      "version": "1.0",
      "backend_name": "MPRIS",
      "priority": 100
    }
  ]
}
