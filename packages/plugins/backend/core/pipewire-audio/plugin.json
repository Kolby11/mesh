{
  "id": "@mesh/pipewire-audio",
  "name": "MESH PipeWire Audio",
  "version": "0.1.0",
  "type": "backend",
  "api_version": "0.1",
  "description": "Audio backend using PipeWire",
  "authors": ["MESH Project"],
  "capabilities": {
    "required": [
      "service.audio.read",
      "service.audio.control",
      "dbus.session"
    ]
  },
  "dependencies": {
    "plugins": {
      "@mesh/audio-interface": ">=1.0.0, <2.0.0"
    },
    "binaries": [
      {
        "name": "wpctl",
        "reason": "PipeWire volume and mute control.",
        "packages": {
          "debian": "wireplumber",
          "arch": "wireplumber",
          "fedora": "wireplumber"
        }
      },
      {
        "name": "awk",
        "reason": "Shell-side parsing for backend state emission."
      },
      {
        "name": "aplay",
        "reason": "Playback for configured shell sounds.",
        "packages": {
          "debian": "alsa-utils",
          "arch": "alsa-utils",
          "fedora": "alsa-utils"
        }
      }
    ]
  },
  "entrypoints": {
    "main": "src/main.luau"
  },
  "provides": [
    {
      "interface": "mesh.audio",
      "version": "1.0",
      "backend_name": "PipeWire",
      "priority": 100
    }
  ]
}
