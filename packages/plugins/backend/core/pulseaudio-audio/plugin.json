{
  "id": "@mesh/pulseaudio-audio",
  "name": "MESH PulseAudio",
  "version": "0.1.0",
  "type": "backend",
  "api_version": "0.1",
  "description": "Audio backend using PulseAudio",
  "authors": ["MESH Project"],
  "capabilities": {
    "required": [
      "service.audio.read",
      "service.audio.control"
    ]
  },
  "dependencies": {
    "plugins": {
      "@mesh/audio-interface": ">=1.0.0, <2.0.0"
    },
    "binaries": [
      {
        "name": "pactl",
        "reason": "PulseAudio volume and mute control.",
        "packages": {
          "debian": "pulseaudio-utils",
          "arch": "libpulse",
          "fedora": "pulseaudio-utils"
        }
      },
      {
        "name": "awk",
        "reason": "Shell-side parsing for backend state emission."
      },
      {
        "name": "aplay",
        "reason": "Playback for configured shell sounds.",
        "packages": {
          "debian": "alsa-utils",
          "arch": "alsa-utils",
          "fedora": "alsa-utils"
        }
      }
    ]
  },
  "entrypoints": {
    "main": "src/main.luau"
  },
  "provides": [
    {
      "interface": "mesh.audio",
      "version": "1.0",
      "backend_name": "PulseAudio",
      "priority": 50
    }
  ]
}
