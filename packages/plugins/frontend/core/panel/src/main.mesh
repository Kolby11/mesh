<template>
  <box class="panel">
    <box class="left">
      <text class="workspace">{activeWorkspace}</text>
    </box>
    <box class="center">
      <text class="clock">{time}</text>
    </box>
    <box class="right">
      <text class="indicator network-indicator" title="{networkStatus}" aria-label="Network status">{networkStatus}</text>
      <button class="indicator volume-indicator" onclick={onVolumeClick} title="Open audio controls" aria-label="Open audio controls">
        <icon class="indicator-glyph" name="{volumeIcon}" size="16" />
        <text class="indicator-value">{volumeLevel}</text>
      </button>
      <text class="battery">{batteryText}</text>
    </box>
  </box>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "@mesh/audio@>=1.0")
local power_ok, power = pcall(require, "@mesh/power@>=1.0")
local network_ok, network = pcall(require, "@mesh/network@>=1.0")

if not audio_ok then audio = nil end
if not power_ok then power = nil end
if not network_ok then network = nil end

time = ""
batteryText = ""
volumeLevel = "0"
volumeIcon = "audio-volume-muted"
networkStatus = "disconnected"
activeWorkspace = "1"

function init()
    updateClock()
end

function updateClock()
    time = os.date("%H:%M")
    mesh.ui.request_redraw()
end

-- Derive battery label directly from proxy fields on rerender.
-- power.level is a 0..100 integer; power.available indicates whether
-- battery data is currently published by the backend.
function batteryLabel()
    if not power_ok or not power then
        return "N/A"
    end
    local lvl = power.level
    if lvl == nil then
        return "N/A"
    end
    return string.format("%d%%", lvl)
end

-- Derive volume icon directly from proxy fields on rerender.
function volumeIconFor()
    if not audio_ok or not audio then
        return "audio-volume-muted"
    end
    local muted = audio.muted
    local pct = audio.percent or 0
    if muted or pct == 0 then
        return "audio-volume-muted"
    elseif pct < 34 then
        return "audio-volume-low"
    elseif pct < 67 then
        return "audio-volume-medium"
    else
        return "audio-volume-high"
    end
end

-- Derive network status label directly from proxy fields on rerender.
-- network.connections is a list; if non-empty the panel shows "connected".
function networkStatusFor()
    if not network_ok or not network then
        return "disconnected"
    end
    local conns = network.connections
    if type(conns) == "table" and #conns > 0 then
        return "connected"
    end
    return "disconnected"
end

-- The template reads these reactive globals on every rerender.
-- Each helper reads live proxy fields directly — no callbacks required.
function onRender()
    batteryText = batteryLabel()
    volumeLevel = tostring(audio_ok and audio and math.floor(audio.percent or 0) or 0)
    volumeIcon = volumeIconFor()
    networkStatus = networkStatusFor()
end

function onVolumeClick()
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/quick-settings" })
end
</script>

<style>
.panel {
    background: token(color.surface);
    color: token(color.on-surface);
    padding: token(spacing.sm);
    gap: token(spacing.md);
    justify-content: space-between;
    align-items: center;
}

.left {
    flex-grow: 1;
    justify-content: start;
}

.center {
    flex-grow: 0;
}

.right {
    flex-grow: 1;
    justify-content: end;
    gap: token(spacing.sm);
}

.indicator {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.sm);
}

.volume-indicator {
    align-items: center;
    gap: token(spacing.xs);
}

.indicator-glyph {
    width: 16px;
    height: 16px;
    color: token(color.on-surface-variant);
}

.clock {
    font-size: token(typography.size.md);
    font-weight: 600;
}

.battery {
    font-size: token(typography.size.sm);
}
</style>
