<template>
  <button
    class="settings-button"
    onclick={onSettingsClick}
    title="{t('nav.open_settings')}"
    aria-label="{t('nav.open_settings')}"
  >
    <icon class="settings-glyph" name="settings" title="{t('nav.settings')}" size="18" />
  </button>
</template>

<script lang="luau">
function onSettingsClick(event)
    local trigger_left = event.current_target.position.margin_left or 0
    local nav_bottom = event.surface.height or event.current_target.position.margin_top or 0
    local surface_overlap = 8
    local quick_settings_width = 480
    local trigger_width = 44
    mesh.events.publish("shell.position-surface", {
        surface_id = "@mesh/quick-settings",
        margin_top = math.max(0, nav_bottom - surface_overlap),
        margin_left = math.max(0, trigger_left - (quick_settings_width - trigger_width)),
    })
    mesh.events.publish("shell.toggle-surface", { surface_id = "@mesh/quick-settings" })
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/volume-bar" })
end
</script>

<style>
.settings-button {
    width: 44px;
    height: 40px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.xs);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    text-wrap: none;
}

.settings-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
    border-radius: token(radius.full);
}

.settings-glyph {
    width: 28px;
    height: 26px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    color: token(color.on-tertiary-container);
}

@container (max-width: 760px) {
    .settings-button {
        width: 44px;
        gap: 0;
        padding-inline: token(spacing.xs);
    }
}
</style>
