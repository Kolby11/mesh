<template>
  <column class="volume-bar">
    <slider
      class="track"
      orient="vertical"
      min="0"
      max="100"
      value="{audio_percent}"
      onchange={onVolumeChange}
      title="{audio_tooltip}"
      aria-label="Volume"
    />
    <text class="label">{audio_label}</text>
  </column>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "@mesh/audio@>=1.0")
if not audio_ok then audio = nil end

icon_name = "audio-volume-muted"
audio_label = "0%"
audio_tooltip = "Volume unavailable"
audio_percent = 0

local function clamp_percent(value)
    local numeric = tonumber(value) or 0
    if numeric < 0 then return 0 end
    if numeric > 100 then return 100 end
    return math.floor(numeric + 0.5)
end

local function update_audio_copy(percent, muted)
    audio_percent = percent
    audio_label = string.format("%d%%", percent)

    if muted then
        audio_tooltip = string.format("Volume muted at %d%%", percent)
    else
        audio_tooltip = string.format("Volume %d%%", percent)
    end
end

function onRender()
    if not audio_ok or not audio or audio.available == false then
        icon_name = "audio-volume-muted"
        audio_label = "0%"
        audio_tooltip = "Audio service unavailable"
        audio_percent = 0
        return
    end

    local percent = clamp_percent(audio.percent)
    local muted = audio.muted or false

    if muted then
        icon_name = "audio-volume-muted"
    else
        if percent == 0 then
            icon_name = "audio-volume-muted"
        else
            if percent < 34 then
                icon_name = "audio-volume-low"
            else
                if percent < 67 then
                    icon_name = "audio-volume-medium"
                else
                    icon_name = "audio-volume-high"
                end
            end
        end
    end

    update_audio_copy(percent, muted)
end

function onVolumeChange(value)
    local percent = clamp_percent(value)
    local normalized = percent / 100
    update_audio_copy(percent, false)

    if audio_ok and audio and audio.available ~= false then
        audio.set_volume("default", normalized)
    else
        audio_tooltip = "Audio controls unavailable"
    end
end

function onToggleMute()
    if audio_ok and audio and audio.available ~= false then
        audio.toggle_mute()
    end
end
</script>

<style>
.volume-bar {
    width: 100%;
    height: 100%;
    flex-direction: column;
    align-items: center;
    padding-block: token(spacing.sm);
    gap: token(spacing.xs);
    background: token(color.surface);
    color: token(color.on-surface);
    border-radius: token(radius.lg);
}

.glyph {
    width: 28px;
    height: 26px;
    flex-shrink: 0;
    color: token(color.on-secondary-container);
}

.track {
    width: 28px;
    flex-grow: 1;
    color: token(color.primary);
}

.label {
    flex-shrink: 0;
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface-variant);
}
</style>
