<template>
  <box class="section">
    <box class="section-header">
      <text class="section-title">Bluetooth Devices</text>
    </box>
    <box class="section-list">
      {#if bluetooth_devices and #bluetooth_devices > 0}
        {#for device in bluetooth_devices}
          <BluetoothItem device_id="{device.id}" device_name="{device.name}" device_state="{device.state}" />
        {/for}
      {:else}
        <box class="section-message">No Bluetooth devices found</box>
      {/if}
    </box>
  </box>
</template>

<script lang="luau">
import BluetoothItem from "./bluetooth-item.mesh"

local network_ok, network = pcall(require, "@mesh/network@>=1.0")
if not network_ok then network = nil end

bluetooth_devices = {}

-- Derive bluetooth_devices directly from live proxy fields on every rerender.
-- network.devices is a runtime-defined extra emitted by the networkmanager
-- backend alongside base contract fields. We filter to kind == "bluetooth"
-- locally, consistent with the "frontend owns display logic" principle.
function onRender()
    if not network_ok or not network then
        bluetooth_devices = {}
        return
    end
    local devices = network.devices
    local bluetooth = {}
    if type(devices) == "table" then
        for _, device in ipairs(devices) do
            if device.kind == "bluetooth" then
                table.insert(bluetooth, device)
            end
        end
    end
    bluetooth_devices = bluetooth
end
</script>

<style>
.section {
    width: 100%;
    gap: token(spacing.sm);
}

.section-header {
    align-items: center;
    gap: token(spacing.sm);
}

.section-title {
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.section-list {
    width: 100%;
    gap: token(spacing.xs);
}

.section-message {
    padding: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface-variant);
    font-size: token(typography.size.sm);
    text-align: center;
}
</style>
