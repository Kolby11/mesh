<template>
  <box class="section">
    <box class="audio-header">
      <box class="audio-copy">
        <text class="section-title">Audio</text>
        <text class="audio-subtitle">{audio_backend}</text>
        <text class="audio-status">{audio_status}</text>
      </box>
      <text class="audio-value">{audio_label}</text>
    </box>
    <box class="volume-row">
      <button class="volume-button" onclick={onVolumeDown} title="Volume down" aria-label="Volume down">-</button>
      <slider class="volume-slider" min="0" max="100" value="{audio_percent}" onchange={onVolumeChange} title="{audio_tooltip}" aria-label="Volume" />
      <button class="volume-button" onclick={onVolumeUp} title="Volume up" aria-label="Volume up">+</button>
    </box>
    <box class="audio-actions">
      <button class="mute-button" onclick={onToggleMute} title="Toggle mute" aria-label="Toggle mute">
        <icon class="mute-icon" name="{icon_name}" size="18" />
      </button>
    </box>
  </box>
</template>

<script lang="luau">
local audio_ok, audio = pcall(require, "@mesh/audio@>=1.0")
if not audio_ok then audio = nil end

icon_name = "audio-volume-muted"
audio_label = "0%"
audio_tooltip = "Volume unavailable"
audio_backend = "Unavailable"
audio_percent = 0
audio_available = false
audio_controls_available = false
audio_status = "Audio unavailable"

local function clamp_percent(value)
    local numeric = tonumber(value) or 0
    if numeric < 0 then return 0 end
    if numeric > 100 then return 100 end
    return math.floor(numeric + 0.5)
end

local function update_audio_copy(percent, muted)
    audio_percent = percent
    audio_label = string.format("%d%%", percent)

    if muted or percent == 0 then
        icon_name = "audio-volume-muted"
    elseif percent < 34 then
        icon_name = "audio-volume-low"
    elseif percent < 67 then
        icon_name = "audio-volume-medium"
    else
        icon_name = "audio-volume-high"
    end

    if muted then
        audio_tooltip = string.format("Volume muted at %d%%", percent)
    else
        audio_tooltip = string.format("Volume %d%%", percent)
    end
end

-- Derive all display state from live proxy fields on every rerender.
-- No callbacks — audio.percent, audio.muted, and audio.source_plugin are
-- read directly; the runtime tracks each field for invalidation.
function onRender()
    audio_available = audio_ok and audio and audio.available ~= false
    audio_controls_available = audio_available

    if not audio_available then
        icon_name = "audio-volume-muted"
        audio_label = "0%"
        audio_tooltip = "Audio unavailable"
        audio_backend = "Unavailable"
        audio_percent = 0
        audio_status = "Audio unavailable"
        return
    end

    local percent = clamp_percent(audio.percent)
    local muted = audio.muted or false

    audio_backend = audio.source_plugin or "Unavailable"
    audio_status = ""
    update_audio_copy(percent, muted)
end

function onVolumeChange(value)
    local percent = clamp_percent(value)
    local normalized = percent / 100
    update_audio_copy(percent, false)

    if audio_ok and audio and audio.available ~= false and audio_controls_available then
        audio.set_volume("default", normalized)
    else
        audio_status = "Audio controls unavailable"
        audio_tooltip = "Audio controls unavailable"
    end
end

function onVolumeDown()
    if audio_ok and audio and audio.available ~= false and audio_controls_available then
        audio.volume_down()
    else
        audio_status = "Audio controls unavailable"
        audio_tooltip = "Audio controls unavailable"
    end
end

function onVolumeUp()
    if audio_ok and audio and audio.available ~= false and audio_controls_available then
        audio.volume_up()
    else
        audio_status = "Audio controls unavailable"
        audio_tooltip = "Audio controls unavailable"
    end
end

function onToggleMute()
    if audio_ok and audio and audio.available ~= false and audio_controls_available then
        audio.toggle_mute()
    else
        audio_status = "Audio controls unavailable"
        audio_tooltip = "Audio controls unavailable"
    end
end
</script>

<style>
.section {
    width: 100%;
    gap: token(spacing.md);
}

.audio-header {
    justify-content: space-between;
    align-items: center;
    gap: token(spacing.md);
}

.audio-copy {
    flex-direction: column;
    gap: 2px;
}

.section-title {
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface-variant);
    letter-spacing: 0;
}

.audio-subtitle {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.xs);
}

.audio-status {
    color: token(color.disabled);
    font-size: token(typography.size.xs);
}

.audio-value {
    width: 56px;
    justify-content: end;
    color: token(color.on-surface);
    font-size: token(typography.size.lg);
    font-weight: 800;
    text-wrap: none;
}

.volume-row {
    align-items: center;
    gap: token(spacing.sm);
}

.volume-button {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    border-radius: token(radius.sm);
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    font-size: token(typography.size.lg);
    font-weight: 800;
}

.volume-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.volume-slider {
    width: 100%;
    height: 36px;
    flex-grow: 1;
    color: token(color.primary);
}

.audio-actions {
    justify-content: start;
    align-items: center;
}

.mute-button {
    width: content;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface);
    text-wrap: none;
}

.mute-icon {
    width: 18px;
    height: 18px;
    color: token(color.on-surface);
}

.mute-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}
</style>
