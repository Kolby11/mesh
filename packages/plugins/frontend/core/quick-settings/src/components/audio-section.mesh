<template>
  <box class="section">
    <box class="audio-header">
      <box class="audio-copy">
        <text class="section-title">Audio</text>
        <text class="audio-subtitle">{audio_backend}</text>
      </box>
      <text class="audio-value">{audio_label}</text>
    </box>
    <box class="volume-row">
      <button class="volume-button" onclick={onVolumeDown} title="Volume down" aria-label="Volume down">-</button>
      <slider class="volume-slider" min="0" max="100" value="{audio_percent}" title="{audio_tooltip}" aria-label="Volume" />
      <button class="volume-button" onclick={onVolumeUp} title="Volume up" aria-label="Volume up">+</button>
    </box>
    <box class="audio-actions">
      <button class="mute-button" onclick={onToggleMute} title="Toggle mute" aria-label="Toggle mute">
        <icon class="mute-icon" name="{icon_name}" size="18" />
      </button>
    </box>
  </box>
</template>

<script lang="luau">
local audio = require("@mesh/audio@>=1.0")

icon_name = "audio-volume-muted"
audio_label = "0%"
audio_tooltip = "Volume unavailable"
audio_backend = "Unavailable"
audio_percent = 0

audio.on_change(function()
    local percent = audio.percent or 0
    local muted = audio.muted or false
    if muted or percent == 0 then
        icon_name = "audio-volume-muted"
    elseif percent < 34 then
        icon_name = "audio-volume-low"
    elseif percent < 67 then
        icon_name = "audio-volume-medium"
    else
        icon_name = "audio-volume-high"
    end

    audio_percent = percent
    audio_label = string.format("%d%%", percent)
    audio_backend = audio.source_plugin or "Unavailable"
    if muted then
        audio_tooltip = string.format("Volume muted at %d%%", percent)
    else
        audio_tooltip = string.format("Volume %d%%", percent)
    end
end)

function onVolumeDown()
    audio.volume_down()
end

function onVolumeUp()
    audio.volume_up()
end

function onToggleMute()
    audio.toggle_mute()
end
</script>

<style>
.section {
    width: 100%;
    gap: token(spacing.md);
}

.audio-header {
    justify-content: space-between;
    align-items: center;
    gap: token(spacing.md);
}

.audio-copy {
    flex-direction: column;
    gap: 2px;
}

.section-title {
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.audio-subtitle {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.xs);
}

.audio-value {
    width: 56px;
    justify-content: end;
    color: token(color.on-surface);
    font-size: token(typography.size.lg);
    font-weight: 800;
    text-wrap: none;
}

.volume-row {
    align-items: center;
    gap: token(spacing.sm);
}

.volume-button {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    border-radius: token(radius.sm);
    background: token(color.tertiary-container);
    color: token(color.on-tertiary-container);
    font-size: token(typography.size.lg);
    font-weight: 800;
}

.volume-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.volume-slider {
    width: 100%;
    height: 36px;
    flex-grow: 1;
    color: token(color.primary);
}

.audio-actions {
    justify-content: start;
    align-items: center;
}

.mute-button {
    width: content;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface);
    text-wrap: none;
}

.mute-icon {
    width: 18px;
    height: 18px;
    color: token(color.on-surface);
}

.mute-button:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}
</style>
