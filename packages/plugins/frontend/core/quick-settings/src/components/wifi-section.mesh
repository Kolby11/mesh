<template>
  <box class="section">
    <box class="section-header">
      <text class="section-title">Wi-Fi Networks</text>
    </box>
    <box class="section-list">
      {#if wifi_enabled and wifi_networks and #wifi_networks > 0}
        {#for network in wifi_networks}
          <WifiItem network_id="{network.id}" network_name="{network.name}" network_strength="{network.strength}" />
        {/for}
      {:else if wifi_enabled}
        <box class="section-message">Scanning for networks…</box>
      {:else}
        <box class="section-message">Wi-Fi is disabled</box>
      {/if}
    </box>
  </box>
</template>

<script lang="luau">
import WifiItem from "./wifi-item.mesh"

wifi_networks = {}

local network_ok, network_iface = pcall(require, "@mesh/network@>=1.0")
if network_ok and network_iface then
    mesh.service.on("network", "sync_network_state")
end

function sync_network_state()
    if not network_ok or not network_iface then
        wifi_networks = {}
        return
    end

    local networks = network_iface.wifi_scan()
    wifi_networks = networks or {}
end

if network_ok and network_iface then
    sync_network_state()
end
</script>

<style>
.section {
    width: 100%;
    gap: token(spacing.sm);
}

.section-header {
    align-items: center;
    gap: token(spacing.sm);
}

.section-title {
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.section-list {
    width: 100%;
    gap: token(spacing.xs);
}

.section-message {
    padding: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface-variant);
    font-size: token(typography.size.sm);
    text-align: center;
}
</style>
