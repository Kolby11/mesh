<template>
  <box class="section">
    <box class="section-header">
      <text class="section-title">Wi-Fi Networks</text>
    </box>
    <box class="section-list">
      {#if wifi_enabled and wifi_networks and #wifi_networks > 0}
        {#for network in wifi_networks}
          <WifiItem network_id="{network.id}" network_name="{network.name}" network_strength="{network.strength}" />
        {/for}
      {:else if wifi_enabled}
        <box class="section-message">Scanning for networks…</box>
      {:else}
        <box class="section-message">Wi-Fi is disabled</box>
      {/if}
    </box>
  </box>
</template>

<script lang="luau">
import WifiItem from "./wifi-item.mesh"

local network_ok, network = pcall(require, "@mesh/network@>=1.0")
if not network_ok then network = nil end

wifi_networks = {}
wifi_enabled = false

-- Derive wifi_networks and wifi_enabled directly from live proxy fields on
-- every rerender. network.networks is emitted by the networkmanager backend
-- as a runtime-defined extra alongside the base contract fields.
-- network.wifi_enabled is a base-contract state field.
function onRender()
    if not network_ok or not network then
        wifi_networks = {}
        wifi_enabled = false
        return
    end
    wifi_enabled = network.wifi_enabled or false
    local nets = network.networks
    wifi_networks = (type(nets) == "table") and nets or {}
end
</script>

<style>
.section {
    width: 100%;
    gap: token(spacing.sm);
}

.section-header {
    align-items: center;
    gap: token(spacing.sm);
}

.section-title {
    font-size: token(typography.size.xs);
    font-weight: 700;
    color: token(color.on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.section-list {
    width: 100%;
    gap: token(spacing.xs);
}

.section-message {
    padding: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface-variant);
    font-size: token(typography.size.sm);
    text-align: center;
}
</style>
