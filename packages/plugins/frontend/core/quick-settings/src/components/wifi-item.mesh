<template>
  <button class="network-item" onclick={onConnectWiFi}>
    <box class="network-info">
      <text class="network-name">{network_name}</text>
      <text class="network-strength">{network_strength}&#37;</text>
      <text class="network-status">{connection_status}</text>
    </box>
  </button>
</template>

<script lang="luau">
network_id = ""
network_name = ""
network_strength = "0"
connection_status = ""

function onConnectWiFi(event)
    if not network_id or network_id == "" then
        connection_status = "Connection details unavailable"
        mesh.log.warn("Connection details unavailable")
        return
    end

    local ok, network = pcall(require, "@mesh/network@>=1.0")
    if not ok or not network or network.available == false then
        connection_status = "Network unavailable"
        mesh.log.warn("Network unavailable for Wi-Fi connection")
        return
    end

    if network.controls_available == false or network.permission_denied == true then
        connection_status = "Network controls unavailable"
        mesh.log.warn("Network controls unavailable for Wi-Fi connection")
        return
    end

    connection_status = ""
    network.connect(network_id)
end
</script>

<style>
.network-item {
    width: 100%;
    padding: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container-high);
    color: token(color.on-surface);
    text-align: start;
    justify-content: space-between;
    align-items: center;
}

.network-item:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.network-info {
    flex-direction: column;
    gap: 2px;
    flex-grow: 1;
}

.network-name {
    font-size: token(typography.size.sm);
    font-weight: 600;
    text-wrap: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.network-strength {
    font-size: token(typography.size.xs);
    color: token(color.on-surface-variant);
}

.network-status {
    font-size: token(typography.size.xs);
    color: token(color.disabled);
}
</style>
