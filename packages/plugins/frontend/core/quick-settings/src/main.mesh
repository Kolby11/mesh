<template>
  <column class="quick-settings">
    <box class="header">
      <text class="title">Quick Settings</text>
      <button class="close-button" onclick={onClose} title="Close quick settings" aria-label="Close quick settings">Close</button>
    </box>
    <box class="chips">
      <button class="chip" onclick={onToggleWiFi} title="Toggle Wi-Fi" aria-label="Toggle Wi-Fi">Wi-Fi</button>
      <button class="chip" onclick={onToggleBluetooth} title="Toggle Bluetooth" aria-label="Toggle Bluetooth">Bluetooth</button>
      <button class="chip wide">Do Not Disturb</button>
    </box>
    <box class="body">
      <box class="nav-rail">
        <button class="nav-btn" onclick={onSelectWifi} title="Wi-Fi settings" aria-label="Wi-Fi settings">
          <icon name="network-wireless" size="18" />
          <text class="nav-label">Wi-Fi</text>
        </button>
        <button class="nav-btn" onclick={onSelectBluetooth} title="Bluetooth settings" aria-label="Bluetooth settings">
          <icon name="bluetooth" size="18" />
          <text class="nav-label">Bluetooth</text>
        </button>
        <button class="nav-btn" onclick={onSelectAudio} title="Audio settings" aria-label="Audio settings">
          <icon name="{icon_name}" size="18" />
          <text class="nav-label">Audio</text>
        </button>
      </box>
      <box class="drawer">
        {#if active_section == "wifi"}
          <WifiSection wifi_enabled="{wifi_enabled}" />
        {/if}
        {#if active_section == "bluetooth"}
          <BluetoothSection />
        {/if}
        {#if active_section == "audio"}
          <AudioSection />
        {/if}
        {#if active_section == ""}
          <box class="drawer-empty">
            <text class="drawer-hint">Select a section from the left</text>
          </box>
        {/if}
      </box>
    </box>
  </column>
</template>

<script lang="luau">
import WifiSection from "./components/wifi-section.mesh"
import BluetoothSection from "./components/bluetooth-section.mesh"
import AudioSection from "./components/audio-section.mesh"

local audio_ok, audio = pcall(require, "@mesh/audio@>=1.0")
local network_ok, network = pcall(require, "@mesh/network@>=1.0")

if not audio_ok then audio = nil end
if not network_ok then network = nil end

active_section = "wifi"
icon_name = "audio-volume-muted"
wifi_enabled = false
network_available = false
network_controls_available = false
network_status = "Network unavailable"

-- Derive audio nav icon directly from proxy fields on every rerender.
-- No callbacks — the template reads icon_name which is updated by onRender.
function audioIconFor()
    if not audio_ok or not audio then
        return "audio-volume-muted"
    end
    local muted = audio.muted
    local pct = audio.percent or 0
    if muted or pct == 0 then
        return "audio-volume-muted"
    elseif pct < 34 then
        return "audio-volume-low"
    elseif pct < 67 then
        return "audio-volume-medium"
    else
        return "audio-volume-high"
    end
end

-- Derive wifi_enabled state directly from proxy fields on every rerender.
-- network.wifi_enabled is emitted by the networkmanager backend.
function wifiEnabledFor()
    if not network_ok or not network or network.available == false then
        return false
    end
    return network.wifi_enabled or false
end

-- Called on rerender to sync reactive globals from live proxy fields.
function onRender()
    icon_name = audioIconFor()
    network_available = network_ok and network and network.available ~= false
    network_controls_available = network_available and network.controls_available ~= false and network.permission_denied ~= true
    wifi_enabled = wifiEnabledFor()
    if not network_available then
        network_status = "Network unavailable"
    elseif not network_controls_available then
        network_status = "Network controls unavailable"
    else
        network_status = ""
    end
end

function sync_nav_classes()
    wifi_nav_class = active_section == "wifi" and "nav-btn nav-active" or "nav-btn"
    bt_nav_class = active_section == "bluetooth" and "nav-btn nav-active" or "nav-btn"
    audio_nav_class = active_section == "audio" and "nav-btn nav-active" or "nav-btn"
end

function onSelectWifi()
    if active_section == "wifi" then
        active_section = ""
    else
        active_section = "wifi"
    end
    sync_nav_classes()
end

function onSelectBluetooth()
    if active_section == "bluetooth" then
        active_section = ""
    else
        active_section = "bluetooth"
    end
    sync_nav_classes()
end

function onSelectAudio()
    if active_section == "audio" then
        active_section = ""
    else
        active_section = "audio"
    end
    sync_nav_classes()
end

function onToggleWiFi()
    if not network_ok or not network or network.available == false then
        network_status = "Network unavailable"
        return
    end
    if network.controls_available == false or network.permission_denied == true then
        network_status = "Network controls unavailable"
        return
    end

    -- Read current state directly from the proxy field, then send the command.
    local enabled = network.wifi_enabled or false
    network.set_wifi_enabled(not enabled)
end

function onToggleBluetooth()
    mesh.log.info("Bluetooth toggle clicked")
end

function onClose()
    mesh.events.publish("shell.hide-surface", { surface_id = "@mesh/quick-settings" })
end

</script>

<style>
.quick-settings {
    background: token(color.surface);
    color: token(color.on-surface);
    padding: token(spacing.lg);
    gap: token(spacing.md);
    width: 100%;
    height: 100%;
}

.header {
    justify-content: space-between;
    align-items: center;
    gap: token(spacing.md);
}

.title {
    font-size: token(typography.size.lg);
    font-weight: 700;
}

.close-button {
    width: content;
    flex-shrink: 0;
    padding-block: token(spacing.xs);
    padding-inline: token(spacing.sm);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface);
    text-wrap: none;
}

.close-button:hover {
    background: token(color.surface-container-high);
}

.chips {
    flex-wrap: nowrap;
    gap: token(spacing.sm);
}

.chip {
    width: content;
    flex-shrink: 0;
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.secondary-container);
    color: token(color.on-secondary-container);
    text-wrap: none;
}

.wide {
    width: 172px;
}

.chip:hover {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.body {
    flex-grow: 1;
    flex-direction: row;
    gap: token(spacing.md);
    overflow-y: hidden;
}

.nav-rail {
    width: 96px;
    flex-shrink: 0;
    flex-direction: column;
    gap: token(spacing.xs);
}

.nav-btn {
    border-radius: 10px;
    transition: border-radius 180ms;
    width: 100%;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding-block: token(spacing.sm);
    padding-inline: token(spacing.xs);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    color: token(color.on-surface-variant);
    text-wrap: none;
}

.nav-btn:hover {
    border-radius: full;
    background: token(color.surface-container-high);
    color: token(color.on-surface);
}

.nav-active {
    background: token(color.primary-container);
    color: token(color.on-primary-container);
}

.nav-label {
    font-size: token(typography.size.xs);
    font-weight: 600;
}

.drawer {
    flex-grow: 1;
    flex-direction: column;
    gap: token(spacing.md);
    padding: token(spacing.md);
    border-radius: token(radius.sm);
    background: token(color.surface-container);
    overflow-y: auto;
}

.drawer-empty {
    flex-grow: 1;
    justify-content: center;
    align-items: center;
}

.drawer-hint {
    color: token(color.on-surface-variant);
    font-size: token(typography.size.sm);
    text-align: center;
}
</style>
