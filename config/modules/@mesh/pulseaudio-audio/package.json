{
  "name": "@mesh/pulseaudio-audio",
  "version": "0.1.0",
  "description": "PulseAudio audio provider module.",
  "repository": {
    "type": "git",
    "url": "https://example.invalid/mesh/pulseaudio-audio.git"
  },
  "mesh": {
    "apiVersion": "0.1",
    "kind": "backend",
    "capabilities": {
      "required": [
        "exec.pactl",
        "exec.aplay"
      ]
    },
    "dependencies": {
      "binaries": [
        {
          "name": "pactl",
          "reason": "PulseAudio volume and mute control.",
          "packages": {
            "debian": "pulseaudio-utils",
            "arch": "libpulse",
            "fedora": "pulseaudio-utils"
          }
        },
        {
          "name": "aplay",
          "reason": "Playback for shell sound effects.",
          "packages": {
            "debian": "alsa-utils",
            "arch": "alsa-utils",
            "fedora": "alsa-utils"
          }
        }
      ]
    },
    "implements": [
      {
        "interface": "mesh.audio",
        "provider": "pulseaudio",
        "label": "PulseAudio",
        "priority": 50
      }
    ]
  }
}
