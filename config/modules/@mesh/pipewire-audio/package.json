{
  "name": "@mesh/pipewire-audio",
  "version": "0.1.0",
  "description": "PipeWire audio provider module.",
  "repository": {
    "type": "git",
    "url": "https://example.invalid/mesh/pipewire-audio.git"
  },
  "mesh": {
    "apiVersion": "0.1",
    "kind": "backend",
    "capabilities": {
      "required": [
        "exec.wpctl",
        "exec.aplay"
      ]
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": ["en"]
    },
    "dependencies": {
      "binaries": [
        {
          "name": "wpctl",
          "reason": "PipeWire volume and mute control.",
          "packages": {
            "debian": "wireplumber",
            "arch": "wireplumber",
            "fedora": "wireplumber"
          }
        },
        {
          "name": "aplay",
          "reason": "Playback for shell sound effects.",
          "packages": {
            "debian": "alsa-utils",
            "arch": "alsa-utils",
            "fedora": "alsa-utils"
          }
        }
      ]
    },
    "implements": [
      {
        "interface": "mesh.audio",
        "provider": "pipewire",
        "label": "PipeWire",
        "priority": 100
      }
    ],
    "contributes": {
      "settings": {
        "namespace": "@mesh/pipewire-audio",
        "schema": {
          "low_latency_mode": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
