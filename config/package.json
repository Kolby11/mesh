{
  "name": "@mesh/local-config",
  "version": "0.1.0",
  "description": "Local MESH module graph.",
  "private": true,
  "mesh": {
    "schemaVersion": 1,
    "modulesDir": "../modules",
    "modules": {
      "@mesh/navigation-bar": {
        "kind": "frontend",
        "path": "frontend/navigation-bar",
        "enabled": true
      },
      "@mesh/pipewire-audio": {
        "kind": "backend",
        "path": "backend/pipewire-audio",
        "enabled": true
      },
      "@mesh/pulseaudio-audio": {
        "kind": "backend",
        "path": "backend/pulseaudio-audio",
        "enabled": true
      }
    },
    "providers": {
      "mesh.audio": "@mesh/pipewire-audio"
    },
    "layout": {
      "entrypoint": "@mesh/navigation-bar:main"
    }
  }
}
