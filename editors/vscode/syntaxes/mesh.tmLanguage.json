{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MESH",
  "scopeName": "source.mesh",
  "patterns": [
    { "include": "#script-block" },
    { "include": "#style-block" },
    { "include": "#template-block" },
    { "include": "#comment" }
  ],
  "repository": {
    "comment": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.mesh"
    },
    "template-block": {
      "begin": "(<)(template)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.mesh" },
        "2": { "name": "entity.name.tag.mesh" },
        "4": { "name": "punctuation.definition.tag.end.mesh" }
      },
      "end": "(</)(template)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.mesh" },
        "2": { "name": "entity.name.tag.mesh" },
        "3": { "name": "punctuation.definition.tag.end.mesh" }
      },
      "contentName": "meta.embedded.block.html",
      "patterns": [{ "include": "text.html.basic" }]
    },
    "script-block": {
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.mesh" },
        "2": { "name": "entity.name.tag.mesh" },
        "4": { "name": "punctuation.definition.tag.end.mesh" }
      },
      "end": "(</)(script)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.mesh" },
        "2": { "name": "entity.name.tag.mesh" },
        "3": { "name": "punctuation.definition.tag.end.mesh" }
      },
      "contentName": "meta.embedded.block.lua",
      "patterns": [{ "include": "source.lua" }]
    },
    "style-block": {
      "begin": "(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.mesh" },
        "2": { "name": "entity.name.tag.mesh" },
        "4": { "name": "punctuation.definition.tag.end.mesh" }
      },
      "end": "(</)(style)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.mesh" },
        "2": { "name": "entity.name.tag.mesh" },
        "3": { "name": "punctuation.definition.tag.end.mesh" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [{ "include": "source.css" }]
    }
  }
}
